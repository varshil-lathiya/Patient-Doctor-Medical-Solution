<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leave Management - PDMS Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .modal { display: none; backdrop-filter: blur(8px); }
        .modal.active { display: flex; }
        .animate-in { animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
        
        .tab-btn.active { background: #6366f1 !important; color: white !important; box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.2); }
        .tab-btn.active .count-badge { background: rgba(255,255,255,0.2) !important; color: white !important; }
        .status-badge { padding: 0.375rem 1.0rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0; }
    </style>
</head>

<body class="bg-[#f8fafc] text-slate-800">

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar Navigation -->
        <%- include('../components/admin-sidebar', { active: 'leaves' }) %>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto p-6 md:p-10">
            <header class="mb-10 flex flex-col xl:flex-row xl:items-center justify-between gap-6 animate-in">
                <div>
                    <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Absence Operations</h2>
                    <p class="text-slate-500 text-sm mt-1">Review and synchronize staff leave applications</p>
                </div>
                
                <!-- Tab Controls -->
                <div class="bg-white p-2 rounded-2xl shadow-sm border border-slate-200 flex gap-1">
                    <button onclick="switchTab('pending')" id="tab-pending" class="tab-btn active px-6 py-2.5 rounded-xl font-bold text-[12px] uppercase tracking-normal transition-all flex items-center gap-2">
                        <span>Pending</span>
                        <span class="count-badge bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded-lg text-[11px] font-bold tracking-normal"><%= counts.pending %></span>
                    </button>
                    <button onclick="switchTab('approved')" id="tab-approved" class="tab-btn px-6 py-2.5 rounded-xl font-bold text-slate-400 text-[12px] uppercase tracking-normal hover:bg-slate-50 transition-all flex items-center gap-2">
                        <span>Approved</span>
                        <span class="count-badge bg-emerald-50 text-emerald-600 px-2 py-0.5 rounded-lg text-[11px] font-bold tracking-normal"><%= counts.approved %></span>
                    </button>
                    <button onclick="switchTab('rejected')" id="tab-rejected" class="tab-btn px-6 py-2.5 rounded-xl font-bold text-slate-400 text-[12px] uppercase tracking-normal hover:bg-slate-50 transition-all flex items-center gap-2">
                        <span>Rejected</span>
                        <span class="count-badge bg-rose-50 text-rose-500 px-2 py-0.5 rounded-lg text-[11px] font-bold tracking-normal"><%= counts.rejected %></span>
                    </button>
                </div>
            </header>

            <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 overflow-hidden animate-in">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50/50">
                                <th class="px-10 py-8 text-sm font-bold text-slate-500 uppercase tracking-normal">Staff Identity</th>
                                <th class="px-10 py-8 text-sm font-bold text-slate-500 uppercase tracking-normal">Registry Details</th>
                                <th class="px-10 py-8 text-sm font-bold text-slate-500 uppercase tracking-normal">Absence Schedule</th>
                                <th class="px-10 py-8 text-sm font-bold text-slate-500 uppercase tracking-normal">Justification</th>
                                <th class="px-10 py-8 text-sm font-bold text-slate-500 uppercase tracking-normal text-center">Lifecycle</th>
                                <th class="px-10 py-8 text-sm font-bold text-slate-500 uppercase tracking-normal text-right">Operations</th>
                            </tr>
                        </thead>
                        <tbody id="leave-table-body" class="divide-y divide-slate-50 font-semibold">
                            <% if (leaves && leaves.length > 0) { %>
                                <% leaves.forEach(leave => { %>
                                    <tr class="leave-row hover:bg-indigo-50/10 transition-colors group" data-status="<%= leave.status %>">
                                        <td class="px-10 py-8">
                                            <div class="flex items-center gap-5">
                                                <div class="w-14 h-14 rounded-[1.5rem] bg-indigo-600 text-white flex items-center justify-center font-black text-base shadow-xl shadow-indigo-100">
                                                    <%= leave.firstname[0] %><%= leave.lastname[0] %>
                                                </div>
                                                <div>
                                                    <p class="text-slate-900 leading-none text-base font-bold">
                                                        <%= leave.role_name === 'Doctor' ? 'Dr.' : '' %> <%= leave.firstname %> <%= leave.lastname %>
                                                    </p>
                                                    <p class="text-xs font-bold text-slate-400 mt-2 uppercase tracking-wider flex items-center gap-2">
                                                        <i class="far fa-clock text-xs"></i>
                                                        <%= new Date(leave.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                    </p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-10 py-8">
                                            <span class="px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-normal <%= leave.role_name === 'Doctor' ? 'bg-indigo-50 text-indigo-600' : 'bg-emerald-50 text-emerald-600' %>">
                                                <%= leave.role_name %>
                                            </span>
                                            <p class="text-sm font-bold text-slate-500 mt-3 ml-1 flex items-center gap-2">
                                                <span class="w-2 h-2 rounded-full bg-slate-200"></span>
                                                <%= leave.department || 'Clinical Ops' %>
                                            </p>
                                        </td>
                                        <td class="px-10 py-8">
                                            <div class="space-y-3">
                                                <div class="flex items-center gap-3 text-sm font-bold text-slate-700">
                                                    <div class="w-7 h-7 rounded-lg bg-rose-50 text-rose-500 flex items-center justify-center"><i class="fas fa-plane-departure text-xs"></i></div>
                                                    <span><%= new Date(leave.from_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                                                </div>
                                                <div class="flex items-center gap-3 text-sm font-bold text-slate-400">
                                                    <div class="w-7 h-7 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center"><i class="fas fa-plane-arrival text-xs"></i></div>
                                                    <span><%= new Date(leave.to_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-10 py-8">
                                            <div class="max-w-[250px] bg-slate-50 p-5 rounded-2xl border border-slate-100 group-hover:bg-white transition-colors">
                                                <p class="text-sm font-bold text-slate-600 leading-relaxed italic line-clamp-2">
                                                    "<%= leave.reason %>"
                                                </p>
                                            </div>
                                        </td>
                                        <td class="px-10 py-8 text-center">
                                            <% if (leave.status === 'pending') { %>
                                                <span class="bg-amber-50 text-amber-600 px-6 py-2.5 rounded-2xl text-xs font-bold uppercase tracking-normal border border-amber-100">Review Pending</span>
                                            <% } else if (leave.status === 'approved') { %>
                                                <span class="bg-emerald-50 text-emerald-600 px-6 py-2.5 rounded-2xl text-xs font-bold uppercase tracking-normal border border-emerald-100">Authorized</span>
                                            <% } else { %>
                                                <span class="bg-rose-50 text-rose-600 px-6 py-2.5 rounded-2xl text-xs font-bold uppercase tracking-normal border border-rose-100">Declined</span>
                                            <% } %>
                                        </td>
                                        <td class="px-10 py-8 text-right">
                                            <% if (leave.status === 'pending') { %>
                                                <div class="flex justify-end gap-3">
                                                    <button onclick="handleLeave('<%= leave.id %>', 'approved', '<%= leave.role_name %>')"
                                                        class="w-14 h-14 bg-emerald-50 text-emerald-600 hover:bg-emerald-600 hover:text-white rounded-[1.2rem] flex items-center justify-center transition-all shadow-sm transform active:scale-95"
                                                        title="Authorize Application">
                                                        <i class="fas fa-check-double text-lg"></i>
                                                    </button>
                                                    <button onclick="handleLeave('<%= leave.id %>', 'rejected', '<%= leave.role_name %>')"
                                                        class="w-14 h-14 bg-rose-50 text-rose-500 hover:bg-rose-600 hover:text-white rounded-[1.2rem] flex items-center justify-center transition-all shadow-sm transform active:scale-95"
                                                        title="Decline Application">
                                                        <i class="fas fa-ban text-lg"></i>
                                                    </button>
                                                </div>
                                            <% } else { %>
                                                <div class="flex items-center justify-end gap-3 text-slate-300">
                                                    <div class="w-3 h-3 rounded-full bg-slate-200"></div>
                                                    <span class="text-xs font-bold uppercase tracking-wide italic">Archived</span>
                                                </div>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                            
                            <!-- Empty States -->
                            <tr id="empty-state" class="hidden">
                                <td colspan="6" class="px-10 py-32 text-center bg-white">
                                    <div class="w-32 h-32 bg-slate-50 rounded-[2.5rem] flex items-center justify-center mx-auto mb-8 shadow-inner">
                                        <i class="fas fa-calendar-alt text-5xl text-slate-200"></i>
                                    </div>
                                    <h3 class="text-2xl font-bold text-slate-400 tracking-tight">Registry Clean</h3>
                                    <p class="text-slate-500 font-semibold mt-2 text-base">No absence reports identified for this classification.</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- Decision Modal -->
    <div id="remark-modal" class="modal fixed inset-0 bg-slate-900/80 items-center justify-center z-50 p-4">
        <div class="animate-in bg-white rounded-[3rem] shadow-2xl max-w-lg w-full p-12 overflow-hidden relative">
            <div class="absolute top-0 right-0 p-8 opacity-5"><i class="fas fa-stamp text-8xl"></i></div>
            
            <h3 id="remark-title" class="text-3xl font-bold text-slate-900 mb-2 tracking-tight">Registry Verdict</h3>
            <p class="text-slate-400 mb-10 font-semibold text-base tracking-tight leading-relaxed">Provide final confirmation remarks. This feedback will be logged for professional records.</p>

            <div class="space-y-4 mb-10">
                <label class="text-xs font-bold text-indigo-400 uppercase tracking-normal ml-1">Official Statement</label>
                <textarea id="admin-remark" rows="4"
                    class="w-full px-8 py-6 bg-slate-50 border-0 rounded-[2rem] focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold resize-none placeholder:text-slate-300 text-base"
                    placeholder="Document your decision rationale here..."></textarea>
            </div>

            <div class="flex gap-6">
                <button onclick="closeModal('remark-modal')"
                    class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold py-5 rounded-[2rem] transition-all uppercase tracking-normal text-xs">Abort Decision</button>
                <button id="confirm-btn"
                    class="flex-1 text-white font-bold py-5 rounded-[2rem] shadow-xl transition-all transform active:scale-95 uppercase tracking-normal text-xs"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let currentLeaveId = null;
        let currentStatus = null;
        let currentRole = null;

        function openModal(id) { document.getElementById(id).classList.add('active'); document.body.style.overflow = 'hidden'; }
        function closeModal(id) { document.getElementById(id).classList.remove('active'); document.body.style.overflow = 'auto'; }

        function handleLeave(id, status, role) {
            currentLeaveId = id;
            currentStatus = status;
            currentRole = role;

            const btn = document.getElementById('confirm-btn');
            btn.textContent = status === 'approved' ? 'Authorize Approval' : 'Submit Decline';
            btn.className = `flex-1 ${status === 'approved' ? 'bg-indigo-600 hover:bg-slate-900 shadow-indigo-100' : 'bg-rose-500 hover:bg-slate-900 shadow-rose-100'} text-white font-bold py-5 rounded-[2rem] shadow-xl transition-all transform active:scale-95 uppercase tracking-normal text-xs`;

            openModal('remark-modal');
        }

        document.getElementById('confirm-btn').onclick = async () => {
            const remark = document.getElementById('admin-remark').value;
            try {
                const response = await fetch('/admin/update-leave-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: currentLeaveId, status: currentStatus, admin_remark: remark, role: currentRole })
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire({ 
                        title: 'Verdict Recorded!', 
                        text: result.message, 
                        icon: 'success', 
                        position: 'top',
                        confirmButtonColor: '#6366f1',
                        customClass: { popup: 'rounded-[2.5rem]' }
                    }).then(() => window.location.reload());
                }
            } catch (err) {
                Swal.fire({ title: 'System Identity Error', text: 'Synchronization failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } });
            }
        };

        function switchTab(status) {
            // Update UI buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active', 'bg-indigo-600', 'text-white');
                btn.classList.add('text-slate-400', 'hover:bg-slate-50');
            });
            const activeTab = document.getElementById(`tab-${status}`);
            activeTab.classList.add('active');
            activeTab.classList.remove('text-slate-400', 'hover:bg-slate-50');

            // Filter rows
            let visibleCount = 0;
            document.querySelectorAll('.leave-row').forEach(row => {
                if (row.dataset.status === status) {
                    row.classList.remove('hidden');
                    visibleCount++;
                } else {
                    row.classList.add('hidden');
                }
            });

            // Handle empty state
            const emptyState = document.getElementById('empty-state');
            if (visibleCount === 0) {
                emptyState.classList.remove('hidden');
            } else {
                emptyState.classList.add('hidden');
            }
        }

        function logout() {
            Swal.fire({
                title: 'Logout?',
                text: "Are you sure you want to end your session?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#6366f1',
                cancelButtonColor: '#f43f5e',
                confirmButtonText: 'Yes, Logout',
                customClass: {
                    popup: 'rounded-[2rem]',
                    confirmButton: 'rounded-xl px-10 py-3 font-bold',
                    cancelButton: 'rounded-xl px-10 py-3 font-bold'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/logout';
                }
            })
        }

        // Initialize with pending tab
        window.onload = () => {
            switchTab('pending');
        };

        window.onclick = (e) => { if (e.target.classList.contains('modal')) closeModal(e.target.id); }
    </script>
</body>

</html>