<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Medical Staff - PDMS Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.4); }
        .modal { display: none; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        .modal.active { display: flex; }
        .animate-in { animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }

        /* Compact Card Adjustments */
        .doctor-card { width: 100%; max-width: 320px; margin: 0 auto; }
        .avatar-container { border: 4px solid white; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); }
        .rotate-180 { transform: translateY(-50%) rotate(180deg) !important; }
    </style>
</head>

<body class="bg-[#f8fafc] text-slate-800">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar Navigation -->
        <%- include('../components/admin-sidebar', { active: 'doctors' }) %>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto p-6 md:p-10 bg-[#f8fafc]">
            <header class="mb-10 flex flex-col xl:flex-row xl:items-center justify-between gap-6 animate-in">
                <div>
                    <h2 class="text-2xl font-bold text-[#0f172a] tracking-tight">Medical Staff</h2>
                    <p class="text-slate-500 text-sm mt-1">Directory of registered doctors and specialists</p>
                </div>
                
                <div class="flex flex-wrap items-center gap-4">
                    <button onclick="openAddModal()"
                        class="bg-[#0f172a] hover:bg-slate-800 text-white font-bold px-8 py-3 rounded-xl flex items-center gap-2 shadow-lg transition-all transform active:scale-95 group">
                        <i class="fas fa-plus text-xs group-hover:rotate-90 transition-transform"></i>
                        <span class="text-sm font-bold">Add Doctor</span>
                    </button>
                    
                    <div class="flex flex-wrap gap-3">
                        <!-- Name Search -->
                        <div class="relative">
                            <input type="text" id="search-input" placeholder="Search name..."
                                class="pl-12 pr-6 py-3 w-72 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-600 outline-none transition-all font-semibold text-[13px] text-slate-400"
                                onkeyup="filterDoctors()">
                            <i class="fas fa-search text-slate-300 absolute left-5 top-1/2 -translate-y-1/2 text-xs"></i>
                        </div>

                        <!-- Department Filter -->
                        <div class="relative">
                            <select id="dept-filter" onchange="filterDoctors()" 
                                class="pl-10 pr-12 py-3 w-56 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-600 outline-none transition-all font-bold text-[13px] text-slate-500 appearance-none cursor-pointer">
                                <option value="">All Departments</option>
                                <% departments.forEach(dept => { %>
                                    <option value="<%= dept %>"><%= dept %></option>
                                <% }) %>
                            </select>
                            <i class="fas fa-filter text-slate-300 absolute left-4 top-1/2 -translate-y-1/2 text-[10px]"></i>
                            <i class="fas fa-chevron-down text-slate-400 absolute right-5 top-1/2 -translate-y-1/2 text-[10px]"></i>
                        </div>
                    </div>
                </div>
            </header>

            <% 
                const colorMap = {
                    'Cardiology': { header: 'bg-rose-100', initials: 'bg-rose-600', pill: 'bg-rose-50 text-rose-600 border-rose-100', icon: 'text-rose-500', btn: 'bg-rose-600' },
                    'Neurology': { header: 'bg-indigo-100', initials: 'bg-indigo-600', pill: 'bg-indigo-50 text-indigo-600 border-indigo-100', icon: 'text-indigo-500', btn: 'bg-indigo-600' },
                    'Orthopedics': { header: 'bg-purple-100', initials: 'bg-purple-600', pill: 'bg-purple-50 text-purple-600 border-purple-100', icon: 'text-purple-500', btn: 'bg-purple-600' },
                    'Oncology': { header: 'bg-emerald-100', initials: 'bg-emerald-600', pill: 'bg-emerald-50 text-emerald-600 border-emerald-100', icon: 'text-emerald-500', btn: 'bg-emerald-600' },
                    'Pulmonology': { header: 'bg-sky-100', initials: 'bg-sky-600', pill: 'bg-sky-50 text-sky-600 border-sky-100', icon: 'text-sky-500', btn: 'bg-sky-600' },
                    'Rheumatology': { header: 'bg-orange-100', initials: 'bg-orange-600', pill: 'bg-orange-50 text-orange-600 border-orange-100', icon: 'text-orange-500', btn: 'bg-orange-600' },
                    'Ophthalmology': { header: 'bg-blue-100', initials: 'bg-blue-600', pill: 'bg-blue-50 text-blue-600 border-blue-100', icon: 'text-blue-500', btn: 'bg-blue-600' },
                    'Nephrology': { header: 'bg-indigo-100', initials: 'bg-indigo-800', pill: 'bg-indigo-50 text-indigo-800 border-indigo-100', icon: 'text-indigo-800', btn: 'bg-indigo-800' }
                };
                const getDeptColors = (dept) => colorMap[dept] || { header: 'bg-slate-100', initials: 'bg-slate-600', pill: 'bg-slate-50 text-slate-600 border-slate-100', icon: 'text-slate-500', btn: 'bg-[#0f172a]' };
            %>

            <div id="doctor-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
                <% if (doctors && doctors.length > 0) { %>
                    <% doctors.forEach((doc, index) => { 
                        const colors = getDeptColors(doc.department);
                    %>
                        <div class="doctor-card bg-white rounded-3xl shadow-sm border border-slate-200/60 overflow-hidden hover:shadow-xl transition-all duration-300 animate-in group" 
                             data-delay="<%=(index % 5) * 0.1%>s"
                             data-name="<%= doc.firstname %> <%= doc.lastname %>"
                             data-dept="<%= doc.department %>"
                             data-degree="<%= doc.degree %>">
                            
                            <!-- Card Header -->
                            <div class="h-20 <%= colors.header %> relative transition-colors duration-500">
                                <div class="absolute -bottom-7 left-1/2 -translate-x-1/2">
                                    <div class="w-14 h-14 rounded-[1.5rem] <%= colors.initials %> flex items-center justify-center text-white text-lg font-black shadow-xl border-4 border-white transform transition-transform duration-500 group-hover:scale-110">
                                        <%= doc.firstname[0] %><%= doc.lastname[0] %>
                                    </div>
                                </div>
                            </div>

                            <div class="pt-10 pb-4 px-6 text-center">
                                <h3 class="text-lg font-bold text-slate-900 leading-tight mb-2 tracking-tight">Dr. <%= doc.firstname %> <%= doc.lastname %></h3>
                                <div class="mb-4">
                                    <span class="font-bold text-[11px] uppercase tracking-[0.15em] px-4 py-1.5 <%= colors.pill %> rounded-xl shadow-sm border border-white/50"><%= doc.department %></span>
                                </div>
                                
                                <div class="space-y-1.5 mb-5">
                                    <div class="flex items-center gap-3 text-slate-500 text-[12px] bg-slate-50/80 px-4 py-2 rounded-xl border border-slate-100">
                                        <i class="far fa-envelope <%= colors.icon %> text-[13px] w-4 mt-0.5"></i>
                                        <span class="truncate font-bold tracking-tight"><%= doc.email %></span>
                                    </div>
                                    <div class="flex items-center gap-3 text-slate-500 text-[12px] bg-slate-50/80 px-4 py-2 rounded-xl border border-slate-100">
                                        <i class="fas fa-phone-alt <%= colors.icon %> text-[13px] w-4 mt-0.5"></i>
                                        <span class="font-bold tracking-tight"><%= doc.mobile %></span>
                                    </div>
                                    <div class="flex items-center gap-3 text-slate-500 text-[12px] bg-slate-50/80 px-4 py-2 rounded-xl border border-slate-100">
                                        <i class="fas fa-graduation-cap <%= colors.icon %> text-[13px] w-4 mt-0.5"></i>
                                        <span class="font-bold truncate tracking-tight"><%= doc.degree %></span>
                                    </div>
                                </div>

                                <div class="flex items-center gap-2">
                                    <button onclick="viewProfile('<%= doc.id %>')" 
                                            class="flex-1 <%= colors.btn %> hover:opacity-90 text-white font-bold py-2.5 rounded-xl shadow-lg transition-all text-[13px] uppercase tracking-wider active:scale-95">
                                        View Details
                                    </button>
                                    <button onclick="openEditModal('<%= doc.id %>')" 
                                            class="w-10 h-10 bg-slate-50 text-slate-400 hover:text-indigo-600 rounded-xl flex items-center justify-center transition-all border border-slate-100 shadow-sm hover:shadow-md">
                                        <i class="fas fa-edit text-xs"></i>
                                    </button>
                                    <button onclick="confirmDelete('<%= doc.id %>', '<%= doc.firstname %>')" 
                                            class="w-10 h-10 bg-slate-50 text-slate-400 hover:text-rose-600 rounded-xl flex items-center justify-center transition-all border border-slate-100 shadow-sm hover:shadow-md">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full py-24 text-center bg-white rounded-3xl border-4 border-dashed border-slate-50 animate-in">
                        <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                            <i class="fas fa-user-doctor text-2xl text-slate-200"></i>
                        </div>
                        <h3 class="text-lg font-bold text-slate-400">Registry is Empty</h3>
                        <p class="text-slate-500 font-medium text-xs mt-1">No specialists currently registered in PDMS.</p>
                        <button onclick="openAddModal()" class="mt-6 bg-[#0f172a] text-white font-bold px-6 py-2.5 rounded-xl shadow-lg text-xs">Register Doctor</button>
                    </div>
                <% } %>
            </div>
        </main>
        </main>
    </div>

    <!-- Registration/Edit Modal -->
    <div id="staff-modal" class="modal fixed inset-0 bg-slate-900/80 items-center justify-center z-50 p-4">
        <div class="animate-in bg-white rounded-[3rem] shadow-2xl max-w-4xl w-full max-h-[90vh] flex flex-col overflow-hidden">
            <div class="p-10 border-b border-slate-50 flex items-center justify-between">
                <div>
                    <h3 id="modal-title" class="text-3xl font-bold text-slate-900 tracking-tight">Staff Registration</h3>
                    <p class="text-slate-400 font-semibold text-sm">Update professional credentials for Pdms database</p>
                </div>
                <button onclick="closeModal('staff-modal')" class="text-slate-400 hover:text-rose-500 transition-all bg-slate-50 w-12 h-12 rounded-2xl flex items-center justify-center text-2xl font-bold shadow-inner">×</button>
            </div>
            
            <form id="staff-form" class="flex-1 overflow-y-auto p-10 grid grid-cols-1 md:grid-cols-2 gap-8 custom-scrollbar">
                <input type="hidden" name="id" id="staff-id">
                <input type="hidden" name="role_id" value="2">
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">First Name</label>
                    <input type="text" name="firstname" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Last Name</label>
                    <input type="text" name="lastname" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Professional Email</label>
                    <input type="email" name="email" id="staff-email" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="space-y-2" id="password-group">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1" id="password-label">Account Password</label>
                    <input type="password" name="password" id="staff-password" value="pdms@123" placeholder="Leave blank to keep current password" class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Mobile Number</label>
                    <input type="tel" name="mobile" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="space-y-2 relative" id="dept-dropdown-container">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Department</label>
                    <div class="relative">
                        <input type="text" id="dept-input" name="department" required autocomplete="off"
                            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold cursor-pointer" 
                            placeholder="Select Department"
                            onclick="toggleDeptDropdown()"
                            oninput="filterDeptDropdown()">
                        <i class="fas fa-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none transition-transform" id="dept-chevron"></i>
                        
                        <div id="dept-list" class="hidden absolute left-0 right-0 mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 z-[60] max-h-64 overflow-y-auto animate-in custom-scrollbar">
                            <% departments.forEach(dept => { %>
                                <div class="px-6 py-3 hover:bg-slate-50 cursor-pointer font-semibold text-slate-700 transition-colors border-b border-slate-50 last:border-0" 
                                     onclick="selectDept('<%= dept %>')">
                                    <%= dept %>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Degree</label>
                    <input type="text" name="degree" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold" placeholder="MBBS, MD">
                </div>
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Specialization</label>
                    <input type="text" name="qualification" class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Experience (Years)</label>
                    <input type="number" name="experience" class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Birth Date</label>
                    <input type="date" name="dob" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Select Gender</label>
                    <select name="gender" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold uppercase text-xs cursor-pointer">
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-slate-100 pt-8 mt-4">
                    <div class="space-y-4">
                        <h4 class="text-sm font-bold text-slate-800 uppercase tracking-wider flex items-center gap-2">
                            <i class="fas fa-sun text-amber-500"></i> Morning Shift
                        </h4>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-normal ml-1">Start Time</label>
                                <input type="time" name="morning_start" value="10:00" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                            </div>
                            <div class="space-y-2">
                                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-normal ml-1">End Time</label>
                                <input type="time" name="morning_end" value="13:00" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                            </div>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <h4 class="text-sm font-bold text-slate-800 uppercase tracking-wider flex items-center gap-2">
                            <i class="fas fa-moon text-indigo-500"></i> Evening Shift
                        </h4>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-normal ml-1">Start Time</label>
                                <input type="time" name="evening_start" value="15:00" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                            </div>
                            <div class="space-y-2">
                                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-normal ml-1">End Time</label>
                                <input type="time" name="evening_end" value="18:00" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Slot Duration (Min)</label>
                    <input type="number" name="duration" value="30" required class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
                </div>
                
                <div class="md:col-span-2 space-y-2 pt-4">
                    <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Residential Address</label>
                    <textarea name="address" rows="2" class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold resize-none"></textarea>
                </div>
                
                <div class="md:col-span-2 py-6 flex gap-6">
                    <button type="button" onclick="closeModal('staff-modal')" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold py-4 rounded-2xl transition-all uppercase tracking-wide text-[12px]">Discard</button>
                    <button type="submit" id="submit-btn" class="flex-1 bg-indigo-600 hover:bg-slate-900 text-white font-bold py-4 rounded-2xl shadow-xl shadow-indigo-100 transition-all uppercase tracking-wide text-[12px]">Save Details</button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function openModal(id) { document.getElementById(id).classList.add('active'); document.body.style.overflow = 'hidden'; }
        function closeModal(id) { document.getElementById(id).classList.remove('active'); document.body.style.overflow = 'auto'; }

        function openAddModal() {
            document.getElementById('modal-title').textContent = 'Staff Registration';
            document.getElementById('staff-id').value = '';
            document.getElementById('staff-email').disabled = false;
            document.getElementById('password-group').style.display = 'block';
            document.getElementById('staff-password').value = 'pdms@123';
            document.getElementById('password-label').textContent = 'Account Password';
            document.getElementById('staff-form').reset();
            openModal('staff-modal');
        }

        async function openEditModal(id) {
            try {
                const response = await fetch(`/admin/staff/${id}`);
                const result = await response.json();
                if (result.success) {
                    const data = result.data;
                    document.getElementById('modal-title').textContent = 'Refine Profile';
                    document.getElementById('staff-id').value = data.id;
                    document.getElementById('staff-email').disabled = true;
                    document.getElementById('password-group').style.display = 'block';
                    document.getElementById('staff-password').value = '';
                    document.getElementById('password-label').textContent = 'New Password (leave blank to keep current)';
                    const form = document.getElementById('staff-form');
                    form.firstname.value = data.firstname;
                    form.lastname.value = data.lastname;
                    form.email.value = data.email;
                    form.mobile.value = data.mobile;
                    form.department.value = data.department;
                    form.degree.value = data.degree;
                    form.qualification.value = data.qualification || '';
                    form.experience.value = data.experience || '';
                    form.gender.value = data.gender;
                    form.address.value = data.address || '';
                    if (data.dob) form.dob.value = new Date(data.dob).toISOString().split('T')[0];
                    
                    // Populate timings
                    form.morning_start.value = data.morning_start || '10:00';
                    form.morning_end.value = data.morning_end || '13:00';
                    form.evening_start.value = data.evening_start || '15:00';
                    form.evening_end.value = data.evening_end || '18:00';
                    form.duration.value = data.duration || 30;
                    
                    openModal('staff-modal');
                }
            } catch (err) { Swal.fire({ title: 'Error', text: 'Synchronization failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } }); }
        }

        document.getElementById('staff-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            const id = data.id;
            const url = id ? `/admin/update-staff/${id}` : '/admin/add-staff';
            try {
                const response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
                const result = await response.json();
                if (result.success) { 
                    Swal.fire({ 
                        title: 'Operational Success', 
                        text: result.message, 
                        icon: 'success', 
                        position: 'top', 
                        confirmButtonColor: '#6366f1',
                        customClass: { popup: 'rounded-3xl' }
                    }).then(() => window.location.reload()); 
                }
                else { Swal.fire({ title: 'Registry Error', text: result.message || 'Action failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } }); }
            } catch (err) { Swal.fire({ title: 'System Error', text: 'Protocol failure', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } }); }
        });

        async function confirmDelete(id, name) {
            const result = await Swal.fire({ 
                title: 'Confirm Excision', 
                text: `Removing Dr. ${name} will permanently purge their credentials from PDMS.`, 
                icon: 'warning', 
                showCancelButton: true, 
                confirmButtonColor: '#f43f5e', 
                confirmButtonText: 'Perform Purge',
                cancelButtonColor: '#64748b',
                position: 'top',
                customClass: { popup: 'rounded-3xl' }
            });
            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/admin/delete-staff/${id}`, { method: 'DELETE' });
                    if (response.ok) { 
                        Swal.fire({ 
                            title: 'Purged', 
                            text: 'Credentials successfully excised.', 
                            icon: 'success', 
                            position: 'top',
                            confirmButtonColor: '#10b981',
                            customClass: { popup: 'rounded-3xl' }
                        }).then(() => window.location.reload()); 
                    }
                } catch (err) { Swal.fire({ title: 'Policy Error', text: 'Excision failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } }); }
            }
        }

        function filterDoctors() {
            const nameTerm = document.getElementById('search-input').value.toLowerCase();
            const deptTerm = document.getElementById('dept-filter').value;

            document.querySelectorAll('.doctor-card').forEach(card => {
                const nameMatch = card.dataset.name.toLowerCase().includes(nameTerm);
                const deptMatch = !deptTerm || card.dataset.dept === deptTerm;

                if (nameMatch && deptMatch) {
                    card.style.display = 'block';
                    card.style.opacity = '1';
                } else {
                    card.style.display = 'none';
                    card.style.opacity = '0';
                }
            });
        }


        const DEPT_COLORS = {
            'Cardiology': { header: 'bg-rose-100', initials: 'bg-rose-600', pill: 'bg-rose-50 text-rose-600 border-rose-100', icon: 'text-rose-500', btn: 'bg-rose-600 shadow-rose-200' },
            'Neurology': { header: 'bg-indigo-100', initials: 'bg-indigo-600', pill: 'bg-indigo-50 text-indigo-600 border-indigo-100', icon: 'text-indigo-500', btn: 'bg-indigo-600 shadow-indigo-200' },
            'Orthopedics': { header: 'bg-purple-100', initials: 'bg-purple-600', pill: 'bg-purple-50 text-purple-600 border-purple-100', icon: 'text-purple-500', btn: 'bg-purple-600 shadow-purple-200' },
            'Oncology': { header: 'bg-emerald-100', initials: 'bg-emerald-600', pill: 'bg-emerald-50 text-emerald-600 border-emerald-100', icon: 'text-emerald-500', btn: 'bg-emerald-600 shadow-emerald-200' },
            'Pulmonology': { header: 'bg-sky-100', initials: 'bg-sky-600', pill: 'bg-sky-50 text-sky-600 border-sky-100', icon: 'text-sky-500', btn: 'bg-sky-600 shadow-sky-200' },
            'Rheumatology': { header: 'bg-orange-100', initials: 'bg-orange-600', pill: 'bg-orange-50 text-orange-600 border-orange-100', icon: 'text-orange-500', btn: 'bg-orange-600 shadow-orange-200' },
            'Ophthalmology': { header: 'bg-blue-100', initials: 'bg-blue-600', pill: 'bg-blue-50 text-blue-600 border-blue-100', icon: 'text-blue-500', btn: 'bg-blue-600 shadow-blue-200' },
            'Nephrology': { header: 'bg-indigo-100', initials: 'bg-indigo-800', pill: 'bg-indigo-50 text-indigo-800 border-indigo-100', icon: 'text-indigo-800', btn: 'bg-indigo-800 shadow-indigo-200' },
            'default': { header: 'bg-slate-100', initials: 'bg-slate-600', pill: 'bg-slate-50 text-slate-600 border-slate-100', icon: 'text-slate-500', btn: 'bg-[#0f172a] shadow-slate-200' }
        };

        const getColors = (dept) => DEPT_COLORS[dept] || DEPT_COLORS.default;

        async function viewProfile(id) {
            try {
                const response = await fetch(`/admin/staff/${id}`);
                const result = await response.json();
                if (result.success) {
                    const data = result.data;
                    const colors = getColors(data.department);
                    const profileHtml = `
                        <div class="text-slate-800 p-0 font-sans overflow-hidden">
                            <div class="h-32 ${colors.header} relative">
                                <div class="absolute -bottom-10 left-1/2 -translate-x-1/2">
                                    <div class="w-24 h-24 rounded-[2.2rem] ${colors.initials} flex items-center justify-center text-white text-3xl font-bold shadow-2xl border-4 border-white">
                                        ${data.firstname[0]}${data.lastname[0]}
                                    </div>
                                </div>
                            </div>
                            
                            <div class="pt-16 pb-8 px-8 text-center">
                                <h3 class="text-2xl font-black tracking-tight leading-none mb-3">Dr. ${data.firstname} ${data.lastname}</h3>
                                <div class="mb-8">
                                    <span class="font-bold text-[12px] uppercase tracking-[0.2em] px-5 py-2 ${colors.pill} rounded-xl shadow-sm border border-slate-100">${data.department || 'GENERALIST'}</span>
                                </div>
                                
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left">
                                    <div class="bg-slate-50/50 p-5 rounded-3xl border border-slate-100 hover:bg-white transition-colors">
                                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-normal mb-1">Background Details</p>
                                        <div class="flex items-center justify-between">
                                            <p class="text-slate-900 font-bold text-base">${data.degree || 'MBBS, MD'}</p>
                                            <i class="fas fa-graduation-cap ${colors.icon} text-base opacity-70"></i>
                                        </div>
                                        <p class="text-[12px] text-slate-500 font-bold mt-1">${data.experience || '0'} Years Pro Experience</p>
                                    </div>
                                    <div class="bg-slate-50/50 p-5 rounded-3xl border border-slate-100 hover:bg-white transition-colors">
                                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-normal mb-1">Contact Channels</p>
                                        <div class="flex items-center justify-between mb-1">
                                            <p class="text-slate-900 font-bold truncate text-[15px]">${data.email}</p>
                                            <i class="far fa-envelope ${colors.icon} text-base opacity-70"></i>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <p class="text-[13px] text-slate-500 font-bold tracking-tight">${data.mobile || '+91 0000 0000'}</p>
                                            <i class="fas fa-phone-alt ${colors.icon} text-[11px] opacity-70"></i>
                                        </div>
                                    </div>
                                    <div class="md:col-span-2 bg-slate-50/50 p-6 rounded-[2rem] relative overflow-hidden border border-slate-100 hover:bg-white transition-colors">
                                        <div class="absolute top-0 right-0 p-4 opacity-5"><i class="fas fa-clock text-2xl text-slate-600"></i></div>
                                        <p class="text-[11px] font-bold text-slate-400 uppercase tracking-normal mb-3">Consultation Schedule</p>
                                        <div class="grid grid-cols-2 gap-6">
                                            <div>
                                                <p class="text-[10px] font-black text-amber-500 uppercase tracking-widest mb-1">Morning Shift</p>
                                                <p class="text-slate-900 font-bold text-[14px]">${data.morning_start ? data.morning_start.substring(0,5) : '10:00'} - ${data.morning_end ? data.morning_end.substring(0,5) : '13:00'}</p>
                                            </div>
                                            <div>
                                                <p class="text-[10px] font-black text-indigo-500 uppercase tracking-widest mb-1">Evening Shift</p>
                                                <p class="text-slate-900 font-bold text-[14px]">${data.evening_start ? data.evening_start.substring(0,5) : '15:00'} - ${data.evening_end ? data.evening_end.substring(0,5) : '18:00'}</p>
                                            </div>
                                        </div>
                                        <div class="mt-3 pt-3 border-t border-slate-100/50">
                                            <p class="text-[10px] text-slate-400 font-bold">Slot Duration: <span class="text-slate-600">${data.duration || '30'} Minutes</span></p>
                                        </div>
                                    </div>
                                    <div class="md:col-span-2 bg-slate-50/50 p-6 rounded-[2rem] relative overflow-hidden border border-slate-100 hover:bg-white transition-colors">
                                        <div class="absolute top-0 right-0 p-4 opacity-5"><i class="fas fa-map-marker-alt text-2xl text-slate-600"></i></div>
                                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-normal mb-2">Authenticated Residence</p>
                                        <p class="text-slate-900 font-bold leading-relaxed text-[14px] tracking-tight">${data.address || 'The registry has not documented a verified physical residence for this specialist.'}</p>
                                    </div>
                                </div>
                            </div>
                        </div>`;
                    Swal.fire({ 
                        html: profileHtml, 
                        width: '550px', 
                        showConfirmButton: true,
                        confirmButtonText: 'CLOSE',
                        confirmButtonColor: '#0f172a',
                        backdrop: `rgba(15, 23, 42, 0.4)`,
                        customClass: { 
                            popup: 'rounded-[3rem] p-0 overflow-hidden', 
                            confirmButton: 'rounded-2xl px-14 py-4 font-bold uppercase text-[13px] tracking-widest mb-10 shadow-2xl active:scale-95 transition-all' 
                        },
                        didOpen: () => {
                            document.querySelector('.swal2-container').style.backdropFilter = 'blur(12px)';
                            document.querySelector('.swal2-container').style.webkitBackdropFilter = 'blur(12px)';
                        }
                    });
                }
            } catch (err) { Swal.fire({ title: 'Error', text: 'Registry identification failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } }); }
        }

        function logout() {
            Swal.fire({
                title: 'Logout?',
                text: "Are you sure you want to end your session?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#6366f1',
                cancelButtonColor: '#f43f5e',
                confirmButtonText: 'Yes, Logout',
                customClass: {
                    popup: 'rounded-[2rem]',
                    confirmButton: 'rounded-xl px-10 py-3 font-bold',
                    cancelButton: 'rounded-xl px-10 py-3 font-bold'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/logout';
                }
            })
        }
        window.onclick = (e) => { 
            if (e.target.classList.contains('modal')) closeModal(e.target.id); 
            // Close custom dropdown if clicking outside
            if (!e.target.closest('#dept-dropdown-container')) {
                document.getElementById('dept-list').classList.add('hidden');
                document.getElementById('dept-chevron').classList.remove('rotate-180');
            }
        }
        
        function toggleDeptDropdown() {
            const list = document.getElementById('dept-list');
            const chevron = document.getElementById('dept-chevron');
            list.classList.toggle('hidden');
            chevron.classList.toggle('rotate-180');
        }

        function selectDept(dept) {
            document.getElementById('dept-input').value = dept;
            document.getElementById('dept-list').classList.add('hidden');
            document.getElementById('dept-chevron').classList.remove('rotate-180');
        }

        function filterDeptDropdown() {
            const input = document.getElementById('dept-input');
            const filter = input.value.toLowerCase();
            const list = document.getElementById('dept-list');
            const items = list.querySelectorAll('div');
            
            list.classList.remove('hidden');
            document.getElementById('dept-chevron').classList.add('rotate-180');

            items.forEach(item => {
                const text = item.textContent || item.innerText;
                if (text.toLowerCase().includes(filter)) {
                    item.style.display = "";
                } else {
                    item.style.display = "none";
                }
            });
        }

        // Initialize dynamic animation delays
        document.querySelectorAll('.animate-in[data-delay]').forEach(el => {
            el.style.animationDelay = el.dataset.delay;
        });
    </script>
</body>

</html>
