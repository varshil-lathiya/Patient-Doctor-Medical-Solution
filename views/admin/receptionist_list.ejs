<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Receptionists - PDMS Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.4); }
    .modal { display: none; backdrop-filter: blur(8px); }
    .modal.active { display: flex; }
    .animate-in { animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }

    /* Compact Card Adjustments */
    .staff-card { width: 100%; max-width: 320px; margin: 0; }
    .avatar-container { border: 4px solid white; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); }
  </style>
</head>

<body class="bg-[#f8fafc] text-slate-800">

  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar Navigation -->
    <%- include('../components/admin-sidebar', { active: 'receptionist' }) %>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-6 md:p-10">
      <header class="mb-10 flex flex-col xl:flex-row xl:items-center justify-between gap-6 animate-in">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Front Desk Operations</h2>
          <p class="text-slate-500 text-sm mt-1">Manage hospital receptionists and administrative staff</p>
        </div>
        
        <div class="flex flex-wrap items-center gap-4">
          <button onclick="openAddModal()"
            class="bg-[#0f172a] hover:bg-slate-800 text-white font-bold px-8 py-3 rounded-xl flex items-center gap-2 shadow-lg transition-all transform active:scale-95 group">
            <i class="fas fa-plus text-xs group-hover:rotate-90 transition-transform"></i>
            <span class="text-sm font-bold">Add Receptionist</span>
          </button>
          
          <div class="flex flex-wrap gap-3">
            <div class="relative group">
              <input type="text" id="search-input" placeholder="Search by name..."
                 class="pl-12 pr-6 py-3 w-72 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-600 outline-none transition-all font-semibold text-[13px] text-slate-400"
                onkeyup="filterReceptionists()">
              <i class="fas fa-search text-slate-300 absolute left-5 top-1/2 -translate-y-1/2 text-xs"></i>
            </div>
          </div>
        </div>
      </header>

      <div id="receptionist-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
        <% if (receptionists && receptionists.length > 0) { %>
          <% receptionists.forEach((rec, index) => { %>
            <div class="staff-card bg-white rounded-3xl shadow-sm border border-slate-200/60 overflow-hidden hover:shadow-xl transition-all duration-300 group animate-in"
                 data-delay="<%=(index % 5) * 0.1%>s">
              
              <!-- Card Header -->
              <div class="h-20 bg-emerald-100 relative transition-colors duration-500">
                <div class="absolute -bottom-7 left-1/2 -translate-x-1/2">
                  <div class="w-14 h-14 rounded-[1.5rem] bg-emerald-600 flex items-center justify-center text-white text-lg font-black shadow-xl border-4 border-white transform transition-transform duration-500 group-hover:scale-110">
                    <%= rec.firstname[0] %><%= rec.lastname[0] %>
                  </div>
                </div>
              </div>

              <div class="pt-10 pb-4 px-6 text-center">
                <h3 class="text-lg font-bold text-slate-900 leading-tight mb-2 tracking-tight">
                  <%= rec.firstname %> <%= rec.lastname %>
                </h3>
                <div class="mb-4">
                  <span class="font-bold text-[11px] uppercase tracking-[0.15em] px-4 py-1.5 bg-emerald-50 text-emerald-600 rounded-xl shadow-sm border border-white/50">Front Desk Staff</span>
                </div>

                <div class="space-y-1.5 mb-5 text-center">
                  <div class="flex items-center gap-3 text-slate-500 text-[12px] bg-slate-50/80 px-4 py-2 rounded-xl border border-slate-100">
                    <i class="far fa-envelope text-emerald-500 text-[13px] w-4 mt-0.5"></i>
                    <span class="truncate font-bold tracking-tight"><%= rec.email %></span>
                  </div>
                  <div class="flex items-center gap-3 text-slate-500 text-[12px] bg-slate-50/80 px-4 py-2 rounded-xl border border-slate-100">
                    <i class="fas fa-phone-alt text-emerald-500 text-[13px] w-4 mt-0.5"></i>
                    <span class="font-bold tracking-tight"><%= rec.mobile %></span>
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <button onclick="viewProfile('<%= rec.id %>')"
                    class="flex-1 bg-emerald-600 hover:opacity-90 text-white font-bold py-2.5 rounded-xl shadow-lg transition-all text-[13px] uppercase tracking-wider active:scale-95">
                    View Details
                  </button>
                  <button onclick="openEditModal('<%= rec.id %>')"
                    class="w-10 h-10 bg-slate-50 text-slate-400 hover:text-indigo-600 rounded-xl flex items-center justify-center transition-all border border-slate-100 shadow-sm hover:shadow-md">
                    <i class="fas fa-edit text-xs"></i>
                  </button>
                  <button onclick="confirmDelete('<%= rec.id %>', '<%= rec.firstname %>')"
                    class="w-10 h-10 bg-slate-50 text-slate-400 hover:text-rose-600 rounded-xl flex items-center justify-center transition-all border border-slate-100 shadow-sm hover:shadow-md">
                    <i class="fas fa-trash-alt text-xs"></i>
                  </button>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
            <div class="w-full py-24 text-center bg-white rounded-[3rem] border-4 border-dashed border-slate-50 animate-in">
                <div class="w-24 h-24 bg-slate-50 rounded-[2.5rem] flex items-center justify-center mx-auto mb-6 shadow-inner">
                    <i class="fas fa-user-shield text-4xl text-slate-200"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-400 tracking-tight">No Front Desk Staff</h3>
                <p class="text-slate-500 font-semibold mt-1 text-base">Administration currently has no registered receptionists.</p>
                <button onclick="openAddModal()" class="mt-6 bg-indigo-600 hover:bg-slate-900 text-white font-bold px-8 py-4 rounded-3xl shadow-xl shadow-indigo-100 transition-all uppercase tracking-wide text-[12px]">Register Staff Member</button>
            </div>
        <% } %>
      </div>
    </main>
  </div>

  <!-- Registration/Edit Modal -->
  <div id="staff-modal" class="modal fixed inset-0 bg-slate-900/80 items-center justify-center z-50 p-4">
    <div class="animate-in bg-white rounded-[3rem] shadow-2xl max-w-2xl w-full max-h-[90vh] flex flex-col overflow-hidden">
      <div class="p-10 border-b border-slate-50 flex items-center justify-between">
        <div>
          <h3 id="modal-title" class="text-3xl font-bold text-slate-900 tracking-tight">Staff Account</h3>
          <p class="text-slate-400 font-semibold text-sm">Coordinate receptionist credentials and access</p>
        </div>
        <button onclick="closeModal('staff-modal')"
          class="text-slate-400 hover:text-rose-500 transition-all bg-slate-50 w-12 h-12 rounded-2xl flex items-center justify-center text-2xl font-bold shadow-inner">×</button>
      </div>
      
      <form id="staff-form" class="flex-1 overflow-y-auto p-10 grid grid-cols-1 md:grid-cols-2 gap-8 custom-scrollbar">
        <input type="hidden" name="id" id="staff-id">
        <input type="hidden" name="role_id" value="3">

        <div class="space-y-2">
          <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Legal First Name</label>
          <input type="text" name="firstname" required
            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
        </div>
        <div class="space-y-2">
          <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Legal Last Name</label>
          <input type="text" name="lastname" required
            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
        </div>
        <div class="space-y-2">
          <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Email Identification</label>
          <input type="email" name="email" id="staff-email" required
            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
        </div>
        <div class="space-y-2" id="password-group">
          <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Account Password</label>
          <input type="text" name="password" id="staff-password" value="pdms@123"
            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
        </div>
        <div class="space-y-2">
          <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Mobile Access</label>
          <input type="tel" name="mobile" required
            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold">
        </div>
        <div class="space-y-2">
          <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Gender Registry</label>
          <select name="gender" required
            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold uppercase text-xs cursor-pointer">
            <option value="Male">Male</option>
            <option value="Female">Female</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div class="space-y-2">
          <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Date of Birth</label>
          <input type="date" name="dob" required
            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-bold">
        </div>
        <div class="md:col-span-2 space-y-2">
          <label class="text-[12px] font-bold text-slate-400 uppercase tracking-normal ml-1">Residential Address</label>
          <textarea name="address" rows="2"
            class="w-full px-6 py-4 bg-slate-50 border-0 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white outline-none transition-all font-semibold resize-none"></textarea>
        </div>

        <div class="md:col-span-2 py-6 flex gap-6">
          <button type="button" onclick="closeModal('staff-modal')"
            class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold py-4 rounded-2xl transition-all uppercase tracking-wide text-[12px]">Discard</button>
          <button type="submit"
            class="flex-1 bg-indigo-600 hover:bg-slate-900 text-white font-bold py-4 rounded-2xl shadow-xl shadow-indigo-100 transition-all uppercase tracking-wide text-[12px]">Save Details</button>
        </div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    function openModal(id) { document.getElementById(id).classList.add('active'); document.body.style.overflow = 'hidden'; }
    function closeModal(id) { document.getElementById(id).classList.remove('active'); document.body.style.overflow = 'auto'; }

    function openAddModal() {
      document.getElementById('modal-title').textContent = 'Staff Account';
      document.getElementById('staff-id').value = '';
      document.getElementById('staff-email').disabled = false;
      document.getElementById('password-group').style.display = 'block';
      document.getElementById('staff-password').value = 'pdms@123';
      document.getElementById('staff-form').reset();
      openModal('staff-modal');
    }

    async function openEditModal(id) {
      try {
        const response = await fetch(`/admin/staff/${id}`);
        const result = await response.json();
        if (result.success) {
          const data = result.data;
          document.getElementById('modal-title').textContent = 'Modify Access';
          document.getElementById('staff-id').value = data.id;
          document.getElementById('staff-email').disabled = true;
          document.getElementById('password-group').style.display = 'none';

          const form = document.getElementById('staff-form');
          form.firstname.value = data.firstname;
          form.lastname.value = data.lastname;
          form.email.value = data.email;
          form.mobile.value = data.mobile;
          form.gender.value = data.gender;
          form.address.value = data.address || '';
          if (data.dob) form.dob.value = new Date(data.dob).toISOString().split('T')[0];

          openModal('staff-modal');
        }
      } catch (err) {
        Swal.fire({ title: 'Error', text: 'Synchronization failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } });
      }
    }

    document.getElementById('staff-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());
      const id = data.id;

      const url = id ? `/admin/update-staff/${id}` : '/admin/add-staff';

      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await response.json();
        if (result.success) {
          Swal.fire({ 
            title: 'Operation Success!', 
            text: result.message, 
            icon: 'success', 
            position: 'top',
            confirmButtonColor: '#6366f1',
            customClass: { popup: 'rounded-3xl' }
          }).then(() => window.location.reload());
        } else {
          Swal.fire({ title: 'Registry Error!', text: result.message || 'Action failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } });
        }
      } catch (err) {
        Swal.fire({ title: 'System Error!', text: 'Protocol failure', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } });
      }
    });

    async function confirmDelete(id, name) {
      const result = await Swal.fire({
        title: 'Revoke Clearance?',
        text: `Are you sure you want to permanently excise ${name} from the front desk registry?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f43f5e',
        confirmButtonText: 'Excise Permanently',
        cancelButtonColor: '#64748b',
        position: 'top',
        customClass: { popup: 'rounded-3xl' }
      });

      if (result.isConfirmed) {
        try {
          const response = await fetch(`/admin/delete-staff/${id}`, { method: 'DELETE' });
          if (response.ok) {
             Swal.fire({ 
                title: 'Excised!', 
                text: 'Staff clearance has been removed from PDMS.', 
                icon: 'success', 
                position: 'top',
                confirmButtonColor: '#10b981',
                customClass: { popup: 'rounded-3xl' }
            }).then(() => window.location.reload());
          }
        } catch (err) {
          Swal.fire({ title: 'Error', text: 'Excision failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } });
        }
      }
    }

    async function viewProfile(id) {
        try {
            const response = await fetch(`/admin/staff/${id}`);
            const result = await response.json();
            if (result.success) {
                const data = result.data;
                const colors = { header: 'bg-emerald-100', initials: 'bg-emerald-600', pill: 'bg-emerald-50 text-emerald-600 border-emerald-100', icon: 'text-emerald-500', btn: 'bg-emerald-600 shadow-emerald-200' };
                const profileHtml = `
                    <div class="text-slate-800 p-0 font-sans overflow-hidden text-center">
                        <div class="h-32 ${colors.header} relative">
                            <div class="absolute -bottom-10 left-1/2 -translate-x-1/2">
                                <div class="w-24 h-24 rounded-[2.2rem] ${colors.initials} flex items-center justify-center text-white text-3xl font-bold shadow-2xl border-4 border-white">
                                    ${data.firstname[0]}${data.lastname[0]}
                                </div>
                            </div>
                        </div>
                        
                        <div class="pt-16 pb-8 px-8 text-center">
                            <h3 class="text-2xl font-bold tracking-tight leading-none mb-3">${data.firstname} ${data.lastname}</h3>
                            <div class="mb-8">
                                <span class="font-bold text-[12px] uppercase tracking-[0.2em] px-5 py-2 ${colors.pill} rounded-xl shadow-sm border border-slate-100">Front Desk Staff</span>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left">
                                <div class="bg-slate-50/50 p-5 rounded-3xl border border-slate-100 hover:bg-white transition-colors">
                                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-normal mb-1">Role Specifications</p>
                                    <div class="flex items-center justify-between">
                                        <p class="text-slate-900 font-bold text-base">Administrative Operations</p>
                                        <i class="fas fa-user-shield ${colors.icon} text-base opacity-70"></i>
                                    </div>
                                    <p class="text-[12px] text-slate-500 font-bold mt-1">Hospital Management</p>
                                </div>
                                <div class="bg-slate-50/50 p-5 rounded-3xl border border-slate-100 hover:bg-white transition-colors">
                                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-normal mb-1">Contact Channels</p>
                                    <div class="flex items-center justify-between mb-1">
                                        <p class="text-slate-900 font-bold truncate text-[15px]">${data.email}</p>
                                        <i class="far fa-envelope ${colors.icon} text-base opacity-70"></i>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <p class="text-[13px] text-slate-500 font-bold tracking-tight">${data.mobile || '+91 0000 0000'}</p>
                                        <i class="fas fa-phone-alt ${colors.icon} text-[11px] opacity-70"></i>
                                    </div>
                                </div>
                                <div class="md:col-span-2 bg-slate-50/50 p-6 rounded-[2rem] relative overflow-hidden border border-slate-100 hover:bg-white transition-colors">
                                    <div class="absolute top-0 right-0 p-4 opacity-5"><i class="fas fa-map-marker-alt text-2xl text-slate-600"></i></div>
                                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-normal mb-2">Verified Residence</p>
                                    <p class="text-slate-900 font-bold leading-relaxed text-[14px] tracking-tight">${data.address || 'The registry has not documented a verified physical residence for this specialist.'}</p>
                                </div>
                            </div>
                        </div>
                    </div>`;
                Swal.fire({ 
                    html: profileHtml, 
                    width: '550px', 
                    showConfirmButton: true,
                    confirmButtonText: 'CLOSE',
                    confirmButtonColor: '#0f172a',
                    backdrop: `rgba(15, 23, 42, 0.4)`,
                    customClass: { 
                        popup: 'rounded-[3rem] p-0 overflow-hidden', 
                        confirmButton: 'rounded-2xl px-14 py-4 font-bold uppercase text-[13px] tracking-widest mb-10 shadow-2xl active:scale-95 transition-all' 
                    },
                    didOpen: () => {
                        document.querySelector('.swal2-container').style.backdropFilter = 'blur(12px)';
                        document.querySelector('.swal2-container').style.webkitBackdropFilter = 'blur(12px)';
                    }
                });
            }
        } catch (err) { Swal.fire({ title: 'Error', text: 'Registry identification failed', icon: 'error', position: 'top', customClass: { popup: 'rounded-3xl' } }); }
    }

    function filterReceptionists() {
      const term = document.getElementById('search-input').value.toLowerCase();
      document.querySelectorAll('.staff-card').forEach(card => {
        const text = card.innerText.toLowerCase();
        card.style.display = text.includes(term) ? 'block' : 'none';
      });
    }

    function logout() {
        Swal.fire({
            title: 'Logout?',
            text: "Are you sure you want to end your session?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#6366f1',
            cancelButtonColor: '#f43f5e',
            confirmButtonText: 'Yes, Logout',
            customClass: {
                popup: 'rounded-[2rem]',
                confirmButton: 'rounded-xl px-10 py-3 font-bold',
                cancelButton: 'rounded-xl px-10 py-3 font-bold'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/logout';
            }
        })
    }

    window.onclick = (e) => { if (e.target.classList.contains('modal')) closeModal(e.target.id); }

    // Initialize dynamic animation delays
    document.querySelectorAll('.animate-in[data-delay]').forEach(el => {
      el.style.animationDelay = el.dataset.delay;
    });
  </script>
</body>

</html>