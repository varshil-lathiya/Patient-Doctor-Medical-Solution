<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDMS - Doctor Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

        * {
            font-family: 'Inter', sans-serif;
        }

        .modal-backdrop {
            backdrop-filter: blur(4px);
        }

        .nav-item {
            transition: all 0.3s ease;
        }

        .nav-item:hover {
            transform: translateX(5px);
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .appointment-card {
            animation: slideIn 0.5s ease forwards;
        }

        @media (max-width: 1023px) {
            .doctor-dashboard-shell > .w-80 {
                display: none;
            }
        }
    </style>
</head>

<body class="bg-gray-50">
    <div class="doctor-dashboard-shell flex min-h-screen">
        <!-- Sidebar Navigation -->
        <%- include('../components/doctor-sidebar', { currentPage: 'dashboard' }) %>

            <!-- Main Content Area -->
            <div class="flex-1 overflow-y-auto min-w-0">
                <!-- Header -->
                <div class="bg-white shadow-sm border-b">
                    <div class="px-4 sm:px-6 lg:px-8 py-5 sm:py-6">
                        <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">Dashboard</h1>
                        <p class="text-gray-500 mt-1">Welcome back, <span id="welcome-name">Dr. <%= user.firstname %>
                                    <%= user.lastname %></span></p>
                    </div>
                </div>

                <!-- Dashboard Content -->
                <div class="p-4 sm:p-6 lg:p-8">
                    <!-- Statistics Cards -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
                        <!-- Pending Appointments Today -->
                        <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-amber-500">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Pending Today</p>
                                    <h3 class="text-3xl font-bold text-gray-800 mt-1">
                                        <%= pendingToday.length %>
                                    </h3>
                                </div>
                                <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center">
                                    <i class="fas fa-clock text-amber-600"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Upcoming Appointments Today -->
                        <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-teal-500">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Upcoming Today</p>
                                    <h3 class="text-3xl font-bold text-gray-800 mt-1">
                                        <%= upcomingToday.length %>
                                    </h3>
                                </div>
                                <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center">
                                    <i class="fas fa-calendar-check text-teal-600"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Total Slots Today Card -->
                        <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-blue-500">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Total Slots Today</p>
                                    <h3 class="text-3xl font-bold text-gray-800 mt-1">
                                        <%= pendingToday.length + upcomingToday.length %>
                                    </h3>
                                </div>
                                <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                                    <i class="fas fa-calendar-day text-blue-600"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Global Dashboard Filter -->
                    <div class="mb-8 relative max-w-md animate-slide-in">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-search text-gray-400"></i>
                        </div>
                        <input type="text" id="dashboardSearch" 
                            onkeyup="filterDashboard()"
                            placeholder="Find patient by name today..." 
                            class="w-full pl-11 pr-4 py-3 bg-white border-2 border-gray-100 rounded-2xl focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 outline-none transition-all shadow-sm font-medium"
                        >
                    </div>

                    <!-- Today's Pending Appointments Section -->
                    <div class="bg-white rounded-2xl shadow-lg p-4 sm:p-6 mb-8">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center">
                                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl sm:text-2xl font-bold text-amber-600">Pending Appointments Today</h3>
                        </div>
                        <div class="border-t-2 border-amber-600 mb-6"></div>

                        <div id="pending-appointments" class="overflow-x-auto">
                            <table class="w-full min-w-[760px]">
                                <thead>
                                    <tr class="bg-gradient-to-r from-amber-50 to-orange-50">
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-amber-700 uppercase tracking-wider rounded-tl-lg">
                                            Patient ID</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-amber-700 uppercase tracking-wider">
                                            Patient Name</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-amber-700 uppercase tracking-wider">
                                            Gender</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-amber-700 uppercase tracking-wider">
                                            Date</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-amber-700 uppercase tracking-wider">
                                            Time</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-amber-700 uppercase tracking-wider rounded-tr-lg">
                                            Action</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200">
                                    <% if (pendingToday && pendingToday.length> 0) { %>
                                        <% pendingToday.forEach((app, index)=> { %>
                                            <tr class="appointment-card hover:bg-gray-50 transition border-b border-gray-200"
                                                style="animation-delay: '<%= index * 0.1 %>s'">
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-amber-100 text-amber-700 font-semibold">
                                                        <%= app.patient_id %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <div class="flex items-center gap-3">
                                                        <div
                                                            class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-600 to-orange-600 flex items-center justify-center text-white font-semibold">
                                                            <%= app.firstname[0] %>
                                                                <%= app.lastname[0] %>
                                                        </div>
                                                        <span class="font-medium text-gray-800">
                                                            <%= app.firstname %>
                                                                <%= app.lastname %>
                                                        </span>
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= app.gender === 'Male' ? 'bg-blue-100 text-blue-700' : 'bg-pink-100 text-pink-700' %>">
                                                        <%= app.gender %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4 text-gray-700 font-medium">
                                                    <%= new Date(app.slot_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-700">
                                                        <i class="far fa-clock"></i>
                                                        <%= app.slot_start %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <button
                                                        onclick="window.location.href='/doctor/patient_history/<%= app.patient_id %>/<%= app.id %>'"
                                                        class="inline-flex items-center gap-2 px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white rounded-lg transition font-medium shadow-sm">
                                                        <i class="fas fa-notes-medical"></i>
                                                        Consult
                                                    </button>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="6"
                                                            class="px-6 py-12 text-center text-gray-500 italic">
                                                            <div class="flex flex-col items-center">
                                                                <svg class="w-16 h-16 text-gray-200 mb-4" fill="none"
                                                                    stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                        stroke-width="2"
                                                                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z">
                                                                    </path>
                                                                </svg>
                                                                <p class="text-xl font-semibold text-gray-400 text-center">No Pending Appointments Sent to You</p>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Upcoming Appointments Today Section -->
                    <div class="bg-white rounded-2xl shadow-lg p-4 sm:p-6">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-10 h-10 bg-teal-100 rounded-lg flex items-center justify-center">
                                <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                                    </path>
                                </svg>
                            </div>
                            <h3 class="text-xl sm:text-2xl font-bold text-teal-600">Upcoming Appointments Today</h3>
                        </div>
                        <div class="border-t-2 border-teal-600 mb-6"></div>

                        <div id="upcoming-appointments-today" class="overflow-x-auto">
                            <table class="w-full min-w-[700px]">
                                <thead>
                                    <tr class="bg-gradient-to-r from-teal-50 to-cyan-50">
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-teal-700 uppercase tracking-wider rounded-tl-lg">
                                            Patient ID</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-teal-700 uppercase tracking-wider">
                                            Patient Name</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-teal-700 uppercase tracking-wider">
                                            Gender</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-teal-700 uppercase tracking-wider">
                                            Date</th>
                                        <th
                                            class="px-6 py-4 text-left text-sm font-semibold text-teal-700 uppercase tracking-wider rounded-tr-lg">
                                            Time</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200">
                                    <% if (upcomingToday && upcomingToday.length> 0) { %>
                                        <% upcomingToday.forEach((app, index)=> { %>
                                            <tr class="appointment-card hover:bg-gray-50 transition"
                                                style="--delay: <%= index * 0.1 %>s; animation-delay: var(--delay);">
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-teal-100 text-teal-700 font-semibold">
                                                        <%= app.patient_id %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <div class="flex items-center gap-3">
                                                        <div
                                                            class="w-10 h-10 rounded-full bg-gradient-to-br from-teal-600 to-cyan-600 flex items-center justify-center text-white font-semibold">
                                                            <%= app.firstname[0] %>
                                                                <%= app.lastname[0] %>
                                                        </div>
                                                        <span class="font-medium text-gray-800">
                                                            <%= app.firstname %>
                                                                <%= app.lastname %>
                                                        </span>
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= app.gender === 'Male' ? 'bg-blue-100 text-blue-700' : 'bg-pink-100 text-pink-700' %>">
                                                        <%= app.gender %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4 text-gray-700 font-medium">
                                                    <%= new Date(app.slot_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-700">
                                                        <i class="far fa-clock"></i>
                                                        <%= app.slot_start %>
                                                    </span>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="5"
                                                            class="px-6 py-8 text-center text-gray-500 italic">
                                                            No other appointments for today.
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
    </div>

    <%- include('../components/doctor-modals') %>

        <!-- Hidden data container for appointments -->
        <script id="pending-appointments-data" type="application/json">
        <%- JSON.stringify(pendingToday) %>
    </script>
        <script id="upcoming-appointments-data" type="application/json">
        <%- JSON.stringify(upcomingToday) %>
    </script>

        <!-- JavaScript -->
        <script>
            // Initialized with Database Data via EJS
            const doctorInfo = {
                firstname: '<%= user.firstname %>',
                lastname: '<%= user.lastname %>',
                department: '<%= user.department %>',
                profile_pic: '<%= user.profile_pic || `https://ui-avatars.com/api/?name=${user.firstname}+${user.lastname}&size=80&background=008B8B&color=fff&bold=true` %>'
            };

            let pendingToday = [];
            let upcomingToday = [];

            try {
                const pendingData = document.getElementById('pending-appointments-data').textContent;
                const upcomingData = document.getElementById('upcoming-appointments-data').textContent;
                pendingToday = JSON.parse(pendingData);
                upcomingToday = JSON.parse(upcomingData);
            } catch (e) {
                console.error('Error parsing appointment data:', e);
            }

            // Load Doctor Information
            function loadDoctorInfo() {
                // ... Existing info loading if needed
            }

            // Initialization logic simplified for server-side rendering
            document.addEventListener('DOMContentLoaded', function () {
                // Navigation item active state is handled via partials usually
            });

            function filterDashboard() {
                const query = document.getElementById('dashboardSearch').value.toLowerCase();
                const rows = document.querySelectorAll('.appointment-card');

                rows.forEach(row => {
                    const patientName = row.innerText.toLowerCase();
                    if (patientName.includes(query)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }
        </script>
        <%- include('../components/doctor-modals') %>
</body>

</html>
