<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDMS - Add Report</title>
    <link rel="icon" href="/assets/favicon.png" type="image/x-icon">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Custom Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-blue': '#0066CC',
                        'primary-teal': '#008B8B',
                        'secondary-cyan': '#00B4D8',
                        'accent-green': '#00A86B',
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gray-50 min-h-screen">
    
    <!-- Receptionist Sidebar -->
    <%- include('../components/receptionist-sidebar') %>

    <!-- Main Content Area -->
    <main class="ml-64 min-h-screen flex items-center justify-center p-8">
        
        <!-- Add Report Card -->
        <div class="w-full max-w-2xl">
            
            <!-- Header -->
            <div class="bg-white rounded-t-2xl shadow-lg p-8 border-b-4 border-primary-teal">
                <a href="/receptionist/dashboard"
                    class="mb-4 inline-flex items-center gap-2 text-primary-teal hover:text-slate-800 font-bold transition-all group">
                    <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                    Back to Dashboard
                </a>
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <div class="w-16 h-16 bg-gradient-to-br from-primary-teal to-teal-600 rounded-xl flex items-center justify-center shadow-lg">
                            <i class="fas fa-file-medical text-3xl text-white"></i>
                        </div>
                        <div>
                            <h1 class="text-3xl font-bold text-gray-900">Add Report</h1>
                            <p class="text-gray-600">Upload medical reports for patients</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Card -->
            <div class="bg-white rounded-b-2xl shadow-lg p-8">
                
                <!-- Patient Verification Section -->
                <div class="mb-8">
                    <label for="patientEmail" class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wide">
                        <i class="fas fa-user-check mr-2 text-primary-teal"></i>
                        Patient Email ID
                    </label>
                    <form id="patient_verify_form" enctype="multipart/form-data">
                        <div class="flex gap-3">
                            <div class="flex-1 relative">
                                <input 
                                    type="email" 
                                    id="patientEmail" 
                                    name="patientEmail"
                                    placeholder="Enter patient email address"
                                    class="w-full px-4 py-4 pl-12 border-2 border-gray-300 rounded-xl focus:ring-2 focus:ring-primary-teal focus:border-transparent transition-all text-lg"
                                    required
                                />
                                <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
                            </div>
                            <button 
                                type="button"
                                id="verifyPatientBtn"
                                onclick="verifyPatient()"
                                class="bg-gradient-to-r from-primary-blue to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-bold px-8 py-4 rounded-xl transition-all shadow-md hover:shadow-xl text-lg"
                            >
                                <i class="fas fa-check-circle mr-2"></i>
                                Verify
                            </button>
                        </div>
                    </form>
                    
                    <!-- Verification Message -->
                    <div id="patientVerifyMessage" class="mt-3 text-sm font-semibold"></div>
                </div>

                <!-- File Upload Section -->
                <div class="mb-6">
                    <label class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wide">
                        <i class="fas fa-file-upload mr-2 text-primary-teal"></i>
                        Medical Report
                    </label>
                    <form id="file-upload" enctype="multipart/form-data">
                        <div class="space-y-4">
                            <!-- Custom File Input -->
                            <div class="relative">
                                <input 
                                    type="file" 
                                    id="report" 
                                    name="report"
                                    accept=".pdf,.jpg,.jpeg,.png,.doc,.docx"
                                    class="hidden"
                                    onchange="updateFileName()"
                                />
                                <label 
                                    for="report" 
                                    class="flex items-center justify-center w-full px-6 py-8 border-3 border-dashed border-gray-300 rounded-xl cursor-pointer hover:border-primary-teal hover:bg-teal-50 transition-all group"
                                >
                                    <div class="text-center">
                                        <i class="fas fa-cloud-upload-alt text-5xl text-gray-400 group-hover:text-primary-teal transition-colors mb-3"></i>
                                        <p class="text-lg font-semibold text-gray-700 group-hover:text-primary-teal transition-colors">
                                            <span id="file-label">Choose File</span>
                                        </p>
                                        <p class="text-sm text-gray-500 mt-1">PDF, JPG, PNG, DOC (Max 10MB)</p>
                                    </div>
                                </label>
                            </div>

                            <!-- Selected File Display -->
                            <div id="selected-file" class="hidden bg-teal-50 border-2 border-primary-teal rounded-xl p-4">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="w-12 h-12 bg-primary-teal rounded-lg flex items-center justify-center">
                                            <i class="fas fa-file-alt text-white text-xl"></i>
                                        </div>
                                        <div>
                                            <p id="file-name" class="font-semibold text-gray-900"></p>
                                            <p id="file-size" class="text-sm text-gray-600"></p>
                                        </div>
                                    </div>
                                    <button 
                                        type="button"
                                        onclick="clearFile()"
                                        class="text-red-500 hover:text-red-700 transition-colors"
                                    >
                                        <i class="fas fa-times-circle text-2xl"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <button 
                                type="button"
                                id="submitBtn"
                                onclick="uploadFile(event)"
                                disabled
                                class="w-full bg-gradient-to-r from-primary-teal to-teal-600 hover:from-teal-600 hover:to-teal-700 text-white font-bold px-6 py-4 rounded-xl transition-all shadow-md hover:shadow-xl text-lg disabled:bg-gray-400 disabled:cursor-not-allowed disabled:shadow-none"
                            >
                                <i class="fas fa-paper-plane mr-2"></i>
                                Submit Report
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Instructions -->
                <div class="bg-blue-50 border-l-4 border-blue-500 rounded-lg p-4">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-info-circle text-blue-500 text-xl mt-0.5"></i>
                        <div>
                            <h4 class="font-bold text-blue-900 mb-2">Instructions:</h4>
                            <ul class="text-sm text-blue-800 space-y-1">
                                <li>• First verify the patient using their email address</li>
                                <li>• Select a medical report file (PDF, JPG, PNG, or DOC)</li>
                                <li>• Maximum file size: 10MB</li>
                                <li>• Click Submit to upload the report</li>
                            </ul>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Recent Uploads (Optional) -->
            <div class="mt-6 bg-white rounded-2xl shadow-lg p-6">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                    <i class="fas fa-history text-primary-teal"></i>
                    Recent Uploads
                </h3>
                <div class="space-y-3">
                    <!-- Recent Upload Item 1 -->
                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center">
                                <i class="fas fa-file-pdf text-white"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-gray-900 text-sm">Blood_Test_Report.pdf</p>
                                <p class="text-xs text-gray-600">john@example.com • 2 hours ago</p>
                            </div>
                        </div>
                        <span class="text-xs bg-green-100 text-green-700 px-3 py-1 rounded-full font-semibold">
                            Uploaded
                        </span>
                    </div>

                    <!-- Recent Upload Item 2 -->
                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
                                <i class="fas fa-file-image text-white"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-gray-900 text-sm">X-Ray_Scan.jpg</p>
                                <p class="text-xs text-gray-600">jane@example.com • 5 hours ago</p>
                            </div>
                        </div>
                        <span class="text-xs bg-green-100 text-green-700 px-3 py-1 rounded-full font-semibold">
                            Uploaded
                        </span>
                    </div>

                    <!-- Recent Upload Item 3 -->
                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-red-500 rounded-lg flex items-center justify-center">
                                <i class="fas fa-file-pdf text-white"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-gray-900 text-sm">MRI_Report.pdf</p>
                                <p class="text-xs text-gray-600">mike@example.com • Yesterday</p>
                            </div>
                        </div>
                        <span class="text-xs bg-green-100 text-green-700 px-3 py-1 rounded-full font-semibold">
                            Uploaded
                        </span>
                    </div>
                </div>
            </div>

        </div>

    </main>

    <!-- Loading Spinner Modal -->
    <div id="spinner-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl p-10 shadow-xl">
            <div class="flex flex-col items-center">
                <img src="/assets/favicon.png" alt="Loading" class="w-16 h-16 animate-bounce mb-3" />
                <p class="text-gray-700 font-medium">Uploading report...</p>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="/js/receptionist_sidebar_navigation.js"></script>
    <script>
        let patientId = null;
        let isPatientVerified = false;

        // Verify Patient
        async function verifyPatient() {
            const email = document.getElementById('patientEmail').value;
            
            if (!email) {
                Swal.fire({
                    title: 'Error!',
                    text: 'Please enter patient email',
                    icon: 'error',
                    confirmButtonColor: '#ef4444'
                });
                return;
            }

            // Show loading
            document.getElementById('verifyPatientBtn').innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Verifying...';
            document.getElementById('verifyPatientBtn').disabled = true;

            try {
                const response = await fetch("/receptionist/verify-patient", {
                    method: "POST",
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email }),
                });

                if (response.redirected) {
                    window.location.href = response.url;
                    return;
                }

                const data = await response.json();

                if (data?.success === true) {
                    patientId = data.patient.id;
                    isPatientVerified = true;
                    
                    // Update UI
                    document.getElementById("patientVerifyMessage").innerHTML = 
                        '<div class="flex items-center gap-2 text-green-600"><i class="fas fa-check-circle"></i><span>Patient verified successfully!</span></div>';
                    
                    document.getElementById("verifyPatientBtn").innerHTML = 
                        '<i class="fas fa-check-circle mr-2"></i>Verified ✓';
                    document.getElementById("verifyPatientBtn").classList.remove('from-primary-blue', 'to-blue-600');
                    document.getElementById("verifyPatientBtn").classList.add('from-green-500', 'to-green-600');
                    document.getElementById("verifyPatientBtn").style.pointerEvents = 'none';
                    document.getElementById("verifyPatientBtn").style.cursor = 'not-allowed';
                    
                    // Enable file upload
                    document.getElementById('submitBtn').disabled = false;

                    Swal.fire({
                        title: 'Success!',
                        text: 'Patient verified successfully!',
                        icon: 'success',
                        confirmButtonColor: '#008B8B',
                        timer: 2000
                    });
                } else {
                    throw new Error(data.message || 'Verification failed');
                }
            } catch (error) {
                document.getElementById("patientVerifyMessage").innerHTML = 
                    '<div class="flex items-center gap-2 text-red-600"><i class="fas fa-times-circle"></i><span>' + (error.message || 'Patient not found. Please check the email address.') + '</span></div>';
                
                document.getElementById("verifyPatientBtn").innerHTML = '<i class="fas fa-check-circle mr-2"></i>Verify';
                document.getElementById("verifyPatientBtn").disabled = false;

                Swal.fire({
                    title: 'Error!',
                    text: error.message || 'Patient not found. Please check the email address.',
                    icon: 'error',
                    confirmButtonColor: '#ef4444'
                });
            }
        }

        // Update file name display
        function updateFileName() {
            const fileInput = document.getElementById('report');
            const file = fileInput.files[0];
            
            if (file) {
                document.getElementById('file-label').textContent = file.name;
                document.getElementById('file-name').textContent = file.name;
                document.getElementById('file-size').textContent = formatFileSize(file.size);
                document.getElementById('selected-file').classList.remove('hidden');
            }
        }

        // Clear selected file
        function clearFile() {
            document.getElementById('report').value = '';
            document.getElementById('file-label').textContent = 'Choose File';
            document.getElementById('selected-file').classList.add('hidden');
        }

        // Format file size
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }

        // Upload File
        async function uploadFile(event) {
            event.preventDefault();

            if (!isPatientVerified) {
                Swal.fire({
                    title: 'Error!',
                    text: 'Please verify patient first',
                    icon: 'error',
                    confirmButtonColor: '#ef4444'
                });
                return;
            }

            const fileInput = document.getElementById('report');
            if (!fileInput.files || !fileInput.files[0]) {
                Swal.fire({
                    title: 'Error!',
                    text: 'Please select a file',
                    icon: 'error',
                    confirmButtonColor: '#ef4444'
                });
                return;
            }

            // Show loading
            document.getElementById('spinner-modal').classList.remove('hidden');

            try {
                let formdata = new FormData(document.getElementById('file-upload'));
                formdata.append("patient_id", patientId);
                
                let file_upload_res = await fetch('/receptionist/uploadReport', {
                    method: 'post',
                    body: formdata
                });

                document.getElementById('spinner-modal').classList.add('hidden');

                if (file_upload_res.redirected) {
                    window.location.href = file_upload_res.url;
                    return;
                }

                if (file_upload_res.status === 200) {
                    await Swal.fire({
                        title: 'Success!',
                        text: 'File uploaded successfully!',
                        icon: 'success',
                        confirmButtonColor: '#008B8B'
                    });
                    
                    // Reset form
                    document.getElementById('patient_verify_form').reset();
                    document.getElementById('file-upload').reset();
                    clearFile();
                    document.getElementById('patientVerifyMessage').innerHTML = '';
                    document.getElementById('verifyPatientBtn').innerHTML = '<i class="fas fa-check-circle mr-2"></i>Verify';
                    document.getElementById('verifyPatientBtn').classList.remove('from-green-500', 'to-green-600');
                    document.getElementById('verifyPatientBtn').classList.add('from-primary-blue', 'to-blue-600');
                    document.getElementById('verifyPatientBtn').disabled = false;
                    document.getElementById('verifyPatientBtn').style.pointerEvents = 'auto';
                    document.getElementById('verifyPatientBtn').style.cursor = 'pointer';
                    document.getElementById('submitBtn').disabled = true;
                    isPatientVerified = false;
                    patientId = null;
                } else {
                    throw new Error('Upload failed');
                }
            } catch (error) {
                document.getElementById('spinner-modal').classList.add('hidden');
                
                Swal.fire({
                    title: 'Error!',
                    text: 'Something went wrong. Please try again.',
                    icon: 'error',
                    confirmButtonColor: '#ef4444'
                });
            }
        }

        // Set active nav item on load
        document.addEventListener('DOMContentLoaded', function() {
            const navItems = document.querySelectorAll('.nav-item');
            navItems.forEach(item => item.classList.remove('active'));
            document.getElementById('nav-add-report')?.classList.add('active');
        });
    </script>
    <script src="/js/receptionist/receptionist_navbar.js"></script>
</body>
</html>
