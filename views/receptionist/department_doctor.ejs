<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/assets/favicon.png" type="image/x-icon" />
    <title>
        <%= departmentName %> - PDMS
    </title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Custom Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-blue': '#0066CC',
                        'primary-teal': '#008B8B',
                        'secondary-cyan': '#00B4D8',
                        'accent-green': '#00A86B',
                    }
                }
            }
        }
    </script>
    <style>
        @media (max-width: 1023px) {
            body > aside {
                display: none !important;
            }

            #right-section {
                margin-left: 0 !important;
                padding: 1rem !important;
            }

            .department-header {
                align-items: flex-start;
            }

            .doctor-card-title,
            .department-title {
                overflow-wrap: anywhere;
            }

            #slots-container {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen">

    <!-- Sidebar Navigation -->
    <%- include('../components/receptionist-sidebar') %>

        <!-- Main Content Area -->
        <main class="ml-64 min-h-screen p-8" id="right-section">

            <!-- Breadcrumb -->
            <nav class="mb-6">
                <ol class="flex flex-wrap items-center gap-2 text-sm">
                    <li>
                        <a href="/receptionist/dashboard"
                            class="text-primary-blue hover:text-primary-teal transition-colors flex items-center gap-1">
                            <i class="fas fa-home"></i>
                            Dashboard
                        </a>
                    </li>
                    <li class="text-gray-400">/</li>
                    <li>
                        <a href="/receptionist/appointments"
                            class="text-primary-blue hover:text-primary-teal transition-colors">Specialties</a>
                    </li>
                    <li class="text-gray-400">/</li>
                    <li class="text-gray-600 font-medium">
                        <%= departmentName %>
                    </li>
                </ol>
            </nav>

            <!-- Department Header -->
            <div class="mb-8">
                <a href="/receptionist/appointments"
                    class="mb-4 inline-flex items-center gap-2 text-primary-teal hover:text-slate-800 font-bold transition-all group">
                    <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                    Back to Specialties
                </a>
                <div class="department-header flex items-center gap-4 mb-3">
                    <div
                        class="w-16 h-16 bg-gradient-to-br from-primary-blue to-primary-teal rounded-xl flex items-center justify-center shadow-lg">
                        <i class="fas fa-hospital text-3xl text-white"></i>
                    </div>
                    <div>
                        <h1 class="department-title text-2xl sm:text-3xl font-bold text-gray-900">
                            <%= departmentName %>
                        </h1>
                        <p class="text-gray-600">Select a doctor to book an appointment</p>
                    </div>
                </div>
            </div>

            <!-- Doctors Section -->
            <section>
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-xl font-semibold text-gray-800 flex items-center gap-2">
                        <i class="fas fa-user-doctor text-primary-teal"></i>
                        Available Doctors
                    </h2>
                </div>

                <!-- Doctors Grid -->
                <div id="doctors-list" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <% if (doctors && doctors.length> 0) { %>
                        <% doctors.forEach(doc=> { %>
                            <div
                                class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden border border-gray-200">
                                <div class="p-6">
                                    <div class="flex items-start gap-4 mb-4">
                                        <div class="flex-shrink-0">
                                            <div
                                                class="w-20 h-20 rounded-full bg-gradient-to-br from-primary-blue to-primary-teal flex items-center justify-center shadow-lg overflow-hidden">
                                                <img src="<%= doc.profile_pic || `https://ui-avatars.com/api/?name=Dr+${doc.firstname}+${doc.lastname}&size=80&background=0066CC&color=fff&bold=true` %>"
                                                    alt="Doctor" class="w-full h-full object-cover" />
                                            </div>
                                        </div>
                                        <div class="flex-1">
                                            <h3 class="doctor-card-title text-xl font-bold text-gray-900 mb-1">Dr. <%= doc.firstname %>
                                                    <%= doc.lastname %>
                                            </h3>
                                            <div
                                                class="inline-flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1 rounded-full text-sm font-medium">
                                                <i class="fas fa-calendar-check"></i>
                                                <span>Active Today</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="space-y-3 mb-4">
                                        <div class="flex items-center gap-2 text-sm text-gray-600">
                                            <i class="fas fa-hospital-alt text-primary-blue w-5"></i>
                                            <span><strong>Department:</strong>
                                                <%= doc.department %>
                                            </span>
                                        </div>
                                        <div class="flex items-center gap-2 text-sm text-gray-600">
                                            <i class="fas fa-graduation-cap text-primary-blue w-5"></i>
                                            <span><strong>Qualification:</strong>
                                                <%= doc.qualification || 'MBBS, MD' %>
                                            </span>
                                        </div>
                                        <div class="flex items-center gap-2 text-sm text-gray-600">
                                            <i class="fas fa-briefcase text-primary-blue w-5"></i>
                                            <span><strong>Experience:</strong>
                                                <%= doc.experience || '3' %> Years
                                            </span>
                                        </div>
                                    </div>
                                    <button
                                        onclick="openSlotModal('<%= doc.id %>', '<%= doc.firstname %> <%= doc.lastname %>', '<%= doc.department %>', '<%= doc.profile_pic || `https://ui-avatars.com/api/?name=Dr+${doc.firstname}+${doc.lastname}&size=80&background=0066CC&color=fff&bold=true` %>')"
                                        class="w-full bg-primary-blue hover:bg-primary-teal text-white font-semibold py-3 rounded-lg transition-all duration-200 flex items-center justify-center gap-2">
                                        <i class="fas fa-calendar-plus"></i>
                                        <span>Schedule Appointment</span>
                                    </button>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div
                                        class="col-span-full text-center py-20 bg-white rounded-xl border-2 border-dashed border-gray-200">
                                        <i class="fas fa-user-doctor text-5xl text-gray-300 mb-4"></i>
                                        <p class="text-xl text-gray-500">No doctors available in this department</p>
                                    </div>
                                    <% } %>
                </div>
            </section>
        </main>

        <!-- Slot Selection Modal -->
        <div id="slot-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
            <div class="bg-white rounded-2xl shadow-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto">
                <div
                    class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between rounded-t-2xl">
                    <h3 class="text-2xl font-bold text-gray-900">Select Slot</h3>
                    <button onclick="closeSlotModal()"
                        class="text-red-500 hover:text-red-700 transition-colors text-2xl font-bold w-8 h-8 flex items-center justify-center">×</button>
                </div>

                <div class="p-6">
                    <!-- Doctor Info Card -->
                    <div class="flex items-center gap-4 mb-6 p-4 bg-gray-50 rounded-xl">
                        <div
                            class="w-16 h-16 rounded-full bg-gradient-to-br from-primary-blue to-primary-teal flex items-center justify-center shadow-lg overflow-hidden">
                            <img id="modal-doctor-image" src="" alt="Doctor" class="w-full h-full object-cover" />
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-gray-900" id="modal-doctor-name"></h4>
                            <p class="text-sm text-primary-teal font-medium" id="modal-doctor-dept"></p>
                        </div>
                    </div>

                    <!-- Patient Verification -->
                    <div class="mb-6 p-4 bg-gray-50 rounded-xl border border-gray-200">
                        <h5 class="text-sm font-bold text-gray-700 mb-3 uppercase tracking-wide">Patient Verification
                        </h5>
                        <div class="flex flex-col sm:flex-row gap-2">
                            <input type="text" id="patientEmail" placeholder="Patient Email ID"
                                class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                            <button type="button" onclick="verifyPatient()"
                                class="bg-primary-teal hover:bg-teal-700 text-white font-bold px-6 py-3 rounded-lg transition-all">Verify</button>
                        </div>
                        <p id="patientVerifyMessage" class="text-sm mt-2 font-bold"></p>
                    </div>

                    <!-- Date Selection -->
                    <div class="mb-6">
                        <h5 class="text-sm font-semibold text-gray-700 mb-3 uppercase tracking-wide">Select Date</h5>
                        <div class="flex gap-2">
                            <button type="button"
                                class="date-btn bg-primary-teal text-white px-6 py-3 rounded-lg font-semibold text-sm transition-all">Today</button>
                        </div>
                    </div>

                    <!-- Time Slots -->
                    <div class="mb-6">
                        <h5 class="text-sm font-semibold text-gray-700 mb-3 uppercase tracking-wide">Available Slots
                        </h5>
                        <div id="slots-container" class="grid grid-cols-4 gap-3">
                            <p class="col-span-full text-center text-gray-500 text-sm italic">Select a date to see slots
                            </p>
                        </div>
                    </div>
                </div>

                <div class="sticky bottom-0 bg-white border-t border-gray-200 px-6 py-4 rounded-b-2xl">
                    <button onclick="bookAppointment()"
                        class="w-full bg-primary-teal hover:bg-slate-800 text-white font-bold py-3 rounded-lg transition-all text-lg shadow-lg">Book
                        Appointment</button>
                </div>
            </div>
        </div>

        <!-- Scripts -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            let currentDoctorId = null;
            let currentPatientId = null;
            let selectedSlotId = null;

            function openSlotModal(doctorId, doctorName, department, doctorImg) {
                currentDoctorId = doctorId;
                document.getElementById('modal-doctor-name').textContent = 'Dr. ' + doctorName;
                document.getElementById('modal-doctor-dept').textContent = department;
                document.getElementById('modal-doctor-image').src = doctorImg;

                document.getElementById('slot-modal').classList.remove('hidden');
                document.body.style.overflow = 'hidden';

                const today = new Date().toISOString().split('T')[0];
                fetchSlots(today);
            }

            function closeSlotModal() {
                document.getElementById('slot-modal').classList.add('hidden');
                document.body.style.overflow = 'auto';
                document.getElementById('patientVerifyMessage').textContent = '';
                currentPatientId = null;
                selectedSlotId = null;
            }

            async function fetchSlots(date) {
                const container = document.getElementById('slots-container');
                container.innerHTML = '<p class="col-span-full text-center text-gray-500 text-sm">Loading slots...</p>';

                try {
                    const response = await fetch(`/receptionist/get-slots?doctor_id=${currentDoctorId}&date=${date}`);
                    const data = await response.json();

                    if (data.slots && data.slots.length > 0) {
                        container.innerHTML = data.slots.map(slot => `
                        <button onclick="selectSlot('${slot.id}', this)" class="slot-btn border-2 border-primary-teal text-primary-teal font-bold py-2 rounded-lg hover:bg-primary-teal hover:text-white transition-all text-sm">
                            ${slot.slot_start}
                        </button>
                    `).join('');
                    } else {
                        container.innerHTML = '<p class="col-span-full text-center text-red-500 text-sm">No slots available</p>';
                    }
                } catch (err) {
                    container.innerHTML = '<p class="col-span-full text-center text-red-500 text-sm">Error loading slots</p>';
                }
            }

            function selectSlot(id, btn) {
                selectedSlotId = id;
                document.querySelectorAll('.slot-btn').forEach(b => {
                    b.classList.remove('bg-primary-teal', 'text-white');
                    b.classList.add('text-primary-teal');
                });
                btn.classList.add('bg-primary-teal', 'text-white');
                btn.classList.remove('text-primary-teal');
            }

            async function verifyPatient() {
                const email = document.getElementById('patientEmail').value;
                if (!email) return Swal.fire('Error', 'Please enter email', 'error');

                try {
                    const response = await fetch('/receptionist/verify-patient', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email })
                    });
                    const data = await response.json();

                    if (data.success) {
                        document.getElementById('patientVerifyMessage').textContent = `✓ Verified: ${data.patient.firstname} ${data.patient.lastname}`;
                        document.getElementById('patientVerifyMessage').className = 'text-sm mt-2 text-green-600 font-bold';
                        currentPatientId = data.patient.id;
                    } else {
                        document.getElementById('patientVerifyMessage').textContent = '✗ ' + data.message;
                        document.getElementById('patientVerifyMessage').className = 'text-sm mt-2 text-red-600 font-bold';
                        currentPatientId = null;
                    }
                } catch (err) {
                    Swal.fire('Error', 'Verification failed', 'error');
                }
            }

            async function bookAppointment() {
                if (!currentPatientId) return Swal.fire('Error', 'Please verify patient', 'error');
                if (!selectedSlotId) return Swal.fire('Error', 'Please select a slot', 'error');

                try {
                    const response = await fetch('/receptionist/book-appointment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ slot_id: selectedSlotId, patient_id: currentPatientId })
                    });
                    const data = await response.json();
                    if (response.ok) {
                        Swal.fire('Success!', data.message, 'success').then(() => window.location.reload());
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (err) {
                    Swal.fire('Error', 'Booking failed', 'error');
                }
            }

            document.getElementById('slot-modal').addEventListener('click', function (e) {
                if (e.target === this) closeSlotModal();
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeSlotModal();
            });
        </script>
        <script src="/js/receptionist/receptionist_navbar.js"></script>
</body>

</html>
