<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PDMS - Add Appointments</title>
    <link rel="icon" href="/assets/favicon.png" type="image/x-icon">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Custom Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-blue': '#0066CC',
                        'primary-teal': '#008B8B',
                        'secondary-cyan': '#00B4D8',
                        'accent-green': '#00A86B',
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gray-50 min-h-screen overflow-x-hidden">

    <!-- Receptionist Sidebar -->
    <%- include('../components/receptionist-sidebar') %>

        <!-- Main Content Area -->
        <main class="ml-64 min-h-screen p-8" id="right-section">

            <!-- Page Header -->
            <div class="mb-8">
                <a href="/receptionist/dashboard"
                    class="mb-4 inline-flex items-center gap-2 text-teal-600 hover:text-slate-800 font-bold transition-all group">
                    <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                    Back to Dashboard
                </a>
                <h1 class="text-3xl font-bold text-primary-teal mb-1">All Departments</h1>
                <p class="text-gray-600">Select a department to view available doctors and book appointments</p>
            </div>

            <!-- Departments Grid -->
            <section id="departments" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <% const deptConfig={ 'Cardiology' : { icon: 'fa-heart-pulse' , color: 'from-red-400 to-red-600' ,
                    hover: 'group-hover:text-red-600' , btn: 'from-red-500 to-red-600' ,
                    description: 'Diagnosis and treatment of heart and vascular conditions.' }, 'Neurology' : {
                    icon: 'fa-brain' , color: 'from-purple-400 to-purple-600' , hover: 'group-hover:text-purple-600' ,
                    btn: 'from-purple-500 to-purple-600' ,
                    description: 'Care for brain, spinal cord, and nervous system disorders.' }, 'Orthopedics' : {
                    icon: 'fa-bone' , color: 'from-blue-400 to-blue-600' , hover: 'group-hover:text-blue-600' ,
                    btn: 'from-blue-500 to-blue-600' , description: 'Treatment of musculoskeletal system issues.'
                    }, 'Oncology' : { icon: 'fa-ribbon' , color: 'from-pink-400 to-pink-600' ,
                    hover: 'group-hover:text-pink-600' , btn: 'from-pink-500 to-pink-600' ,
                    description: 'Diagnosis and treatment related to cancer.' }, 'Pediatrics' : { icon: 'fa-child' ,
                    color: 'from-green-400 to-green-600' , hover: 'group-hover:text-green-600' ,
                    btn: 'from-green-500 to-green-600' ,
                    description: 'Medical care for infants, children, and adolescents.' }, 'Pulmonology' : {
                    icon: 'fa-lungs' , color: 'from-amber-400 to-amber-600' , hover: 'group-hover:text-amber-600' ,
                    btn: 'from-amber-500 to-amber-600' ,
                    description: 'Treatment of lung and respiratory tract disorders.' }, 'Rheumatology' : {
                    icon: 'fa-hands' , color: 'from-lime-400 to-lime-600' , hover: 'group-hover:text-lime-600' ,
                    btn: 'from-lime-500 to-lime-600' , description: 'Care for autoimmune and inflammatory diseases.'
                    }, 'Gastroenterology' : { logo: 'https://img.icons8.com/?size=100&id=9498&format=png&color=ffffff' , color: 'from-emerald-400 to-emerald-600' ,
                    hover: 'group-hover:text-emerald-600' , btn: 'from-emerald-500 to-emerald-600' ,
                    description: 'Treatment related to digestive system disorders.' }, 'Ophthalmology' : {
                    icon: 'fa-eye' , color: 'from-sky-400 to-sky-600' , hover: 'group-hover:text-sky-600' ,
                    btn: 'from-sky-500 to-sky-600' , description: 'Treatment related to eye care and vision services.'
                    }, 'Nephrology' : { icon: 'fa-vials' , color: 'from-cyan-400 to-cyan-600' ,
                    hover: 'group-hover:text-cyan-600' , btn: 'from-cyan-500 to-cyan-600' ,
                    description: 'Treatment for kidney-related conditions.' }, 'Otorhinolaryngology (ENT)' : {
                    logo: 'https://img.icons8.com/?size=100&id=BOELoM6usUUR&format=png&color=ffffff' , color: 'from-violet-400 to-violet-600' ,
                    hover: 'group-hover:text-violet-600' , btn: 'from-violet-500 to-violet-600' ,
                    description: 'Care for ear, nose, and throat conditions.' }, 'Emergency' : { icon: 'fa-truck-medical' ,
                    color: 'from-red-600 to-red-800' , hover: 'group-hover:text-red-800' ,
                    btn: 'from-red-600 to-red-700' ,
                    description: 'Immediate medical care for acute illnesses and injuries.' } }; if (specialties &&
                    specialties.length> 0) {
                    specialties.forEach(spec => {
                    const config = deptConfig[spec.department] || {
                    icon: 'fa-user-doctor',
                    color: 'from-gray-400 to-gray-600',
                    hover: 'group-hover:text-gray-600',
                    btn: 'from-gray-500 to-gray-600',
                    description: `Specialized medical care in the ${spec.department} department.`
                    };
                    %>
                    <div
                        class="bg-white rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 group">
                        <div class="p-6">
                            <div class="flex items-center gap-4 mb-4">
                                <div
                                    class="w-16 h-16 bg-gradient-to-br <%= config.color %> rounded-xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                                    <% if (config.logo) { %>
                                        <img src="<%= config.logo %>" alt="<%= spec.department %>" class="w-8 h-8 object-contain" />
                                    <% } else { %>
                                        <i class="fa-solid <%= config.icon %> fa-fw text-3xl text-white"></i>
                                    <% } %>
                                </div>
                                <h3 class="text-xl font-bold text-gray-900 <%= config.hover %> transition-colors">
                                    <%= spec.department %>
                                </h3>
                            </div>
                            <p class="text-gray-600 text-sm mb-6 min-h-[48px]">
                                <%= config.description %>
                            </p>
                            <button onclick="select_department('<%= spec.department %>')"
                                class="w-full bg-gradient-to-r <%= config.btn %> hover:opacity-90 text-white font-bold py-3 rounded-lg transition-all shadow-md hover:shadow-xl">
                                Select
                            </button>
                        </div>
                    </div>
                    <% }); } else { %>
                        <div
                            class="col-span-full py-20 text-center bg-white rounded-2xl border-2 border-dashed border-gray-200">
                            <i class="fas fa-search text-5xl text-gray-300 mb-4"></i>
                            <p class="text-xl text-gray-500">No specialties available at the moment</p>
                        </div>
                        <% } %>
            </section>
        </main>

        <!-- Add Report Modal -->
        <div id="add-report-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
            <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full">
                <div
                    class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between rounded-t-2xl">
                    <h3 class="text-2xl font-bold text-slate-700">Add Report</h3>
                    <button onclick="closeModal('add-report-modal')"
                        class="text-red-500 hover:text-red-700 transition-colors text-3xl font-bold w-8 h-8 flex items-center justify-center">
                        ×
                    </button>
                </div>
                <div class="p-6">
                    <form id="patient-verify-form" class="mb-4">
                        <div class="flex gap-2">
                            <input type="text" id="patientEmail" placeholder="Patient Email Id"
                                class="flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                            <button type="button" onclick="verifyPatient()"
                                class="bg-primary-teal hover:bg-teal-700 text-white font-bold px-6 py-3 rounded-lg transition-all">
                                Verify
                            </button>
                        </div>
                    </form>
                    <p id="patientVerifyMessage" class="text-sm mb-4"></p>
                    <form id="file-upload">
                        <div class="space-y-4">
                            <input type="file" id="report"
                                class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg" />
                            <button type="button" id="submit-report" disabled onclick="uploadFile()"
                                class="w-full bg-primary-teal hover:bg-teal-700 text-white font-bold py-3 rounded-lg transition-all disabled:bg-gray-400 disabled:cursor-not-allowed">
                                Submit
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Loading Spinner Modal -->
        <div id="spinner-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center">
            <div class="bg-white rounded-xl p-10 shadow-xl">
                <div class="flex flex-col items-center">
                    <img src="/assets/favicon.png" alt="Loading" class="w-16 h-16 animate-bounce mb-3" />
                    <p class="text-gray-700 font-medium">Loading...</p>
                </div>
            </div>
        </div>

        <!-- Scripts -->
        <script>
            // Select Department
            function select_department(department) {
                console.log('Selected department:', department);
                // Navigate to doctors list for this department
                window.location.href = `/receptionist/department/${department}`;
            }

            // Modal Functions
            function closeModal(modalId) {
                document.getElementById(modalId).classList.add('hidden');
                document.body.style.overflow = 'auto';
            }

            function showModal(modalId) {
                document.getElementById(modalId).classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            // Verify Patient
            function verifyPatient() {
                const email = document.getElementById('patientEmail').value;
                if (!email) {
                    Swal.fire({
                        title: 'Email Required',
                        text: 'Please enter patient email to verify.',
                        icon: 'warning',
                        position: 'top',
                        confirmButtonColor: '#008B8B'
                    });
                    return;
                }
                document.getElementById('patientVerifyMessage').textContent = 'Patient verified!';
                document.getElementById('patientVerifyMessage').classList.add('text-green-600');
                document.getElementById('submit-report').disabled = false;
            }

            // Upload File
            function uploadFile() {
                const file = document.getElementById('report').files[0];
                if (!file) {
                    Swal.fire({
                        title: 'Selection Required',
                        text: 'Please select a file to upload.',
                        icon: 'warning',
                        position: 'top',
                        confirmButtonColor: '#008B8B'
                    });
                    return;
                }
                Swal.fire({
                    title: 'Success!',
                    text: 'Report uploaded successfully!',
                    icon: 'success',
                    position: 'top',
                    confirmButtonColor: '#008B8B'
                });
                closeModal('add-report-modal');
            }

            // Logout
            function logout() {
                Swal.fire({
                    title: 'Logout?',
                    text: "Are you sure you want to end your session?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, Logout',
                    position: 'top'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '/logout';
                    }
                })
            }

            // Redirect functions (placeholders)

            // Close modals when clicking outside
            document.querySelectorAll('[id$="-modal"]').forEach(modal => {
                modal.addEventListener('click', function (e) {
                    if (e.target === this) {
                        closeModal(this.id);
                    }
                });
            });

            // Close modals on ESC key
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    document.querySelectorAll('[id$="-modal"]:not(.hidden)').forEach(modal => {
                        if (modal.id !== 'spinner-modal') {
                            closeModal(modal.id);
                        }
                    });
                }
            });

            // Set appointments nav as active on load
            document.addEventListener('DOMContentLoaded', function () {
                const navBtn = document.getElementById('nav-appointments');
                if (navBtn) navBtn.classList.add('active');
            });
        </script>
        <script src="/js/receptionist/receptionist_navbar.js"></script>
        <!-- <script src="/js/receptionist/receptionist_department"></script> -->
</body>

</html>