<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PDMS - Doctor List</title>
    <link rel="icon" href="/assets/favicon.png" type="image/x-icon">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Custom Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-blue': '#0066CC',
                        'primary-teal': '#008B8B',
                        'secondary-cyan': '#00B4D8',
                        'accent-green': '#00A86B',
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gray-50 min-h-screen">

    <!-- Receptionist Sidebar -->
    <%- include('../components/receptionist-sidebar') %>

        <!-- Main Content Area -->
        <main class="ml-64 min-h-screen p-8" id="right-section">

            <!-- Page Header -->
            <div class="mb-8">
                <a href="/receptionist/dashboard"
                    class="mb-4 inline-flex items-center gap-2 text-primary-teal hover:text-slate-800 font-bold transition-all group">
                    <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                    Back to Dashboard
                </a>
                <h1 class="text-3xl font-bold text-primary-teal mb-1">Doctor Directory</h1>
                <p class="text-gray-600">Search and filter hospital doctors by name, department, or education.</p>
            </div>

            <!-- Search and Filter Bar -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 mb-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Search by Name -->
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-gray-700 uppercase tracking-wide">Search Name</label>
                        <div class="relative">
                            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                            <input type="text" id="search-name" onkeyup="filterDoctors()" placeholder="Doctor name..."
                                class="w-full pl-11 pr-4 py-3 bg-gray-50 border-2 border-gray-100 rounded-xl focus:ring-2 focus:ring-primary-teal focus:border-transparent transition-all" />
                        </div>
                    </div>

                    <!-- Filter by Department -->
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-gray-700 uppercase tracking-wide">Department</label>
                        <div class="relative">
                            <i class="fas fa-hospital absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                            <select id="filter-dept" onchange="filterDoctors()"
                                class="w-full pl-11 pr-4 py-3 bg-gray-50 border-2 border-gray-100 rounded-xl focus:ring-2 focus:ring-primary-teal focus:border-transparent transition-all appearance-none cursor-pointer">
                                <option value="">All Departments</option>
                                <% departments.forEach(dept => { %>
                                    <option value="<%= dept.department %>"><%= dept.department %></option>
                                <% }) %>
                            </select>
                            <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-xs"></i>
                        </div>
                    </div>

                    <!-- Filter by Education -->
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-gray-700 uppercase tracking-wide">Education / Qualification</label>
                        <div class="relative">
                            <i class="fas fa-graduation-cap absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                            <input type="text" id="filter-edu" onkeyup="filterDoctors()" placeholder="Degree (MBBS, MD...)"
                                class="w-full pl-11 pr-4 py-3 bg-gray-50 border-2 border-gray-100 rounded-xl focus:ring-2 focus:ring-primary-teal focus:border-transparent transition-all" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Buttons -->
            <div class="mb-6">
                <div class="flex gap-3">
                    <button id="available-btn" onclick="showAvailable()"
                        class="px-8 py-3 bg-primary-teal text-white font-semibold rounded-lg transition-all hover:bg-teal-700">
                        Available
                    </button>
                    <button id="onleave-btn" onclick="showOnLeave()"
                        class="px-8 py-3 bg-slate-600 text-white font-semibold rounded-lg transition-all hover:bg-slate-700">
                        On Leave
                    </button>
                </div>
            </div>
            <div id="add-report-modal"
                class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
                <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full">
                    <div
                        class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between rounded-t-2xl">
                        <h3 class="text-2xl font-bold text-slate-700">Add Report</h3>
                        <button onclick="closeModal('add-report-modal')"
                            class="text-red-500 hover:text-red-700 transition-colors text-3xl font-bold w-8 h-8 flex items-center justify-center">
                            ×
                        </button>
                    </div>
                    <div class="p-6">
                        <form id="patient-verify-form" class="mb-4">
                            <div class="flex gap-2">
                                <input type="text" id="patientEmailReport" placeholder="Patient Email Id"
                                    class="flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                                <button type="button" onclick="verifyPatientReport()"
                                    class="bg-primary-teal hover:bg-teal-700 text-white font-bold px-6 py-3 rounded-lg transition-all">
                                    Verify
                                </button>
                            </div>
                        </form>
                        <p id="patientVerifyMessage" class="text-sm mb-4"></p>
                        <form id="file-upload">
                            <div class="space-y-4">
                                <input type="file" id="report"
                                    class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg" />
                                <button type="button" id="submit-report" disabled onclick="uploadFile()"
                                    class="w-full bg-primary-teal hover:bg-teal-700 text-white font-bold py-3 rounded-lg transition-all disabled:bg-gray-400 disabled:cursor-not-allowed">
                                    Submit
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>


            <!-- Available Doctors Section -->
            <div id="available-section">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                    <% const activeDoctors=doctors.filter(d=> d.on_leave === 0);
                        const leaveDoctors = doctors.filter(d => d.on_leave > 0);
                        %>

                        <% if (activeDoctors.length> 0) { %>
                            <% activeDoctors.forEach(doc=> { %>
                                <div
                                    class="bg-white rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 group doctor-card">
                                    <div class="p-6">
                                        <div class="flex justify-center mb-4">
                                            <div
                                                class="w-32 h-32 rounded-full overflow-hidden border-4 border-primary-teal shadow-lg group-hover:scale-105 transition-transform">
                                                <img src="<%= doc.profile_pic || `https://ui-avatars.com/api/?name=Dr+${doc.firstname}+${doc.lastname}&size=128&background=008B8B&color=fff&bold=true` %>"
                                                    alt="Doctor" class="w-full h-full object-cover" />
                                            </div>
                                        </div>
                                        <h3 class="text-xl font-bold text-gray-900 text-center mb-4">Dr. <%=
                                                doc.firstname %>
                                                <%= doc.lastname %>
                                        </h3>
                                        <div class="space-y-3 mb-6">
                                            <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50 text-sm">
                                                <i class="fas fa-user text-primary-teal w-5"></i>
                                                <span class="text-gray-500 font-medium min-w-[80px]">Gender:</span>
                                                <span class="text-gray-900 font-bold"><%= doc.gender %></span>
                                            </div>
                                            <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50 text-sm">
                                                <i class="fas fa-graduation-cap text-primary-teal w-5"></i>
                                                <span class="text-gray-500 font-medium min-w-[80px]">Education:</span>
                                                <span class="text-gray-900 font-bold doctor-edu"><%= doc.qualification || 'MBBS' %></span>
                                            </div>
                                            <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50 text-sm">
                                                <i class="fas fa-building text-primary-teal w-5"></i>
                                                <span class="text-gray-500 font-medium min-w-[80px]">Dept:</span>
                                                <span class="text-gray-900 font-bold doctor-dept"><%= doc.department %></span>
                                            </div>
                                            <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50 text-sm">
                                                <i class="fas fa-phone-alt text-primary-teal w-5"></i>
                                                <span class="text-gray-500 font-medium min-w-[80px]">Contact:</span>
                                                <span class="text-gray-900 font-bold"><%= doc.mobile %></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div
                                            class="col-span-full text-center py-20 bg-white rounded-xl border-2 border-dashed border-gray-200">
                                            <i class="fas fa-user-doctor text-5xl text-gray-300 mb-4"></i>
                                            <p class="text-xl text-gray-500">No active doctors available</p>
                                        </div>
                                        <% } %>

                </div>
            </div>

            <!-- On Leave Doctors Section (Hidden by default) -->
            <div id="onleave-section" class="hidden">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                    <% if (leaveDoctors.length> 0) { %>
                        <% leaveDoctors.forEach(doc=> { %>
                            <div
                                class="bg-white rounded-xl shadow-sm transition-all duration-300 overflow-hidden border border-gray-200 opacity-75 doctor-card">
                                <div class="p-6">
                                    <div class="flex justify-center mb-4">
                                        <div
                                            class="w-32 h-32 rounded-full overflow-hidden border-4 border-gray-400 shadow-lg">
                                            <img src="<%= doc.profile_pic || `https://ui-avatars.com/api/?name=Dr+${doc.firstname}+${doc.lastname}&size=128&background=008B8B&color=fff&bold=true` %>"
                                                alt="Doctor" class="w-full h-full object-cover grayscale" />
                                        </div>
                                    </div>
                                    <h3 class="text-xl font-bold text-gray-600 text-center mb-4">Dr. <%= doc.firstname
                                            %>
                                            <%= doc.lastname %>
                                    </h3>
                                    <div class="space-y-3 mb-6">
                                        <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50 text-sm">
                                            <i class="fas fa-graduation-cap text-gray-500 w-5"></i>
                                            <span class="text-gray-500 font-medium min-w-[80px]">Education:</span>
                                            <span class="text-gray-600 font-bold doctor-edu"><%= doc.qualification || 'MBBS, MD' %></span>
                                        </div>
                                        <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50 text-sm">
                                            <i class="fas fa-building text-gray-500 w-5"></i>
                                            <span class="text-gray-500 font-medium min-w-[80px]">Dept:</span>
                                            <span class="text-gray-600 font-bold doctor-dept"><%= doc.department %></span>
                                        </div>
                                    </div>
                                    <div class="absolute top-4 right-4">
                                        <span class="bg-gray-200 text-gray-600 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">
                                            Away
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div
                                        class="col-span-full text-center py-20 bg-white rounded-xl border-2 border-dashed border-gray-200">
                                        <i class="fas fa-calendar-times text-5xl text-gray-300 mb-4"></i>
                                        <p class="text-xl text-gray-500">No doctors on leave today</p>
                                    </div>
                                    <% } %>

                </div>
            </div>
        </main>

        <!-- Book Appointment Modal -->
        <div id="booking-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
            <div class="bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">

                <!-- Modal Header -->
                <div
                    class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between rounded-t-2xl z-10">
                    <h3 class="text-2xl font-bold text-slate-700">Select Slot</h3>
                    <button onclick="closeModal('booking-modal')"
                        class="text-red-500 hover:text-red-700 transition-colors text-3xl font-bold w-8 h-8 flex items-center justify-center">
                        ×
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">

                    <!-- Doctor Details -->
                    <div
                        class="flex items-center gap-4 mb-6 p-4 bg-gradient-to-r from-primary-teal/10 to-blue-500/10 rounded-xl border border-primary-teal/20">
                        <div
                            class="w-20 h-20 rounded-full bg-gradient-to-br from-primary-blue to-primary-teal flex items-center justify-center shadow-lg overflow-hidden">
                            <img id="modal-doctor-img" src="" alt="Doctor" class="w-full h-full object-cover" />
                        </div>
                        <div>
                            <h4 id="modal-doctor-name" class="text-xl font-bold text-gray-900">Dr. Name</h4>
                            <p id="modal-doctor-dept" class="text-sm text-primary-teal font-medium">Department</p>
                        </div>
                    </div>

                    <!-- Patient Verification -->
                    <div class="mb-6 p-4 bg-gray-50 rounded-xl border border-gray-200">
                        <h5 class="text-sm font-bold text-gray-700 mb-3 uppercase tracking-wide">Patient Verification
                        </h5>
                        <div class="flex gap-2">
                            <input type="text" id="patientEmailBooking" placeholder="Patient Email ID"
                                class="flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                            <button type="button" onclick="verifyPatientBooking()"
                                class="bg-primary-teal hover:bg-teal-700 text-white font-bold px-6 py-3 rounded-lg transition-all">
                                Verify
                            </button>
                            <button type="button" onclick="showRegisterModal()"
                                class="bg-blue-500 hover:bg-blue-600 text-white font-bold px-6 py-3 rounded-lg transition-all">
                                Register
                            </button>
                        </div>
                        <p id="patientVerifyMessage" class="text-sm mt-2"></p>
                    </div>

                    <!-- Date Selection -->
                    <div class="mb-6">
                        <h5 class="text-sm font-semibold text-gray-700 mb-3 uppercase tracking-wide">Select Date</h5>
                        <div class="grid grid-cols-7 gap-2">
                            <button
                                class="date-btn bg-primary-teal text-white px-4 py-3 rounded-lg font-semibold text-sm hover:bg-primary-blue transition-all">
                                <div>Sun</div>
                                <div class="text-xs">26</div>
                            </button>
                            <button
                                class="date-btn bg-slate-700 text-white px-4 py-3 rounded-lg font-semibold text-sm hover:bg-slate-800 transition-all">
                                <div>Mon</div>
                                <div class="text-xs">27</div>
                            </button>
                            <button
                                class="date-btn bg-slate-700 text-white px-4 py-3 rounded-lg font-semibold text-sm hover:bg-slate-800 transition-all">
                                <div>Tue</div>
                                <div class="text-xs">28</div>
                            </button>
                            <button
                                class="date-btn bg-slate-700 text-white px-4 py-3 rounded-lg font-semibold text-sm hover:bg-slate-800 transition-all">
                                <div>Wed</div>
                                <div class="text-xs">29</div>
                            </button>
                            <button
                                class="date-btn bg-slate-700 text-white px-4 py-3 rounded-lg font-semibold text-sm hover:bg-slate-800 transition-all">
                                <div>Thu</div>
                                <div class="text-xs">30</div>
                            </button>
                            <button
                                class="date-btn bg-slate-700 text-white px-4 py-3 rounded-lg font-semibold text-sm hover:bg-slate-800 transition-all">
                                <div>Fri</div>
                                <div class="text-xs">31</div>
                            </button>
                            <button
                                class="date-btn bg-slate-700 text-white px-4 py-3 rounded-lg font-semibold text-sm hover:bg-slate-800 transition-all">
                                <div>Sat</div>
                                <div class="text-xs">1</div>
                            </button>
                        </div>
                    </div>

                    <!-- Time Slots -->
                    <div class="mb-6">
                        <h5 class="text-sm font-semibold text-gray-700 mb-3 uppercase tracking-wide">Available Slots
                        </h5>
                        <div class="grid grid-cols-4 gap-3">
                            <button
                                class="slot-btn bg-white border-2 border-primary-teal text-primary-teal font-semibold px-4 py-3 rounded-lg hover:bg-primary-teal hover:text-white transition-all">10:00
                                AM</button>
                            <button
                                class="slot-btn bg-white border-2 border-primary-teal text-primary-teal font-semibold px-4 py-3 rounded-lg hover:bg-primary-teal hover:text-white transition-all">11:00
                                AM</button>
                            <button
                                class="slot-btn bg-white border-2 border-primary-teal text-primary-teal font-semibold px-4 py-3 rounded-lg hover:bg-primary-teal hover:text-white transition-all">2:00
                                PM</button>
                            <button
                                class="slot-btn bg-white border-2 border-primary-teal text-primary-teal font-semibold px-4 py-3 rounded-lg hover:bg-primary-teal hover:text-white transition-all">3:00
                                PM</button>
                            <button
                                class="slot-btn bg-white border-2 border-primary-teal text-primary-teal font-semibold px-4 py-3 rounded-lg hover:bg-primary-teal hover:text-white transition-all">4:00
                                PM</button>
                            <button
                                class="slot-btn bg-white border-2 border-primary-teal text-primary-teal font-semibold px-4 py-3 rounded-lg hover:bg-primary-teal hover:text-white transition-all">5:00
                                PM</button>
                        </div>
                    </div>

                    <!-- Book Button -->
                    <button onclick="bookAppointment()"
                        class="w-full bg-gradient-to-r from-primary-teal to-teal-600 hover:from-teal-600 hover:to-teal-700 text-white font-bold py-4 rounded-lg transition-all text-lg shadow-lg hover:shadow-xl">
                        Book Slot
                    </button>

                </div>
            </div>
        </div>

        <!-- Patient Registration Modal -->
        <div id="register-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
            <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">

                <!-- Modal Header -->
                <div
                    class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between rounded-t-2xl z-10">
                    <h3 class="text-2xl font-bold text-slate-700">Patient Registration</h3>
                    <button onclick="closeModal('register-modal')"
                        class="text-red-500 hover:text-red-700 transition-colors text-3xl font-bold w-8 h-8 flex items-center justify-center">
                        ×
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="patient-register-form" class="space-y-4">

                        <div class="grid grid-cols-2 gap-4">
                            <!-- First Name -->
                            <div>
                                <label for="firstname" class="block text-sm font-semibold text-gray-700 mb-2">First Name
                                    :</label>
                                <input type="text" id="firstname"
                                    class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                                <p id="firstnameError" class="text-red-500 text-sm mt-1"></p>
                            </div>

                            <!-- Last Name -->
                            <div>
                                <label for="lastname" class="block text-sm font-semibold text-gray-700 mb-2">Last Name
                                    :</label>
                                <input type="text" id="lastname"
                                    class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                                <p id="lastnameError" class="text-red-500 text-sm mt-1"></p>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <!-- Contact -->
                            <div>
                                <label for="mobile" class="block text-sm font-semibold text-gray-700 mb-2">Contact
                                    :</label>
                                <input type="text" id="mobile"
                                    class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                                <p id="mobileError" class="text-red-500 text-sm mt-1"></p>
                            </div>

                            <!-- Email -->
                            <div>
                                <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email
                                    :</label>
                                <input type="email" id="email"
                                    class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                                <p id="emailError" class="text-red-500 text-sm mt-1"></p>
                            </div>
                        </div>

                        <!-- Gender -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Gender :</label>
                            <div class="flex gap-6">
                                <label class="flex items-center gap-2">
                                    <input type="radio" name="gender" value="Male" class="w-4 h-4 text-primary-teal" />
                                    <span>Male</span>
                                </label>
                                <label class="flex items-center gap-2">
                                    <input type="radio" name="gender" value="Female"
                                        class="w-4 h-4 text-primary-teal" />
                                    <span>Female</span>
                                </label>
                                <label class="flex items-center gap-2">
                                    <input type="radio" name="gender" value="Others"
                                        class="w-4 h-4 text-primary-teal" />
                                    <span>Others</span>
                                </label>
                            </div>
                            <p id="genderError" class="text-red-500 text-sm mt-1"></p>
                        </div>

                        <!-- Address -->
                        <div>
                            <label for="address" class="block text-sm font-semibold text-gray-700 mb-2">Address
                                :</label>
                            <input type="text" id="address"
                                class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                            <p id="addressError" class="text-red-500 text-sm mt-1"></p>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <!-- DOB -->
                            <div>
                                <label for="dob" class="block text-sm font-semibold text-gray-700 mb-2">DOB :</label>
                                <input type="date" id="dob"
                                    class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                                <p id="dobError" class="text-red-500 text-sm mt-1"></p>
                            </div>

                            <!-- Blood Group -->
                            <div>
                                <label for="blood_group" class="block text-sm font-semibold text-gray-700 mb-2">Blood
                                    Group :</label>
                                <select id="blood_group"
                                    class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent">
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                </select>
                                <p id="blood_groupError" class="text-red-500 text-sm mt-1"></p>
                            </div>
                        </div>

                        <!-- OTP -->
                        <div>
                            <label for="otp" class="block text-sm font-semibold text-gray-700 mb-2">OTP :</label>
                            <div class="flex gap-2">
                                <input type="text" id="otp"
                                    class="flex-1 px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-transparent" />
                                <button type="button" onclick="sendOTP()"
                                    class="bg-blue-500 hover:bg-blue-600 text-white font-bold px-6 py-2.5 rounded-lg transition-all">
                                    Send
                                </button>
                            </div>
                        </div>

                        <!-- Register Button -->
                        <button type="button" onclick="registerPatient()"
                            class="w-full bg-gradient-to-r from-primary-teal to-teal-600 hover:from-teal-600 hover:to-teal-700 text-white font-bold py-3 rounded-lg transition-all text-lg">
                            Register
                        </button>

                        <p id="errPatientReg" class="text-red-500 text-center"></p>
                    </form>
                </div>
            </div>
        </div>

        <!-- Loading Spinner Modal -->
        <div id="spinner-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center">
            <div class="bg-white rounded-xl p-10 shadow-xl">
                <div class="flex flex-col items-center">
                    <img src="/assets/favicon.png" alt="Loading" class="w-16 h-16 animate-bounce mb-3" />
                    <p class="text-gray-700 font-medium">Loading...</p>
                </div>
            </div>
        </div>

        <!-- Scripts -->
        <script src="/js/receptionist/receptionist_navbar.js"></script>
        <script>
            function filterDoctors() {
                const nameInput = document.getElementById('search-name').value.toLowerCase();
                const deptInput = document.getElementById('filter-dept').value.toLowerCase();
                const eduInput = document.getElementById('filter-edu').value.toLowerCase();

                const doctors = document.querySelectorAll('.doctor-card'); 

                doctors.forEach(doc => {
                    const nameEl = doc.querySelector('h3');
                    const deptEl = doc.querySelector('.doctor-dept');
                    const eduEl = doc.querySelector('.doctor-edu');

                    if (!nameEl || !deptEl || !eduEl) return;

                    const name = nameEl.textContent.toLowerCase();
                    const dept = deptEl.textContent.toLowerCase();
                    const edu = eduEl.textContent.toLowerCase();

                    const matchesName = name.includes(nameInput);
                    const matchesDept = dept.includes(deptInput);
                    const matchesEdu = edu.includes(eduInput);

                    if (matchesName && matchesDept && matchesEdu) {
                        doc.style.display = 'block';
                    } else {
                        doc.style.display = 'none';
                    }
                });

                // Check for empty results in visible sections
                updateNoResultsMessage('available-section');
                updateNoResultsMessage('onleave-section');
            }

            function updateNoResultsMessage(sectionId) {
                const section = document.getElementById(sectionId);
                if (!section) return;
                const visibleDoctors = Array.from(section.querySelectorAll('.doctor-card')).filter(d => d.style.display !== 'none');
                
                let noResultsMsg = section.querySelector('.no-results-msg');
                
                if (visibleDoctors.length === 0) {
                    if (!noResultsMsg) {
                        noResultsMsg = document.createElement('div');
                        noResultsMsg.className = 'no-results-msg col-span-full text-center py-20 bg-white rounded-xl border-2 border-dashed border-gray-200';
                        noResultsMsg.innerHTML = `
                            <i class="fas fa-search text-5xl text-gray-300 mb-4"></i>
                            <p class="text-xl text-gray-500">No doctors match your search filters</p>
                        `;
                        section.querySelector('.grid').appendChild(noResultsMsg);
                    }
                    // Hide the default "No doctors" if it exists
                    const defaultMsg = section.querySelector('.col-span-full:not(.no-results-msg)');
                    if(defaultMsg) defaultMsg.style.display = 'none';
                } else {
                    if (noResultsMsg) noResultsMsg.remove();
                    // Show default message if no doctors at all
                    const defaultMsg = section.querySelector('.col-span-full:not(.no-results-msg)');
                    // If there are actually no doctors in the array (activeDoctors.length == 0), keep default showing if search is empty
                    // Handled by EJS normally, but for search we should be careful.
                }
            }
            let currentDoctorId = null;
            let currentPatientId = null;
            let selectedSlotId = null;

            // Show/Hide Sections
            function showAvailable() {
                document.getElementById('available-section').classList.remove('hidden');
                document.getElementById('onleave-section').classList.add('hidden');

                document.getElementById('available-btn').classList.add('bg-primary-teal');
                document.getElementById('available-btn').classList.remove('bg-slate-600');
                document.getElementById('onleave-btn').classList.remove('bg-primary-teal');
                document.getElementById('onleave-btn').classList.add('bg-slate-600');
            }

            function showOnLeave() {
                document.getElementById('available-section').classList.add('hidden');
                document.getElementById('onleave-section').classList.remove('hidden');

                document.getElementById('onleave-btn').classList.add('bg-primary-teal');
                document.getElementById('onleave-btn').classList.remove('bg-slate-600');
                document.getElementById('available-btn').classList.remove('bg-primary-teal');
                document.getElementById('available-btn').classList.add('bg-slate-600');
            }

            // Modal Functions
            function closeModal(modalId) {
                document.getElementById(modalId).classList.add('hidden');
                document.body.style.overflow = 'auto';
            }

            function showModal(modalId) {
                document.getElementById(modalId).classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            async function openBookingModal(doctorId, doctorName, department, doctorImg) {
                currentDoctorId = doctorId;
                document.getElementById('modal-doctor-name').textContent = doctorName;
                document.getElementById('modal-doctor-dept').textContent = department;
                document.getElementById('modal-doctor-img').src = doctorImg;

                // Reset Patient Verification
                document.getElementById('patientEmailBooking').value = '';
                document.getElementById('patientVerifyMessage').textContent = '';
                currentPatientId = null;

                // Generate Next 7 Days
                const dateContainer = document.querySelector('#booking-modal .grid-cols-7');
                const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                let dateHtml = '';
                const today = new Date();

                for (let i = 0; i < 7; i++) {
                    const d = new Date();
                    d.setDate(today.getDate() + i);
                    const dayName = days[d.getDay()];
                    const dateNum = d.getDate();
                    const fullDate = d.toISOString().split('T')[0];
                    const activeClass = i === 0 ? 'bg-primary-teal' : 'bg-slate-700';

                    dateHtml += `
                        <button onclick="selectDate('${fullDate}', this)" 
                            class="date-btn ${activeClass} text-white px-2 py-3 rounded-lg font-semibold text-sm hover:bg-primary-blue transition-all">
                            <div>${dayName}</div>
                            <div class="text-xs">${dateNum}</div>
                        </button>
                    `;
                }
                dateContainer.innerHTML = dateHtml;

                showModal('booking-modal');
                fetchSlots(today.toISOString().split('T')[0]);
            }

            async function selectDate(date, btn) {
                document.querySelectorAll('.date-btn').forEach(b => {
                    b.classList.remove('bg-primary-teal');
                    b.classList.add('bg-slate-700');
                });
                btn.classList.remove('bg-slate-700');
                btn.classList.add('bg-primary-teal');
                fetchSlots(date);
            }

            async function fetchSlots(date) {
                const slotContainer = document.querySelector('#booking-modal .grid.grid-cols-4');
                slotContainer.innerHTML = '<p class="col-span-4 text-center text-gray-500 text-sm">Loading slots...</p>';

                try {
                    const response = await fetch(`/receptionist/get-slots?doctor_id=${currentDoctorId}&date=${date}`);
                    const data = await response.json();

                    if (data.slots && data.slots.length > 0) {
                        slotContainer.innerHTML = data.slots.map(slot => `
                        <button 
                            onclick="selectSlot('${slot.id}', this)"
                            class="slot-btn bg-white border-2 border-primary-teal text-primary-teal font-semibold px-4 py-3 rounded-lg hover:bg-primary-teal hover:text-white transition-all text-sm"
                        >
                            ${slot.slot_start}
                        </button>
                    `).join('');
                    } else {
                        slotContainer.innerHTML = '<p class="col-span-4 text-center text-red-500 text-sm">No slots available for this day</p>';
                    }
                } catch (err) {
                    slotContainer.innerHTML = '<p class="col-span-4 text-center text-red-500 text-sm">Failed to load slots</p>';
                }
            }

            function selectSlot(id, btn) {
                selectedSlotId = id;
                document.querySelectorAll('.slot-btn').forEach(b => {
                    b.classList.remove('bg-primary-teal', 'text-white');
                    b.classList.add('text-primary-teal');
                });
                btn.classList.add('bg-primary-teal', 'text-white');
                btn.classList.remove('text-primary-teal');
            }

            // Verify Patient (Booking Modal)
            async function verifyPatientBooking() {
                const email = document.getElementById('patientEmailBooking').value.trim();
                if (!email) return Swal.fire('Error', 'Please enter email', 'error');

                try {
                    const response = await fetch('/receptionist/verify-patient', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email })
                    });
                    const data = await response.json();

                    if (data.success) {
                        document.getElementById('patientVerifyMessage').textContent = `✓ Patient Verified: ${data.patient.firstname} ${data.patient.lastname}`;
                        document.getElementById('patientVerifyMessage').className = 'text-sm mt-2 text-green-600 font-bold';
                        currentPatientId = data.patient.id;
                    } else {
                        document.getElementById('patientVerifyMessage').textContent = '✗ ' + data.message;
                        document.getElementById('patientVerifyMessage').className = 'text-sm mt-2 text-red-600 font-bold';
                        currentPatientId = null;
                    }
                } catch (err) {
                    Swal.fire('Error', 'Verification failed', 'error');
                }
            }

            // Verify Patient (Report Modal)
            async function verifyPatientReport() {
                const email = document.getElementById('patientEmailReport').value.trim();
                if (!email) return Swal.fire('Error', 'Please enter email', 'error');

                try {
                    const response = await fetch('/receptionist/verify-patient', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email })
                    });
                    const data = await response.json();

                    const messageElement = document.querySelector('#add-report-modal #patientVerifyMessage');
                    if (data.success) {
                        messageElement.textContent = `✓ Verified: ${data.patient.firstname} ${data.patient.lastname}`;
                        messageElement.className = 'text-sm mb-4 text-green-600 font-bold';
                        document.getElementById('submit-report').disabled = false;
                        currentPatientId = data.patient.id;
                    } else {
                        messageElement.textContent = '✗ ' + data.message;
                        messageElement.className = 'text-sm mb-4 text-red-600 font-bold';
                        document.getElementById('submit-report').disabled = true;
                        currentPatientId = null;
                    }
                } catch (err) {
                    Swal.fire('Error', 'Verification failed', 'error');
                }
            }

            // Book Appointment
            async function bookAppointment() {
                if (!currentPatientId) {
                    Swal.fire('Error', 'Please verify patient first', 'error');
                    return;
                }
                if (!selectedSlotId) {
                    Swal.fire('Error', 'Please select a slot', 'error');
                    return;
                }

                try {
                    const response = await fetch('/receptionist/book-appointment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            slot_id: selectedSlotId,
                            patient_id: currentPatientId
                        })
                    });
                    const data = await response.json();
                    if (response.ok) {
                        Swal.fire('Success!', data.message, 'success').then(() => window.location.reload());
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (err) {
                    Swal.fire('Error', 'Something went wrong', 'error');
                }
            }

            function showRegisterModal() {
                showModal('register-modal');
            }

            // Register Patient
            async function registerPatient() {
                const formData = {
                    firstname: document.getElementById('firstname').value,
                    lastname: document.getElementById('lastname').value,
                    mobile: document.getElementById('mobile').value,
                    email: document.getElementById('email').value,
                    gender: document.querySelector('input[name="gender"]:checked')?.value,
                    address: document.getElementById('address').value,
                    dob: document.getElementById('dob').value,
                    blood_group: document.getElementById('blood_group').value
                };

                if (!formData.firstname || !formData.lastname || !formData.email || !formData.mobile) {
                    Swal.fire('Error', 'All fields are required', 'error');
                    return;
                }

                try {
                    const response = await fetch('/receptionist/register-patient', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    });
                    const data = await response.json();
                    if (response.ok) {
                        Swal.fire('Success!', 'Patient registered successfully!', 'success').then(() => {
                            document.getElementById('patientEmailBooking').value = formData.email;
                            verifyPatientBooking();
                            closeModal('register-modal');
                        });
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (err) {
                    Swal.fire('Error', 'Registration failed', 'error');
                }
            }

            // Close modals when clicking outside
            document.querySelectorAll('[id$="-modal"]').forEach(modal => {
                modal.addEventListener('click', function (e) {
                    if (e.target === this) {
                        closeModal(this.id);
                    }
                });
            });

            // Close modals on ESC key
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    document.querySelectorAll('[id$="-modal"]:not(.hidden)').forEach(modal => {
                        if (modal.id !== 'spinner-modal') {
                            closeModal(modal.id);
                        }
                    });
                }
            });


        </script>
        <script src="/js/receptionist/receptionist_navbar.js"></script>

</body>

</html>