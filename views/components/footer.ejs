    <!-- Scripts -->
    <script>
        // Mobile Menu Toggle
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        
        if (mobileMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', () => {
                mobileMenu.classList.toggle('active');
            });
            
            // Close mobile menu when clicking on links
            document.querySelectorAll('#mobile-menu a').forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.remove('active');
                });
            });
        }
        
        // Smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    const headerOffset = 80;
                    const elementPosition = target.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
                    
                    window.scrollTo({
                        top: offsetPosition,
                        behavior: 'smooth'
                    });
                }
            });
        });

        // Header shadow on scroll
        window.addEventListener('scroll', function() {
            const header = document.querySelector('header');
            if (header) {
                if (window.scrollY > 50) {
                    header.classList.add('shadow-2xl');
                } else {
                    header.classList.remove('shadow-2xl');
                }
            }
        });

        // Animate elements on scroll
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);

        // Observe all cards and animate them
        document.addEventListener('DOMContentLoaded', () => {
            const cards = document.querySelectorAll('.hover\\:-translate-y-2');
            cards.forEach(card => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(30px)';
                card.style.transition = 'all 0.6s ease-out';
                observer.observe(card);
            });
        });

        // User authentication check (optional - can be customized)
        const getUserDetails = async () => {
            try {
                const response = await fetch("/patient/userdetails");
                if (response.status === 200) {
                    location.href = '/patient/dashboard';
                }
            } catch (error) {
                console.log('User not authenticated');
            }
        };
        
        // Uncomment the line below if you want to enable auto-redirect for authenticated users
        // getUserDetails();

        // Button event listeners - Desktop
        const loginBtn = document.getElementById("patient-login-btn");
        const registerBtn = document.getElementById("patient-register-btn");
        
        if (loginBtn) {
            loginBtn.addEventListener("click", () => {
                location.href = "/patient/login";
            });
        }

        if (registerBtn) {
            registerBtn.addEventListener("click", () => {
                location.href = "/patient/signup/email";
            });
        }
        
        // Button event listeners - Mobile
        const mobileLoginBtn = document.getElementById("patient-login-btn-mobile");
        const mobileRegisterBtn = document.getElementById("patient-register-btn-mobile");
        
        if (mobileLoginBtn) {
            mobileLoginBtn.addEventListener("click", () => {
                location.href = "/patient/login";
            });
        }
        
        if (mobileRegisterBtn) {
            mobileRegisterBtn.addEventListener("click", () => {
                location.href = "/patient/signup/email";
            });
        }
    </script>
