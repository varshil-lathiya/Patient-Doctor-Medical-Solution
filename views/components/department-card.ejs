
<div class="bg-gradient-to-br from-<%= colorFrom %> to-<%= colorTo %> p-4 sm:p-6 rounded-xl sm:rounded-2xl shadow-lg hover:-translate-y-2 transition-all duration-300 border border-<%= borderColor %>">
    <div class="mb-3 sm:mb-4 transform hover:scale-110 hover:rotate-6 transition-all duration-300">
        <img class="w-16 h-16 sm:w-20 sm:h-20 mx-auto" src="<%= icon %>" alt="<%= title %>">
    </div>
    <h5 class="text-lg sm:text-xl font-bold text-gray-900 text-center mb-2 sm:mb-3 font-display"><%= title %></h5>
    <p class="text-xs sm:text-sm text-gray-600 text-center leading-relaxed"><%= description %></p>
</div>
