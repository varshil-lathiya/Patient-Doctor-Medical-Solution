<div class="bg-white p-6 sm:p-8 rounded-xl sm:rounded-2xl shadow-lg hover:-translate-y-2 transition-all duration-300 border border-<%= borderColor %>">
    <div class="w-12 h-12 sm:w-16 sm:h-16 bg-gradient-to-br from-<%= iconBgFrom %> to-<%= iconBgTo %> rounded-lg sm:rounded-xl flex items-center justify-center mb-4 sm:mb-6">
        <i class="<%= icon %> text-white text-xl sm:text-2xl"></i>
    </div>
    <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3 sm:mb-4 font-display"><%= title %></h3>
    <p class="text-sm sm:text-base text-gray-600 leading-relaxed"><%= description %></p>
</div>
