<!-- components/receptionist-sidebar.ejs -->
<!-- <script src="/js/receptionist/receptionist_navbar.js"></script> -->

<div class="lg:hidden fixed top-0 left-0 right-0 h-16 bg-white border-b border-gray-100 shadow-sm z-[60] flex items-center px-4">
    <img src="/assets/logo.png" alt="PDMS Logo" class="h-10 w-auto" />
</div>

<!-- Mobile Menu Button -->
<button type="button" onclick="openReceptionistMobileMenu()"
    class="lg:hidden fixed top-2.5 right-4 z-[70] w-11 h-11 rounded-xl bg-primary-teal text-white shadow-lg flex items-center justify-center">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
</button>

<!-- Mobile Sidebar Drawer -->
<div id="receptionist-mobile-menu" class="lg:hidden hidden fixed inset-0 z-[80]">
    <button type="button" onclick="closeReceptionistMobileMenu()" class="absolute inset-0 bg-black/40"></button>
    <aside class="relative h-full w-64 bg-white shadow-2xl flex flex-col border-r border-gray-200">
        <div class="p-4 border-b border-gray-200 flex items-center justify-between">
            <img src="/assets/logo.png" alt="PDMS Logo" class="h-12 w-auto" />
            <button type="button" onclick="closeReceptionistMobileMenu()" class="w-9 h-9 rounded-lg bg-gray-100 text-gray-600 flex items-center justify-center text-2xl leading-none">×</button>
        </div>

        <nav class="flex-1 px-3 py-4 overflow-y-auto">
            <div class="space-y-1">
                <a href="/receptionist/dashboard" class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold hover:bg-primary-teal hover:text-white">
                    <i class="fas fa-calendar-alt text-lg"></i><span>Schedule</span>
                </a>
                <a href="/receptionist/appointments" class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold hover:bg-primary-teal hover:text-white">
                    <i class="fas fa-calendar-check text-lg"></i><span>Appointments</span>
                </a>
                <a href="/receptionist/doctors" class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold hover:bg-primary-teal hover:text-white">
                    <i class="fas fa-user-doctor text-lg"></i><span>Doctors</span>
                </a>
                <a href="/receptionist/patients" class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold hover:bg-primary-teal hover:text-white">
                    <i class="fas fa-users text-lg"></i><span>Patients</span>
                </a>
                <a href="/receptionist/addReport" class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold hover:bg-primary-teal hover:text-white">
                    <i class="fas fa-file-medical text-lg"></i><span>Add Report</span>
                </a>
                <a href="/receptionist/profile" class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold hover:bg-primary-teal hover:text-white">
                    <i class="fas fa-user-circle text-lg"></i><span>Profile</span>
                </a>
                <a href="/receptionist/leaves" class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold hover:bg-primary-teal hover:text-white">
                    <i class="fas fa-calendar-times text-lg"></i><span>Leave Application</span>
                </a>
            </div>
        </nav>

        <div class="p-4 border-t border-gray-200">
            <button onclick="logout()" class="w-full flex items-center justify-center gap-3 px-4 py-3 bg-red-500 hover:bg-red-600 text-white font-bold rounded-xl">
                <i class="fas fa-sign-out-alt text-lg"></i><span>Logout</span>
            </button>
        </div>
    </aside>
</div>

<!-- Sidebar Navigation -->
<aside class="hidden lg:flex fixed left-0 top-0 h-screen w-64 bg-white shadow-xl z-50 flex-col border-r border-gray-200">
    <!-- Logo Section -->
    <div class="p-4 border-b border-gray-200">
        <div class="flex items-center justify-center">
            <img src="/assets/logo.png" alt="PDMS Logo" class="h-12 w-auto" />
        </div>
    </div>

    <!-- Profile Section -->
    <div class="px-6 py-3 border-b border-gray-200">
        <div class="flex flex-col items-center">
            <div class="w-16 h-16 rounded-full overflow-hidden border-4 border-primary-teal shadow-lg mb-1">
                <% if (user.profile_pic) { %>
                    <img src="<%= user.profile_pic %>" alt="Profile" class="w-full h-full object-cover" />
                <% } else { %>
                    <div class="w-full h-full bg-gradient-to-br from-primary-teal to-teal-700 flex items-center justify-center text-white text-xl font-black select-none">
                        <%= user.firstname[0].toUpperCase() %><%= user.lastname[0].toUpperCase() %>
                    </div>
                <% } %>
            </div>
            <h4 id="recep_name" class="text-gray-900 font-bold text-center text-sm">
                <%= user.firstname %>
                    <%= user.lastname %>
            </h4>
        </div>
    </div>

    <!-- Navigation Menu -->
    <nav class="flex-1 px-3 py-4 overflow-y-auto">
        <div class="mb-4">
            <h4 class="text-slate-700 text-[10px] font-bold uppercase tracking-wider mb-2 px-3">
                Menu
            </h4>
            <div class="space-y-1">
                <!-- Schedule -->
                <a id="nav-schedule" href="/receptionist/dashboard"
                    class="nav-item w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold transition-all duration-300 hover:bg-primary-teal hover:text-white group">
                    <i class="fas fa-calendar-alt text-lg"></i>
                    <span>Schedule</span>
                </a>

                <!-- Appointments -->
                <a id="nav-appointments" href="/receptionist/appointments"
                    class="nav-item w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold transition-all duration-300 hover:bg-primary-teal hover:text-white group">
                    <i class="fas fa-calendar-check text-lg"></i>
                    <span>Appointments</span>
                </a>

                <!-- Doctors -->
                <a id="nav-doctors" href="/receptionist/doctors"
                    class="nav-item w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold transition-all duration-300 hover:bg-primary-teal hover:text-white group">
                    <i class="fas fa-user-doctor text-lg"></i>
                    <span>Doctors</span>
                </a>

                <!-- Patients -->
                <a id="nav-patients" href="/receptionist/patients"
                    class="nav-item w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold transition-all duration-300 hover:bg-primary-teal hover:text-white group">
                    <i class="fas fa-users text-lg"></i>
                    <span>Patients</span>
                </a>

                <!-- Add Report -->
                <a id="nav-add-report" href="/receptionist/addReport"
                    class="nav-item w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold transition-all duration-300 hover:bg-primary-teal hover:text-white group">
                    <i class="fas fa-file-medical text-lg"></i>
                    <span>Add Report</span>
                </a>

                <!-- Profile -->
                <a id="nav-profile" href="/receptionist/profile"
                    class="nav-item w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold transition-all duration-300 hover:bg-primary-teal hover:text-white group">
                    <i class="fas fa-user-circle text-lg"></i>
                    <span>Profile</span>
                </a>

                <!-- Leave Application -->
                <a id="nav-leaves" href="/receptionist/leaves"
                    class="nav-item w-full flex items-center gap-3 px-4 py-2 rounded-xl text-gray-700 font-semibold transition-all duration-300 hover:bg-primary-teal hover:text-white group">
                    <i class="fas fa-calendar-times text-lg"></i>
                    <span>Leave Application</span>
                </a>
            </div>
        </div>
    </nav>

    <!-- Logout Section -->
    <div class="p-4 border-t border-gray-200">
        <button onclick="logout()"
            class="btn-logout w-full flex items-center justify-center gap-3 px-4 py-3 bg-red-500 hover:bg-red-600 text-white font-bold rounded-xl transition-all duration-300 group">
            <i class="fas fa-sign-out-alt text-lg group-hover:translate-x-1 transition-transform"></i>
            <span>Logout</span>
        </button>
    </div>

</aside>

<style>
    /* Active navigation item */
    .nav-item.active {
        background: linear-gradient(135deg, #008B8B, #00B4D8);
        color: white !important;
        box-shadow: 0 4px 12px rgba(0, 139, 139, 0.3);
    }

    .nav-item.active i {
        transform: scale(1.1);
    }

    /* Hide scrollbar for Chrome, Safari and Opera */
    aside::-webkit-scrollbar,
    nav::-webkit-scrollbar {
        display: none;
    }

    /* Hide scrollbar for IE, Edge and Firefox */
    aside,
    nav {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
    }

    @media (max-width: 1023px) {
        #right-section,
        main {
            padding-top: 5rem !important;
        }
    }
</style>

<script>
    function openReceptionistMobileMenu() {
        document.getElementById('receptionist-mobile-menu')?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeReceptionistMobileMenu() {
        document.getElementById('receptionist-mobile-menu')?.classList.add('hidden');
        document.body.style.overflow = 'auto';
    }
</script>
