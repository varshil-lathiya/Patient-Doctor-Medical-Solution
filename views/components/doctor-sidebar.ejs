<div class="lg:hidden fixed top-0 left-0 right-0 h-16 bg-white border-b border-gray-100 shadow-sm z-[60] flex items-center px-4">
    <img src="/assets/logo.png" alt="PDMS Logo" class="h-10 w-auto" />
</div>

<!-- Mobile Menu Button -->
<button type="button" onclick="openDoctorMobileMenu()"
    class="lg:hidden fixed top-2.5 right-4 z-[70] w-11 h-11 rounded-xl bg-teal-600 text-white shadow-lg flex items-center justify-center">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
</button>

<!-- Mobile Sidebar Drawer -->
<div id="doctor-mobile-menu" class="lg:hidden hidden fixed inset-0 z-[80]">
    <button type="button" onclick="closeDoctorMobileMenu()" class="absolute inset-0 bg-black/40"></button>
    <aside class="relative h-full w-80 max-w-[85vw] bg-gradient-to-br from-teal-600 to-cyan-500 text-white flex flex-col shadow-2xl">
        <div class="p-6 bg-white/10 backdrop-blur-sm flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center shadow-md">
                    <img src="/assets/favicon.png" alt="Logo" class="w-10 h-10">
                </div>
                <span class="text-2xl font-bold">PDMS</span>
            </div>
            <button type="button" onclick="closeDoctorMobileMenu()" class="w-9 h-9 rounded-lg bg-white/10 text-white flex items-center justify-center text-2xl leading-none">×</button>
        </div>

        <div class="p-6 text-center border-b border-white/20">
            <div class="w-20 h-20 mx-auto mb-3 rounded-full border-4 border-white shadow-lg overflow-hidden">
                <img src="<%= user.profile_pic || 'https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=200&h=200&fit=crop' %>"
                    alt="Doctor" class="w-full h-full object-cover">
            </div>
            <h4 class="text-lg font-semibold">Dr. <%= user.firstname %> <%= user.lastname %></h4>
            <p class="text-teal-100 text-sm mt-1"><%= user.department %></p>
        </div>

        <nav class="flex-1 p-6 space-y-2">
            <button onclick="window.location.href='/doctor/dashboard'"
                class="w-full text-left px-4 py-3 rounded-lg <%= currentPage === 'dashboard' ? 'bg-white text-teal-600 font-medium shadow-md' : 'hover:bg-white/10 font-medium transition' %>">
                Dashboard
            </button>
            <button onclick="window.location.href='/doctor/appoinments'"
                class="w-full text-left px-4 py-3 rounded-lg <%= currentPage === 'appointments' ? 'bg-white text-teal-600 font-medium shadow-md' : 'hover:bg-white/10 font-medium transition' %>">
                Appointments
            </button>
            <button onclick="window.location.href='/doctor/profilePage'"
                class="w-full text-left px-4 py-3 rounded-lg <%= currentPage === 'profile' ? 'bg-white text-teal-600 font-medium shadow-md' : 'hover:bg-white/10 font-medium transition' %>">
                Profile
            </button>
            <button onclick="window.location.href='/doctor/leaves'"
                class="w-full text-left px-4 py-3 rounded-lg <%= currentPage === 'leaves' ? 'bg-white text-teal-600 font-medium shadow-md' : 'hover:bg-white/10 font-medium transition' %>">
                Leave Application
            </button>
        </nav>

        <div class="p-6 border-t border-white/20">
            <button onclick="logout()" class="w-full px-4 py-3 bg-red-500 hover:bg-red-600 rounded-lg font-medium transition shadow-lg">
                Logout
            </button>
        </div>
    </aside>
</div>

<div class="hidden lg:flex w-80 bg-gradient-to-br from-teal-600 to-cyan-500 text-white flex-col shadow-2xl">
    <!-- Logo Section -->
    <div class="p-6 bg-white/10 backdrop-blur-sm">
        <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center shadow-md">
                <img src="/assets/favicon.png" alt="Logo" class="w-10 h-10">
            </div>
            <span class="text-2xl font-bold">PDMS</span>
        </div>
    </div>

    <!-- Doctor Profile -->
    <div class="p-6 text-center border-b border-white/20">
        <div class="w-24 h-24 mx-auto mb-4 rounded-full border-4 border-white shadow-lg overflow-hidden">
            <% if (user.profile_pic) { %>
                <img src="<%= user.profile_pic %>" alt="Doctor" class="w-full h-full object-cover">
            <% } else { %>
                <div class="w-full h-full bg-white flex items-center justify-center text-primary-teal text-2xl font-black select-none">
                    <%= user.firstname[0].toUpperCase() %><%= user.lastname[0].toUpperCase() %>
                </div>
            <% } %>
        </div>
        <h4 class="text-xl font-semibold">Dr. <%= user.firstname %>
                <%= user.lastname %>
        </h4>
        <p class="text-teal-100 text-sm mt-1">
            <%= user.department %>
        </p>
    </div>

    <!-- Navigation Menu -->
    <div class="flex-1 p-6">
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-4 text-teal-100">Menu</h4>
        <nav class="space-y-2">
            <button onclick="window.location.href='/doctor/dashboard'"
                class="nav-item w-full text-left px-4 py-3 rounded-lg <%= currentPage === 'dashboard' ? 'bg-white text-teal-600 font-medium shadow-md' : 'hover:bg-white/10 font-medium transition' %>">
                <span class="flex items-center gap-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6">
                        </path>
                    </svg>
                    Dashboard
                </span>
            </button>
            <button onclick="window.location.href='/doctor/appoinments'"
                class="nav-item w-full text-left px-4 py-3 rounded-lg <%= currentPage === 'appointments' ? 'bg-white text-teal-600 font-medium shadow-md' : 'hover:bg-white/10 font-medium transition' %>">
                <span class="flex items-center gap-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                        </path>
                    </svg>
                    Appointments
                </span>
            </button>
            <button onclick="window.location.href='/doctor/profilePage'"
                class="nav-item w-full text-left px-4 py-3 rounded-lg <%= currentPage === 'profile' ? 'bg-white text-teal-600 font-medium shadow-md' : 'hover:bg-white/10 font-medium transition' %>">
                <span class="flex items-center gap-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    Profile
                </span>
            </button>
            <button onclick="window.location.href='/doctor/leaves'"
                class="nav-item w-full text-left px-4 py-3 rounded-lg <%= currentPage === 'leaves' ? 'bg-white text-teal-600 font-medium shadow-md' : 'hover:bg-white/10 font-medium transition' %>">
                <span class="flex items-center gap-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                        </path>
                    </svg>
                    Leave Application
                </span>
            </button>
        </nav>
    </div>

    <!-- Logout Button -->
    <div class="p-6 border-t border-white/20">
        <button onclick="logout()"
            class="w-full px-4 py-3 bg-red-500 hover:bg-red-600 rounded-lg font-medium transition shadow-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                </path>
            </svg>
            Logout
        </button>
    </div>
</div>

<script>
    function openDoctorMobileMenu() {
        document.getElementById('doctor-mobile-menu')?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeDoctorMobileMenu() {
        document.getElementById('doctor-mobile-menu')?.classList.add('hidden');
        document.body.style.overflow = 'auto';
    }
</script>

<style>
    @media (max-width: 1023px) {
        .doctor-dashboard-shell > .flex-1,
        .doctor-appointments-shell > .flex-1,
        body > .flex.min-h-screen > .flex-1 {
            padding-top: 4rem;
        }
    }
</style>
