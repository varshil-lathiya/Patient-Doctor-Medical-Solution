<%- include('../components/header', { title: 'Staff Login - Kalp Hospital' , page: 'login' }) %>

    <div
        class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 via-white to-cyan-50 py-12 px-4 sm:px-6 lg:px-8">
        <div
            class="max-w-md w-full space-y-8 bg-white p-10 rounded-2xl shadow-2xl border border-blue-100 transform transition-all hover:scale-[1.01]">
            <div>
                <div class="flex justify-center">
                    <div class="p-3 bg-blue-600 rounded-xl shadow-lg shadow-blue-200">
                        <i class="fas fa-user-shield text-3xl text-white"></i>
                    </div>
                </div>
                <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 font-display">
                    Staff Portal
                </h2>
                <p class="mt-2 text-center text-sm text-gray-600">
                    Admin, Doctor & Receptionist Access
                </p>
            </div>

            <form class="mt-8 space-y-6" id="staffLoginForm">
                <div class="rounded-md shadow-sm -space-y-px">
                    <div class="mb-4">
                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email Address</label>
                        <div class="relative">
                            <div
                                class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                                <i class="fas fa-envelope"></i>
                            </div>
                            <input id="email" name="email" type="email" required
                                class="appearance-none rounded-xl relative block w-full px-10 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-blue focus:border-transparent transition-all"
                                placeholder="name@kalphospital.com">
                        </div>
                    </div>

                    <div class="mb-6">
                        <label for="password" class="block text-sm font-semibold text-gray-700 mb-1">Password</label>
                        <div class="relative">
                            <div
                                class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                                <i class="fas fa-lock"></i>
                            </div>
                            <input id="password" name="password" type="password" required
                                class="appearance-none rounded-xl relative block w-full px-10 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-blue focus:border-transparent transition-all"
                                placeholder="••••••••">
                        </div>
                    </div>
                </div>

                <div>
                    <button type="submit"
                        class="group relative w-full flex justify-center py-3.5 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-gradient-to-r from-primary-blue to-primary-teal hover:from-blue-700 hover:to-teal-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-blue transition-all shadow-lg active:scale-95">
                        <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                            <i class="fas fa-sign-in-alt group-hover:translate-x-1 transition-transform"></i>
                        </span>
                        Login to Dashboard
                    </button>
                </div>
            </form>

            <div class="text-center">
                <a href="/patient/login"
                    class="text-sm font-medium text-primary-blue hover:text-primary-teal transition-colors">
                    Are you a patient? Login here
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('staffLoginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            try {
                const response = await fetch('/staff/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (response.ok) {
                    window.location.href = `/${result.role}/dashboard`;
                } else {
                    Swal.fire({
                        title: 'Login Failed',
                        text: result.message || 'Invalid credentials. Please try again.',
                        icon: 'error',
                        position: 'top',
                        confirmButtonColor: '#2563eb'
                    });
                }
            } catch (error) {
                console.error('Login error:', error);
                Swal.fire({
                    title: 'System Error',
                    text: 'An unexpected error occurred. Please try again.',
                    icon: 'error',
                    position: 'top',
                    confirmButtonColor: '#2563eb'
                });
            }
        });
    </script>

    <%- include('../components/footer') %>