<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verification</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Simple Notify (optional, kept for compatibility) -->
    <script src="https://cdn.jsdelivr.net/npm/simple-notify/dist/simple-notify.min.js"></script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/simple-notify/dist/simple-notify.css"
    />
  </head>

  <body class="bg-teal-50 min-h-screen flex items-center justify-center">
    <div
      class="w-11/12 sm:w-2/3 md:w-1/3 bg-white shadow-2xl rounded-2xl p-6 sm:p-8 flex flex-col items-center"
    >
      <!-- Logo -->
      <div class="w-full flex justify-center mb-6">
        <img src="/assets/logo.png" alt="Logo" class="w-28 h-28 object-contain" />
      </div>

      <!-- Title -->
      <div class="text-center mb-6">
        <h2 class="text-2xl font-semibold text-gray-800">Verification Code</h2>
        <p class="text-gray-500 text-sm mt-1">
          We’ve sent a 6-digit verification code to your email.
        </p>
      </div>

      <!-- OTP Inputs -->
      <div id="inputs" class="flex justify-center gap-2 sm:gap-3 mb-6 w-full sm:w-4/5">
        <input type="text" maxlength="1" class="otp-input" />
        <input type="text" maxlength="1" class="otp-input" />
        <input type="text" maxlength="1" class="otp-input" />
        <input type="text" maxlength="1" class="otp-input" />
        <input type="text" maxlength="1" class="otp-input" />
        <input type="text" maxlength="1" class="otp-input" />
      </div>

      <!-- Error Message -->
      <p id="otpError" class="text-red-500 text-sm mb-4 text-center"></p>

      <!-- Verify Button -->
      <div class="w-full text-center">
        <button
          id="verify"
          onclick="verifyOTP()"
          class="w-4/5 bg-teal-600 text-white py-2.5 rounded-lg hover:bg-teal-700 transition-colors"
        >
          Verify
        </button>
      </div>
    </div>

    <script>
      // Redirect check (optional pre-verification step)

      window.onload = () => {
        setupOTPInputs();
      };

      // OTP input behavior
      function setupOTPInputs() {
        const inputs = document.querySelectorAll(".otp-input");

        inputs.forEach((input, index) => {
          input.addEventListener("input", (e) => {
            const value = e.target.value;
            if (!/^[0-9]$/.test(value)) {
              e.target.value = "";
              return;
            }
            if (index < inputs.length - 1 && value) {
              inputs[index + 1].focus();
            }
          });

          input.addEventListener("keydown", (e) => {
            if (e.key === "Backspace" && !input.value && index > 0) {
              inputs[index - 1].focus();
            }
          });

          input.addEventListener("paste", (e) => {
            e.preventDefault();
            const pasteData = e.clipboardData.getData("text").trim();
            for (let i = 0; i < inputs.length; i++) {
              inputs[i].value = pasteData[i] || "";
            }
            const nextEmpty = Array.from(inputs).find((el) => !el.value);
            if (nextEmpty) nextEmpty.focus();
          });
        });
      }

      // Verify OTP
      async function verifyOTP() {
        try {
          let otp = "";
          const inputs = document.querySelectorAll(".otp-input");
          inputs.forEach((el) => (otp += el.value));

          if (otp.length < 6) {
            document.getElementById("otpError").innerText =
              "Please enter all 6 digits.";
            return;
          }

  const response = await fetch("/patient/login/otp_verification", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify({ otp }),
  });
          if (response.status === 200) {
            // Success Alert
            Swal.fire({
              icon: "success",
              title: "Verification Successful!",
              text: "Redirecting to your dashboard...",
              confirmButtonColor: "#0d9488",
              confirmButtonText: "OK",
              allowOutsideClick: false,
            }).then(() => {
              location.href = "/patient/dashboard";
            });
          } else if (response.status === 400) {
            let data = await response.json();
            Swal.fire({
              icon: "error",
              title: "Invalid Code",
              text: data.message || "Please try again.",
              confirmButtonColor: "#dc2626",
              confirmButtonText: "OK",
              allowOutsideClick: false,
            })
            // .then(() => {
            //   location.href = "/patient/email";
            // });
          } else if (response.status === 440)  {
            Swal.fire({
              icon: "error",
              title: "Session Expired",
              text: "Please sign up again.",
              confirmButtonColor: "#dc2626",
              confirmButtonText: "OK",
              allowOutsideClick: false,
            })
          }
        } catch (error) {
          console.error(error);
          Swal.fire({
            icon: "error",
            title: "Server Error",
            text: "Something went wrong. Please try again later.",
            confirmButtonColor: "#dc2626",
          }).then(() => {
              location.href = "/patient/login";
            });
        }
      }
    </script>

    <style>
      .otp-input {
        width: 3rem;
        height: 3.5rem;
        border: 2px solid #14b8a6;
        border-radius: 0.5rem;
        text-align: center;
        font-size: 1.25rem;
        font-weight: 500;
        color: #0f766e;
        outline: none;
        transition: border-color 0.2s ease;
      }

      .otp-input:focus {
        border-color: #0d9488;
        box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.2);
      }

      @media (max-width: 640px) {
        .otp-input {
          width: 2.125rem;
          height: 3rem;
          font-size: 1.125rem;
        }
      }
    </style>
  </body>
</html>
