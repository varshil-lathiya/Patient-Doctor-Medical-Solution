<%- include('../components/header', { 
    title: 'Patient Registration -  Kalp Hospital', 
    page: 'register' 
}) %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Registration Section -->
<section class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-cyan-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-12 xl:px-20">
        <div class="max-w-7xl mx-auto">
            
            <!-- Page Header -->
            <div class="text-center mb-12">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-primary-blue to-primary-teal rounded-2xl mb-4 shadow-lg">
                    <i class="fas fa-user-edit text-white text-2xl"></i>
                </div>
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-3 font-display">
                    Complete Your Registration
                </h1>
                <p class="text-gray-600 text-lg max-w-2xl mx-auto">
                    Fill in your details to create your patient profile
                </p>
            </div>

            <div class="grid lg:grid-cols-3 gap-8 items-start">
                
                <!-- Left Side - Form -->
                <div class="lg:col-span-2">
                    <div class="bg-white rounded-3xl shadow-2xl p-8 md:p-10 border border-gray-100">
                        
                        <!-- Progress Indicator -->
                        <div class="mb-8">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-semibold text-gray-700">Registration Progress</span>
                                <span class="text-sm font-semibold text-primary-blue">Step 2 of 2</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-2">
                                <div class="bg-gradient-to-r from-primary-blue to-primary-teal h-2 rounded-full" style="width: 100%"></div>
                            </div>
                        </div>

                        <!-- Form -->
                        <form id="register_form" class="space-y-6">
                            
                            <!-- Personal Information Section -->
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                                    <i class="fas fa-user text-primary-blue mr-3"></i>
                                    Personal Information
                                </h3>
                                
                                <div class="grid md:grid-cols-2 gap-6">
                                    <!-- First Name -->
                                    <div>
                                        <label for="firstname" class="block text-sm font-semibold text-gray-700 mb-2">
                                            First Name <span class="text-red-500">*</span>
                                        </label>
                                        <input 
                                            type="text" 
                                            id="firstname" 
                                            name="firstname"
                                            placeholder="Enter first name"
                                            class="w-full px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-primary-blue focus:ring-2 focus:ring-primary-blue/20 outline-none transition-all duration-200"
                                            required
                                        />
                                        <p id="firstnameError" class="text-red-600 text-sm mt-1 hidden"></p>
                                    </div>

                                    <!-- Last Name -->
                                    <div>
                                        <label for="lastname" class="block text-sm font-semibold text-gray-700 mb-2">
                                            Last Name <span class="text-red-500">*</span>
                                        </label>
                                        <input 
                                            type="text" 
                                            id="lastname" 
                                            name="lastname"
                                            placeholder="Enter last name"
                                            class="w-full px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-primary-blue focus:ring-2 focus:ring-primary-blue/20 outline-none transition-all duration-200"
                                            required
                                        />
                                        <p id="lastnameError" class="text-red-600 text-sm mt-1 hidden"></p>
                                    </div>

                                    <!-- Email (Read-only) -->
                                    <div>
                                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
                                            Email Address <span class="text-red-500">*</span>
                                        </label>
                                        <div class="relative">
                                            <input 
                                                type="email" 
                                                id="email" 
                                                name="email"
                                                class="w-full px-4 py-3 bg-gray-100 border-2 border-gray-200 rounded-xl outline-none cursor-not-allowed"
                                                readonly
                                            />
                                            <i class="fas fa-lock absolute right-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                                        </div>
                                        <p id="emailError" class="text-red-600 text-sm mt-1 hidden"></p>
                                    </div>

                                    <!-- Mobile -->
                                    <div>
                                        <label for="mobile" class="block text-sm font-semibold text-gray-700 mb-2">
                                            Contact Number <span class="text-red-500">*</span>
                                        </label>
                                        <input 
                                            type="tel" 
                                            id="mobile" 
                                            name="mobile"
                                            placeholder="Enter 10-digit number"
                                            maxlength="10"
                                            class="w-full px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-primary-blue focus:ring-2 focus:ring-primary-blue/20 outline-none transition-all duration-200"
                                            required
                                        />
                                        <p id="mobileError" class="text-red-600 text-sm mt-1 hidden"></p>
                                    </div>

                                    <!-- Date of Birth -->
                                    <div>
                                        <label for="dob" class="block text-sm font-semibold text-gray-700 mb-2">
                                            Date of Birth <span class="text-red-500">*</span>
                                        </label>
                                        <input 
                                            type="date" 
                                            id="dob" 
                                            name="dob"
                                            class="w-full px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-primary-blue focus:ring-2 focus:ring-primary-blue/20 outline-none transition-all duration-200"
                                            required
                                        />
                                        <p id="dobError" class="text-red-600 text-sm mt-1 hidden"></p>
                                    </div>

                                    <!-- Gender -->
                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Gender <span class="text-red-500">*</span>
                                        </label>
                                        <div class="flex gap-4">
                                            <label class="flex items-center px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl cursor-pointer hover:border-primary-blue transition-all">
                                                <input type="radio" name="gender" value="Male" class="w-4 h-4 text-primary-blue" required />
                                                <span class="ml-2 text-gray-700">Male</span>
                                            </label>
                                            <label class="flex items-center px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl cursor-pointer hover:border-primary-blue transition-all">
                                                <input type="radio" name="gender" value="Female" class="w-4 h-4 text-primary-blue" required />
                                                <span class="ml-2 text-gray-700">Female</span>
                                            </label>
                                            <label class="flex items-center px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl cursor-pointer hover:border-primary-blue transition-all">
                                                <input type="radio" name="gender" value="Other" class="w-4 h-4 text-primary-blue" required />
                                                <span class="ml-2 text-gray-700">Other</span>
                                            </label>
                                        </div>
                                        <p id="genderError" class="text-red-600 text-sm mt-1 hidden"></p>
                                    </div>
                                </div>
                            </div>

                            <!-- Medical Information Section -->
                            <div class="pt-6 border-t border-gray-200">
                                <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                                    <i class="fas fa-heart-pulse text-primary-teal mr-3"></i>
                                    Medical Information
                                </h3>
                                
                                <div class="grid md:grid-cols-2 gap-6">
                                    <!-- Blood Group -->
                                    <div>
                                        <label for="blood_group" class="block text-sm font-semibold text-gray-700 mb-2">
                                            Blood Group <span class="text-red-500">*</span>
                                        </label>
                                        <select 
                                            id="blood_group" 
                                            name="blood_group"
                                            class="w-full px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-primary-blue focus:ring-2 focus:ring-primary-blue/20 outline-none transition-all duration-200"
                                            required
                                        >
                                            <option value="">Select blood group</option>
                                            <option value="A+">A+</option>
                                            <option value="A-">A-</option>
                                            <option value="B+">B+</option>
                                            <option value="B-">B-</option>
                                            <option value="AB+">AB+</option>
                                            <option value="AB-">AB-</option>
                                            <option value="O+">O+</option>
                                            <option value="O-">O-</option>
                                        </select>
                                        <p id="blood_groupError" class="text-red-600 text-sm mt-1 hidden"></p>
                                    </div>

                                    <!-- Address -->
                                    <div>
                                        <label for="address" class="block text-sm font-semibold text-gray-700 mb-2">
                                            Address <span class="text-red-500">*</span>
                                        </label>
                                        <input 
                                            type="text" 
                                            id="address" 
                                            name="address"
                                            placeholder="Enter your address"
                                            class="w-full px-4 py-3 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-primary-blue focus:ring-2 focus:ring-primary-blue/20 outline-none transition-all duration-200"
                                            required
                                        />
                                        <p id="addressError" class="text-red-600 text-sm mt-1 hidden"></p>
                                    </div>
                                </div>
                            </div>


                            <!-- Submit Button -->
                            <button 
                              onclick="insertSignUpDetails()"
                                type="button" 
                                id="btn-submit"
                                class="w-full bg-gradient-to-r from-primary-blue to-primary-teal text-white font-bold py-4 rounded-xl hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200"
                            >
                                <span class="flex items-center justify-center gap-2">
                                    <i class="fas fa-check-circle text-xl"></i>
                                    Complete Registration
                                </span>
                            </button>

                        </form>
                    </div>
                </div>

                <!-- Right Side - Information -->
                <div class="lg:col-span-1 space-y-6">
                    
                    <!-- Why Register Card -->
                    <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
                        <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                            <i class="fas fa-info-circle text-primary-blue mr-2"></i>
                            Why Register?
                        </h3>
                        <ul class="space-y-3 text-sm text-gray-600">
                            <li class="flex items-start">
                                <i class="fas fa-check-circle text-accent-green mt-1 mr-3"></i>
                                <span>Quick appointment booking</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check-circle text-accent-green mt-1 mr-3"></i>
                                <span>Access medical records 24/7</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check-circle text-accent-green mt-1 mr-3"></i>
                                <span>Get appointment reminders</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check-circle text-accent-green mt-1 mr-3"></i>
                                <span>View test results online</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check-circle text-accent-green mt-1 mr-3"></i>
                                <span>Secure health data storage</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Security Card -->
                    <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl shadow-lg p-6 border border-blue-100">
                        <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                            <i class="fas fa-shield-alt text-primary-teal mr-2"></i>
                            Your Data is Safe
                        </h3>
                        <p class="text-sm text-gray-600 mb-4">
                            We use industry-standard encryption to protect your personal and medical information.
                        </p>
                        <div class="flex items-center gap-4 text-xs text-gray-600">
                            <div class="flex items-center">
                                <i class="fas fa-lock text-primary-teal mr-2"></i>
                                SSL Encrypted
                            </div>
                            <div class="flex items-center">
                                <i class="fas fa-user-shield text-primary-teal mr-2"></i>
                                HIPAA Compliant
                            </div>
                        </div>
                    </div>

                    <!-- Help Card -->
                    <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
                        <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center">
                            <i class="fas fa-question-circle text-primary-blue mr-2"></i>
                            Need Help?
                        </h3>
                        <p class="text-sm text-gray-600 mb-4">
                            Contact our support team if you face any issues during registration.
                        </p>
                        <a href="tel:+912345678900" class="flex items-center text-primary-blue font-semibold text-sm hover:text-primary-teal transition-colors">
                            <i class="fas fa-phone mr-2"></i>
                            +91 234 567 890
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

<%- include('../components/footer') %>

<script>
      function getCookie(name) {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) return parts.pop().split(';').shift();
  }

  window.onload = () => {
    const cookieValue = getCookie("signup_details");
    if (cookieValue) {
      const decoded = decodeURIComponent(cookieValue);
      const parsed = JSON.parse(decoded);
      document.getElementById("email").value = parsed.email;
    }
  };

async function insertSignUpDetails() {
  // Collect all form values
  const firstname = document.getElementById("firstname").value.trim();
  const lastname = document.getElementById("lastname").value.trim();
  const email = document.getElementById("email").value.trim();
  const mobile = document.getElementById("mobile").value.trim();
  const dob = document.getElementById("dob").value;
  const gender = document.querySelector("input[name='gender']:checked")?.value;
  const blood_group = document.getElementById("blood_group").value;
  const address = document.getElementById("address").value.trim();

  // Basic validation
  if (!firstname || !lastname || !email || !mobile || !dob || !gender || !blood_group || !address) {
    Swal.fire({
      icon: "warning",
      title: "Missing Details",
      text: "Please fill all required fields.",
      confirmButtonColor: "#0d9488",
    });
    return;
  }

  // Prepare the data
  const payload = {
    firstname,
    lastname,
    email,
    mobile,
    dob,
    gender,
    blood_group,
    address
  };

  try {
    const response = await fetch("/patient/signup/insert_registration_details", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify(payload),
    });

    if (response.status === 200) {
      Swal.fire({
        icon: "success",
        title: "Registration Complete!",
        text: "Redirecting to your dashboard...",
        confirmButtonColor: "#0d9488",
      }).then(() => {
        location.href = "/patient/login";
      });
    } else if (response.status === 500) {
      const data = await response.json();
      Swal.fire({
        icon: "error",
        title: "Invalid Data",
        text: data.message || "Please check your details.",
        confirmButtonColor: "#dc2626",
      });
        location.href = "/patient/signup/email";
    } else {
      throw new Error("Unexpected response");

    }
  } catch (error) {
    console.error("Error submitting registration:", error);
    Swal.fire({
      icon: "error",
      title: "Server Error",
      text: "Something went wrong. Please try again later.",
      confirmButtonColor: "#dc2626",
    });
        location.href = "/patient/signup/email";

  }
}

</script>

