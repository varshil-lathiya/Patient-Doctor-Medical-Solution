<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/assets/favicon.png" type="image/x-icon" />
    <title>PDMS - My Medical History</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-blue': '#0066CC',
                        'primary-teal': '#008B8B',
                        'accent-green': '#00A86B',
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gray-50 min-h-screen">
    <%- include('../components/patient-sidebar') %>

        <main class="ml-64 min-h-screen p-8" id="right-section">
            <!-- Back Button -->
            <div class="mb-4">
                <a href="/patient/dashboard"
                    class="inline-flex items-center gap-2 text-primary-teal hover:text-slate-800 font-bold transition-all group">
                    <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                    Back to Dashboard
                </a>
            </div>

            <div class="mb-8 flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900 mb-1">Medical History</h1>
                    <p class="text-gray-600">Review your past consultations and prescriptions</p>
                </div>
            </div>

            <div class="space-y-4">
                <% if (history && history.length> 0) { %>
                    <% history.forEach(record=> { %>
                        <div
                            class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex flex-col md:flex-row md:items-center justify-between gap-6 hover:shadow-md transition-all">
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center overflow-hidden border border-gray-100">
                                    <img src="https://ui-avatars.com/api/?name=Dr+<%= record.d_first %>+<%= record.d_last %>&size=64&background=eee&color=333&bold=true"
                                        alt="Doctor" class="w-full h-full object-cover" />
                                </div>
                                <div>
                                    <h3 class="text-lg font-bold text-gray-900">Dr. <%= record.d_first %>
                                            <%= record.d_last %>
                                    </h3>
                                    <p class="text-gray-500 font-bold text-xs uppercase">
                                        <%= record.department %>
                                    </p>
                                </div>
                            </div>

                            <div class="flex-1 px-8 md:border-l md:border-r border-gray-100">
                                <div class="flex items-center justify-between mb-2">
                                    <p class="text-sm font-bold text-gray-400 uppercase tracking-widest">Diagnosis</p>
                                    <p class="text-xs font-bold text-gray-400">
                                        <%= new Date(record.slot_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %> • <%= record.slot_start
                                                %>
                                    </p>
                                </div>
                                <p class="text-gray-900 font-bold line-clamp-1">
                                    <%= record.diagnosis || record.summary_text || 'Consultation completed' %>
                                </p>
                            </div>

                            <div class="flex gap-2">
                                <button data-record="<%= JSON.stringify(record).replace(/" /g, '&quot;' ) %>"
                                    onclick="openSummaryModal(this)" class="bg-primary-teal text-white
                                    hover:bg-slate-800 font-bold px-6 py-2.5 rounded-xl transition-all text-sm
                                    shadow-md">View Summary</button>
                                <button onclick="openFeedbackModal('<%= record.doctor_id %>', '<%= record.slot_id %>')"
                                    class="bg-yellow-50 text-yellow-600 hover:bg-yellow-500 hover:text-white font-bold px-6 py-2.5 rounded-xl transition-all text-sm">Feedback</button>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="py-20 text-center bg-white rounded-2xl border border-gray-100">
                                    <i class="fas fa-folder-open text-5xl text-gray-200 mb-4"></i>
                                    <h3 class="text-xl font-bold text-gray-400">No History Records Found</h3>
                                    <p class="text-gray-500">Your medical history will appear here after your first
                                        consultation.</p>
                                </div>
                                <% } %>
            </div>
        </main>

        <!-- Summary Modal -->
        <div id="summary-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
            <div class="bg-white rounded-3xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">
                <div
                    class="sticky top-0 bg-white border-b border-gray-100 px-8 py-5 flex items-center justify-between z-10">
                    <h3 class="text-2xl font-bold text-gray-900">Consultation Summary</h3>
                    <button onclick="closeModal('summary-modal')"
                        class="text-gray-400 hover:text-red-500 transition-colors bg-gray-100 w-10 h-10 rounded-full flex items-center justify-center text-xl">×</button>
                </div>

                <div class="p-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                        <div class="space-y-6">
                            <div class="bg-blue-50/50 p-6 rounded-2xl border border-blue-100">
                                <p class="text-xs font-bold text-blue-500 uppercase tracking-widest mb-2">Observations
                                </p>
                                <p id="modal-observation" class="text-gray-900 font-medium leading-relaxed"></p>
                            </div>
                            <div class="bg-green-50/50 p-6 rounded-2xl border border-green-100">
                                <p class="text-xs font-bold text-green-600 uppercase tracking-widest mb-2">Conclusion
                                </p>
                                <p id="modal-conclusion" class="text-gray-900 font-medium leading-relaxed"></p>
                            </div>
                        </div>
                        <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Prescription</p>
                            <div id="modal-prescription" class="space-y-3"></div>
                        </div>
                    </div>

                    <div class="bg-gray-900 rounded-2xl p-6 text-white flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-xs font-bold uppercase mb-1">Doctor's Remark</p>
                            <p id="modal-remark" class="font-medium italic">"Follow the prescription strictly and rest
                                well."</p>
                        </div>
                        <i class="fas fa-quote-right text-4xl text-white/10"></i>
                    </div>
                </div>

                <div class="p-8 border-t border-gray-100 text-center">
                    <button onclick="window.print()"
                        class="text-primary-blue font-bold hover:underline flex items-center gap-2 mx-auto">
                        <i class="fas fa-print"></i> Download PDF Summary
                    </button>
                </div>
            </div>
        </div>

        <!-- Feedback Modal -->
        <div id="feedback-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
            <div class="bg-white rounded-3xl shadow-2xl max-w-lg w-full">
                <div class="p-10 text-center">
                    <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="fas fa-star text-3xl text-yellow-500"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-2">Rate Your Experience</h3>
                    <p class="text-gray-500 mb-8">How was your consultation?</p>

                    <!-- Stars Layout: Removed inline onclick to avoid EJS linter confusion -->
                    <div class="flex justify-center gap-3 mb-8" id="rating-stars-container">
                        <% for(let i=1; i<=5; i++) { %>
                            <button type="button" data-rating="<%= i %>"
                                class="star-btn text-4xl text-gray-200 hover:text-yellow-400 transition-all"><i
                                    class="fas fa-star"></i></button>
                            <% } %>
                    </div>

                    <textarea id="feedback-comment"
                        class="w-full px-4 py-3 border-2 border-gray-100 rounded-2xl focus:ring-2 focus:ring-yellow-400 outline-none transition-all resize-none mb-6"
                        placeholder="Any additional comments?"></textarea>

                    <div class="flex gap-4">
                        <button type="button" onclick="closeModal('feedback-modal')"
                            class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-4 rounded-2xl transition-all">Cancel</button>
                        <button type="button" onclick="submitFeedback()"
                            class="flex-1 bg-yellow-500 hover:bg-yellow-600 text-white font-bold py-4 rounded-2xl transition-all shadow-lg">Submit
                            Feedback</button>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            let selectedDoctorId = null;
            let selectedSlotId = null;
            let currentRating = 0;

            // Initialize event listener for stars
            document.getElementById('rating-stars-container').addEventListener('click', (e) => {
                const btn = e.target.closest('.star-btn');
                if (btn) {
                    const rating = parseInt(btn.getAttribute('data-rating'));
                    setRating(rating);
                }
            });

            function closeModal(id) {
                document.getElementById(id).classList.add('hidden');
                document.body.style.overflow = 'auto';
            }

            function openSummaryModal(btn) {
                try {
                    const record = JSON.parse(btn.getAttribute('data-record'));
                    document.getElementById('modal-observation').textContent = record.observation || (record.summary_text ? 'See summary below' : 'No observations recorded.');
                    document.getElementById('modal-conclusion').textContent = record.conclusion || 'No conclusion recorded.';

                    if (record.summary_text && !record.observation) {
                        document.getElementById('modal-observation').innerHTML = `<span class="italic text-gray-500">Summary:</span><br>${record.summary_text.replace(/\n/g, '<br>')}`;
                    }

                    const prescContainer = document.getElementById('modal-prescription');
                    if (record.medicine) {
                        prescContainer.innerHTML = `<div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
                        <p class="text-gray-900 font-bold text-sm mb-2">Prescribed Medicines</p>
                        <p class="text-gray-600 text-sm whitespace-pre-line">${record.medicine}</p>
                        <p class="text-gray-400 text-xs mt-3">Dosage: ${record.dosage || '-'}</p>
                    </div>`;
                    } else {
                        prescContainer.innerHTML = '<p class="text-gray-400 italic text-sm">No medicine prescribed.</p>';
                    }

                    document.getElementById('summary-modal').classList.remove('hidden');
                    document.body.style.overflow = 'hidden';
                } catch (e) {
                    console.error('Error parsing record:', e);
                }
            }

            function openFeedbackModal(docId, slotId) {
                selectedDoctorId = docId;
                selectedSlotId = slotId;
                currentRating = 0;
                resetStars();
                document.getElementById('feedback-modal').classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            function setRating(r) {
                currentRating = r;
                const stars = document.querySelectorAll('#rating-stars-container .star-btn');
                stars.forEach((star, idx) => {
                    if (idx < r) {
                        star.classList.add('text-yellow-400');
                        star.classList.remove('text-gray-200');
                    } else {
                        star.classList.remove('text-yellow-400');
                        star.classList.add('text-gray-200');
                    }
                });
            }

            function resetStars() {
                document.querySelectorAll('#rating-stars-container .star-btn').forEach(b => {
                    b.classList.remove('text-yellow-400');
                    b.classList.add('text-gray-200');
                });
            }

            async function submitFeedback() {
                if (currentRating === 0) {
                    return Swal.fire('Rating Required', 'Please select at least one star.', 'warning');
                }
                const comment = document.getElementById('feedback-comment').value;
                const response = await fetch('/patient/rate-doctor', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ doctor_id: selectedDoctorId, slot_id: selectedSlotId, rating: currentRating, comment })
                });
                if (response.ok) {
                    Swal.fire('Success', 'Feedback submitted. Thank you!', 'success').then(() => closeModal('feedback-modal'));
                } else {
                    Swal.fire('Error', 'Failed to submit feedback.', 'error');
                }
            }
        </script>
</body>

</html>