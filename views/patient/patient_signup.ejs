<%- include('../components/header', { 
    title: 'Patient Registration -  Kalp Hospital', 
    page: 'signup' 
}) %>

<!-- Signup Section - Split Screen Design -->
<section class="min-h-screen flex">
    
    <!-- Left Side - Full Height Image -->
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden">
        <!-- Background Image -->
        <img 
            src="https://media.istockphoto.com/id/1476261444/photo/young-pharmaceutic-seller-explaining-something-to-doctor-in-hospital.jpg?s=612x612&w=0&k=20&c=pEJ7PefqTUcR5hPhB3jLIvAUOzPA6FVPlw391Oxqnrw=" 
            alt="Healthcare Professional" 
            class="absolute inset-0 w-full h-full object-cover"
        />
        
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary-teal/90 via-accent-green/80 to-secondary-cyan/90"></div>
        
        <!-- Content Over Image -->
        <div class="relative z-10 flex flex-col justify-center items-start p-16 text-white">
            <div class="max-w-md">
                <!-- Badge -->
                <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-6">
                    <div class="w-2 h-2 bg-white rounded-full animate-pulse"></div>
                    <span class="text-sm font-semibold">Join 50K+ Patients</span>
                </div>
                
                <h2 class="text-5xl font-bold mb-6 font-display leading-tight">
                    Your Health Journey Starts Here
                </h2>
                
                <p class="text-xl text-white/90 mb-8 leading-relaxed">
                    Experience world-class healthcare with instant access to specialists
                </p>
                
                <!-- Quick Features -->
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-white/20 backdrop-blur-sm rounded-lg flex items-center justify-center">
                            <i class="fas fa-check text-white"></i>
                        </div>
                        <span class="text-lg">Book appointments instantly</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-white/20 backdrop-blur-sm rounded-lg flex items-center justify-center">
                            <i class="fas fa-check text-white"></i>
                        </div>
                        <span class="text-lg">Access records 24/7</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-white/20 backdrop-blur-sm rounded-lg flex items-center justify-center">
                            <i class="fas fa-check text-white"></i>
                        </div>
                        <span class="text-lg">500+ expert doctors</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Side - Signup Form -->
    <div class="w-full lg:w-1/2 flex items-center justify-center bg-gradient-to-br from-gray-50 to-blue-50 p-8 sm:p-12">
        <div class="w-full max-w-md">
            
            <!-- Logo for Mobile -->
            <div class="lg:hidden text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-primary-teal to-accent-green rounded-2xl mb-4">
                    <i class="fas fa-hospital text-white text-2xl"></i>
                </div>
            </div>

            <!-- Form Card -->
            <div class="bg-white rounded-3xl shadow-2xl p-8 sm:p-10">
                
                <!-- Header -->
                <div class="mb-8">
                    <h1 class="text-3xl font-bold text-gray-900 mb-2 font-display">
                        Create Account
                    </h1>
                    <p class="text-gray-600">Get started in seconds</p>
                </div>

                <!-- Form -->
                <form id="login_form" class="space-y-6">
                    
                    <!-- Email Input -->
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
                            Email Address
                        </label>
                        <div class="relative">
                            <input 
                                type="email" 
                                id="email" 
                                name="email"
                                placeholder="yourname@example.com"
                                class="w-full px-4 py-3.5 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-primary-teal focus:ring-4 focus:ring-primary-teal/10 outline-none transition-all duration-200 text-gray-900"
                                required
                            />
                            <div class="absolute inset-y-0 right-0 flex items-center pr-4">
                                <i class="fas fa-envelope text-gray-400"></i>
                            </div>
                        </div>
                        <p id="emailError" class="text-red-600 text-sm mt-2 hidden"></p>
                    </div>

                    <!-- Submit Button -->
                    <button 
                    onclick="velidateEmail(event)"
                        type="button" 
                        id="btn-send-otp"
                        class="w-full bg-gradient-to-r from-primary-teal to-accent-green text-white font-bold py-4 rounded-xl hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200"
                    >   
                        <span class="flex items-center justify-center gap-2">
                            <i class="fas fa-rocket"></i>
                            Get Started
                        </span>
                    </button>

                    <!-- Error Message -->
                    <div id="otpError" class="text-center text-red-600 text-sm hidden"></div>

                    <!-- Divider -->
                    <div class="relative my-6">
                        <div class="absolute inset-0 flex items-center">
                            <div class="w-full border-t border-gray-200"></div>
                        </div>
                        <div class="relative flex justify-center text-sm">
                            <span class="px-4 bg-white text-gray-500">Already registered?</span>
                        </div>
                    </div>

                    <!-- Login Link -->
                    <a 
                        href="/patient/login" 
                        class="block w-full text-center py-3.5 border-2 border-gray-300 text-gray-700 font-semibold rounded-xl hover:border-primary-teal hover:text-primary-teal transition-all duration-200"
                    >
                        Sign In
                    </a>

                </form>

                <!-- Trust Badges -->
                <div class="flex items-center justify-center gap-6 mt-8 pt-6 border-t border-gray-100">
                    <div class="text-center">
                        <i class="fas fa-shield-alt text-primary-teal text-xl mb-1"></i>
                        <p class="text-xs text-gray-600 font-medium">Secure</p>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-lock text-accent-green text-xl mb-1"></i>
                        <p class="text-xs text-gray-600 font-medium">Private</p>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-bolt text-secondary-cyan text-xl mb-1"></i>
                        <p class="text-xs text-gray-600 font-medium">Fast</p>
                    </div>
                </div>
            </div>

            <!-- Mobile Features -->
            <div class="lg:hidden mt-8 space-y-3">
                <div class="flex items-center gap-3 text-gray-700">
                    <i class="fas fa-check-circle text-accent-green"></i>
                    <span class="text-sm">Book appointments instantly</span>
                </div>
                <div class="flex items-center gap-3 text-gray-700">
                    <i class="fas fa-check-circle text-accent-green"></i>
                    <span class="text-sm">Access records 24/7</span>
                </div>
                <div class="flex items-center gap-3 text-gray-700">
                    <i class="fas fa-check-circle text-accent-green"></i>
                    <span class="text-sm">500+ expert doctors</span>
                </div>
            </div>

        </div>
    </div>

</section>

<%- include('../components/footer') %>


<script>
  async function velidateEmail(e) {
    e.preventDefault();

    // Select elements
    const emailInput = document.getElementById('email');
    const emailError = document.getElementById('emailError');
    const btnSendOtp = document.getElementById('btn-send-otp');

    // Clear previous error
    emailError.classList.add('hidden');
    emailError.textContent = '';

    const userIncommingEmail = emailInput.value.trim();

    // Basic validation
    if (!userIncommingEmail) {
      emailError.textContent = 'Please enter your email address';
      emailError.classList.remove('hidden');
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(userIncommingEmail)) {
      emailError.textContent = 'Please enter a valid email address';
      emailError.classList.remove('hidden');
      return;
    }

    // Show loading state
    const originalHTML = btnSendOtp.innerHTML;
    btnSendOtp.disabled = true;
    btnSendOtp.innerHTML = `
      <span class="flex items-center justify-center gap-2">
        <i class="fas fa-spinner fa-spin"></i>
        Sending...
      </span>
    `;

    try {
      const response = await fetch('/patient/signup/emailVerification', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: userIncommingEmail })
      });

      const data = await response.json();
      console.log(data);
      
      // Handle response
      if (response.status === 200) {
        // Success: navigate or show success
        btnSendOtp.innerHTML = `
          <span class="flex items-center justify-center gap-2">
            <i class="fas fa-check-circle"></i>
            Success!
          </span>
        `;
        btnSendOtp.classList.add('bg-green-600');

        // Redirect or next step
        setTimeout(() => {
          location.href = '/patient/signup/otp_verifiaction_page';
        }, 1000);
      } 
      else if (response.status === 400) {
        // Show specific error under input box
        emailError.textContent = data.message;
        emailError.classList.remove('hidden');
      } 
      else {
        // Other errors
        emailError.textContent = data.message || 'Something went wrong. Please try again.';
        emailError.classList.remove('hidden');
      }

    } catch (err) {
      console.error('Fetch error:', err);
      emailError.textContent = 'Network error. Please try again later.';
      emailError.classList.remove('hidden');
    } 
    finally {
      btnSendOtp.disabled = false;
      btnSendOtp.innerHTML = originalHTML;
      btnSendOtp.classList.remove('bg-green-600');
    }
  }
</script>
