                        <!-- Feature 3 -->
                        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                            <div class="flex items-start gap-5">
                                <div class="flex-shrink-0">
                                    <div class="w-14 h-14 bg-gradient-to-br from-green-100 to-green-200 rounded-xl flex items-center justify-center shadow-md group-hover:scale-110 transition-transform duration-300">
                                        <i class="fas fa-heart-pulse text-accent-green text-2xl"></i>
                                    </div>
                                </div>
                                <div class="flex-1">
                                    <h3 class="font-bold text-gray-900 text-lg mb-2">Real-Time Health Monitoring</h3>
                                    <p class="text-gray-600 text-sm leading-relaxed">
                                        Track vitals, medications, and treatment progress with our advanced monitoring system
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

