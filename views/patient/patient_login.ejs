                                    <div class="flex items-start gap-4">
                                        <div class="flex-shrink-0">
                                            <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center shadow-sm">
                                                <i class="fas fa-shield-alt text-primary-blue text-lg"></i>
                                            </div>
                                        </div>
                                        <div>
                                            <p class="font-bold text-gray-900 mb-1">Secure Authentication</p>
                                            <p class="text-sm text-gray-600 leading-relaxed">
                                                We'll send a one-time verification code to your registered email address for secure access
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Divider -->
                                <div class="relative flex items-center py-4">
                                    <div class="flex-grow border-t-2 border-gray-200"></div>
                                    <span class="flex-shrink mx-4 text-gray-500 font-semibold text-sm">OR</span>
                                    <div class="flex-grow border-t-2 border-gray-200"></div>
                                </div>

                                <!-- Register Button -->
                                <a 
                                    href="/patient/signup/email" 
                                    class="group block w-full text-center py-4 border-2 border-primary-blue text-primary-blue font-bold rounded-xl hover:bg-primary-blue hover:text-white transition-all duration-300 shadow-sm hover:shadow-lg"
                                >
                                    <i class="fas fa-user-plus mr-2 text-lg"></i>
                                    Create New Account
                                    <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform duration-300"></i>
                                </a>

                                <!-- Back to Home -->
                                <div class="text-center pt-2">
                                    <a 
                                        href="/" 
                                        class="inline-flex items-center gap-2 text-gray-600 hover:text-primary-blue transition-colors text-sm font-semibold group"
                                    >
                                        <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform duration-300"></i>
                                        <span>Back to Homepage</span>
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Security Features -->
                    <div class="grid grid-cols-3 gap-4 mt-8">
                        <div class="bg-white rounded-2xl p-4 shadow-lg border border-gray-100 text-center hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                            <div class="w-12 h-12 bg-gradient-to-br from-blue-100 to-blue-200 rounded-xl flex items-center justify-center mx-auto mb-3">
