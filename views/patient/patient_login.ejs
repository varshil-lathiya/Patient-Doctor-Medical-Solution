<%- include('../components/header', { 
    title: 'Patient Login -  Kalp Hospital', 
    page: 'login',
}) %>


<section class="relative min-h-screen py-16 lg:py-20 overflow-hidden">
   
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-cyan-50">
     
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #0066CC 1px, transparent 1px); background-size: 40px 40px;"></div>
        
        <div class="absolute top-20 left-10 w-72 h-72 bg-gradient-to-br from-primary-blue/20 to-primary-teal/20 rounded-full blur-3xl animate-float"></div>
        <div class="absolute bottom-20 right-10 w-96 h-96 bg-gradient-to-br from-accent-green/20 to-secondary-cyan/20 rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
    </div>

    <div class="relative container mx-auto px-4 sm:px-6 lg:px-12 xl:px-20">
