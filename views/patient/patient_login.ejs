<%- include('../components/footer') %>

 <script>
    // Verification function
    async function verification() {
        try {
        const email = document.getElementById('email').value.trim();

        document.getElementById('emailError').classList.add('hidden');
        document.getElementById('otpError').classList.add('hidden');

        try {
            const response = await fetch('/patient/login/emailVerification', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email }),
            });

            const data = await response.json();

            if (response.status === 200) {
                // OTP sent successfully, redirect to OTP verification page
                window.location.href = '/patient/login/otpVerificationPage';
            } else if (response.status === 400) {
                // Show specific error under input box
                const emailError = document.getElementById('emailError');
                emailError.querySelector('span').textContent = data.message;
                emailError.classList.remove('hidden');
            } else {
                // Other errors
                const otpError = document.getElementById('otpError');
                otpError.textContent = data.message || 'Something went wrong. Please try again.';
                otpError.classList.remove('hidden');
            }
        } catch (error) {
            console.error('Error sending OTP:', error);
            const otpError = document.getElementById('otpError');
            otpError.textContent = 'An error occurred while sending the OTP. Please try again later.';
            otpError.classList.remove('hidden');
        }
        } catch (error) {
            console.error('Verification error:', error);
        }
    }

</script>
