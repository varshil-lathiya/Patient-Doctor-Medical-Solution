                            <!-- Header Section -->
                            <div class="text-center mb-8">
                                <!-- Icon with Gradient Background -->
                                <div class="relative inline-block mb-6">
                                    <div class="absolute inset-0 bg-gradient-to-br from-primary-blue to-primary-teal rounded-2xl blur-lg opacity-50"></div>
                                    <div class="relative bg-gradient-to-br from-primary-blue to-primary-teal p-5 rounded-2xl shadow-lg">
                                        <i class="fas fa-user-doctor text-white text-4xl"></i>
                                    </div>
                                </div>
                                
