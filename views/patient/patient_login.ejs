                                    <!-- Gradient Background -->
                                    <div class="absolute inset-0 bg-gradient-to-r from-primary-blue to-primary-teal"></div>
                                    <div class="absolute inset-0 bg-gradient-to-r from-primary-teal to-accent-green opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                                    
                                    <!-- Button Content -->
                                    <div class="relative flex items-center justify-center gap-3 py-4 text-white font-bold text-lg">
                                        <i class="fas fa-paper-plane text-xl group-hover:translate-x-1 transition-transform duration-300"></i>
                                        <span>Send Verification Code</span>
                                    </div>
                                </button>

                                <!-- OTP Error -->
                                <div id="otpError" class="text-center text-red-600 text-sm font-medium hidden"></div>

                                <!-- Info Box -->
