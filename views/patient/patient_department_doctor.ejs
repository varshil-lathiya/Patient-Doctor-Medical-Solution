<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/assets/favicon.png" type="image/x-icon" />
    <title>
        <%= departmentName %> - PDMS
    </title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Custom Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-blue': '#0066CC',
                        'primary-teal': '#008B8B',
                        'secondary-cyan': '#00B4D8',
                        'accent-green': '#00A86B',
                    }
                }
            }
        }
    </script>
    <style>
        @media (max-width: 1023px) {
            body > aside {
                display: none !important;
            }

            #right-section {
                margin-left: 0 !important;
                padding: 1rem !important;
            }

            .department-header {
                align-items: flex-start;
            }

            .doctor-card-title,
            .department-title {
                overflow-wrap: anywhere;
            }

            .modal-body-padding {
                padding: 1rem;
            }

            #slots-container {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen">

    <!-- Sidebar Navigation -->
    <%- include('../components/patient-sidebar') %>

        <!-- Main Content Area -->
        <main class="ml-64 min-h-screen p-8" id="right-section">

            <!-- Back Button -->
            <div class="mb-4">
                <a href="/patient/dashboard"
                    class="inline-flex items-center gap-2 text-primary-teal hover:text-slate-800 font-bold transition-all group">
                    <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                    Back to Dashboard
                </a>
            </div>

            <!-- Breadcrumb -->
            <nav class="mb-6">
                <ol class="flex flex-wrap items-center gap-2 text-sm">
                    <li>
                        <a href="/patient/dashboard"
                            class="text-primary-blue hover:text-primary-teal transition-colors flex items-center gap-1">
                            <i class="fas fa-home"></i>
                            Dashboard
                        </a>
                    </li>
                    <li class="text-gray-400">/</li>
                    <li class="text-gray-600 font-medium font-bold">
                        <%= departmentName %>
                    </li>
                </ol>
            </nav>

            <!-- Department Header -->
            <div class="mb-8">
                <div class="department-header flex items-center gap-4 mb-3">
                    <div
                        class="w-16 h-16 bg-gradient-to-br from-primary-blue to-primary-teal rounded-xl flex items-center justify-center shadow-lg">
                        <i class="fas fa-hospital text-3xl text-white"></i>
                    </div>
                    <div>
                        <h1 class="department-title text-2xl sm:text-3xl font-bold text-gray-900 uppercase tracking-tight">
                            <%= departmentName %>
                        </h1>
                        <p class="text-gray-600">Select a doctor to schedule your consultation</p>
                    </div>
                </div>
            </div>

            <!-- Doctors Section -->
            <section>
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                        <i class="fas fa-user-doctor text-primary-teal"></i>
                        Available Specialists
                    </h2>
                </div>

                <!-- Doctors Grid -->
                <div id="doctors-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% if (doctors && doctors.length> 0) { %>
                        <% doctors.forEach(doc=> { %>
                            <div
                                class="bg-white rounded-2xl shadow-sm hover:shadow-xl hover:scale-[1.02] transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col">
                                <div class="p-6 flex-1">
                                    <div class="flex items-start gap-4 mb-4">
                                        <div class="flex-shrink-0">
                                            <div
                                                class="w-16 h-16 rounded-full bg-gradient-to-br from-primary-blue to-primary-teal flex items-center justify-center shadow-lg overflow-hidden">
                                                <img src="<%= doc.profile_pic || `https://ui-avatars.com/api/?name=Dr+${doc.firstname}+${doc.lastname}&size=64&background=0066CC&color=fff&bold=true` %>"
                                                    alt="Doctor" class="w-full h-full object-cover" />
                                            </div>
                                        </div>
                                        <div class="flex-1">
                                            <h3 class="doctor-card-title text-lg font-bold text-gray-900 mb-0.5">Dr. <%= doc.firstname %>
                                                    <%= doc.lastname %>
                                            </h3>
                                            <div class="flex items-center gap-1 mb-2">
                                                <% for(let i=1; i<=5; i++) { %>
                                                    <i
                                                        class="fas fa-star text-sm <%= i <= Math.round(doc.rating_avg || 0) ? 'text-yellow-400' : 'text-gray-200' %>"></i>
                                                    <% } %>
                                                        <span class="text-xs text-gray-500 font-bold ml-1">(<%=
                                                                Number(doc.rating_avg || 0).toFixed(2) %>)</span>
                                            </div>
                                            <div
                                                class="inline-flex items-center gap-1.5 bg-green-50 text-green-700 px-2.5 py-1 rounded-full text-xs font-bold">
                                                <i class="fas fa-certificate"></i>
                                                <span>
                                                    <%= doc.experience %> Years Exp.
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="space-y-2 mb-6 text-sm text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <i class="fas fa-graduation-cap text-primary-blue w-4"></i>
                                            <span class="font-medium">
                                                <%= doc.qualification || 'MBBS, MD' %>
                                            </span>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <i class="fas fa-clock text-primary-blue w-4"></i>
                                            <span class="font-medium">Available Today</span>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <i class="fas fa-chair text-primary-teal w-4"></i>
                                            <span class="font-bold text-primary-teal">
                                                <%= doc.available_slots %> Seats Available
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="p-4 bg-gray-50 border-t border-gray-100 mt-auto">
                                    <button
                                        onclick="openSlotModal('<%= doc.id %>', '<%= doc.firstname %> <%= doc.lastname %>', '<%= doc.department %>', '<%= doc.profile_pic || `https://ui-avatars.com/api/?name=Dr+${doc.firstname}+${doc.lastname}&size=64&background=0066CC&color=fff&bold=true` %>')"
                                        class="w-full bg-primary-teal hover:bg-slate-800 text-white font-bold py-3 rounded-xl transition-all shadow-md active:scale-95">
                                        Book Appointment
                                    </button>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div
                                        class="col-span-full py-20 text-center bg-white rounded-2xl border border-gray-200">
                                        <i class="fas fa-user-tie text-5xl text-gray-300 mb-4"></i>
                                        <h3 class="text-xl font-bold text-gray-400">No Doctors Found</h3>
                                        <p class="text-gray-500">There are no specialists currently listed in this
                                            department.</p>
                                    </div>
                                    <% } %>
                </div>
            </section>
        </main>

        <!-- Slot Selection Modal -->
        <div id="slot-modal"
            class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
            <div class="bg-white rounded-3xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
                <div
                    class="sticky top-0 bg-white border-b border-gray-100 px-4 sm:px-8 py-5 flex items-center justify-between gap-4 z-10">
                    <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Select Time Slot</h3>
                    <button onclick="closeSlotModal()"
                        class="text-gray-400 hover:text-red-500 transition-colors bg-gray-100 w-10 h-10 rounded-full flex items-center justify-center text-xl">×</button>
                </div>

                <div class="modal-body-padding p-8">
                    <div class="flex items-center gap-5 mb-8 p-5 bg-blue-50/50 rounded-2xl border border-blue-100">
                        <div
                            class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary-blue to-primary-teal flex items-center justify-center shadow-md overflow-hidden">
                            <img id="modal-doctor-image" src="" alt="Doctor" class="w-full h-full object-cover" />
                        </div>
                        <div>
                            <h4 class="text-xl font-bold text-gray-900" id="modal-doctor-name"></h4>
                            <p class="text-sm text-primary-teal font-bold" id="modal-doctor-dept"></p>
                            <div class="mt-2 inline-flex items-center gap-1.5 bg-amber-50 text-amber-700 px-3 py-1 rounded-full text-xs font-bold border border-amber-100">
                                <i class="fas fa-ticket-alt"></i>
                                <span>Token Fee: ₹200</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-8">
                        <h5 class="text-sm font-bold text-gray-500 mb-4 uppercase tracking-widest">Select Date</h5>
                        <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide" id="date-selection">
                            <!-- Dates will be generated here -->
                        </div>
                    </div>

                    <div>
                        <h5 class="text-sm font-bold text-gray-500 mb-4 uppercase tracking-widest">Available Slots</h5>
                        <div id="slots-container" class="grid grid-cols-3 sm:grid-cols-4 gap-3">
                            <p class="col-span-full text-center text-gray-400 italic">Please select a date first</p>
                        </div>
                    </div>
                </div>

                <div class="sticky bottom-0 bg-white border-t border-gray-100 p-4 sm:p-8">
                    <button id="book-btn" onclick="bookAppointment()" disabled
                        class="w-full bg-primary-teal text-white font-bold py-4 rounded-2xl transition-all text-lg shadow-lg disabled:bg-gray-200 disabled:text-gray-400 disabled:shadow-none hover:bg-slate-800">
                        Confirm Booking
                    </button>
                </div>
            </div>
        </div>

        <!-- Scripts -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            let currentDoctorId = null;
            let selectedDate = null;
            let selectedSlotId = null;

            function openSlotModal(doctorId, doctorName, department, doctorImg) {
                currentDoctorId = doctorId;
                document.getElementById('modal-doctor-name').textContent = 'Dr. ' + doctorName;
                document.getElementById('modal-doctor-dept').textContent = department;
                document.getElementById('modal-doctor-image').src = doctorImg;

                generateDates();
                document.getElementById('slot-modal').classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            function closeSlotModal() {
                document.getElementById('slot-modal').classList.add('hidden');
                document.body.style.overflow = 'auto';
                currentDoctorId = null;
                selectedDate = null;
                selectedSlotId = null;
                document.getElementById('book-btn').disabled = true;
            }

            function generateDates() {
                const container = document.getElementById('date-selection');
                container.innerHTML = '';

                const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                const today = new Date();

                for (let i = 0; i < 7; i++) {
                    const date = new Date(today);
                    date.setDate(today.getDate() + i);

                    // Use local date format YYYY-MM-DD
                    const dateStr = date.getFullYear() + '-' + 
                                  String(date.getMonth() + 1).padStart(2, '0') + '-' + 
                                  String(date.getDate()).padStart(2, '0');
                    const dayName = days[date.getDay()];
                    const dayNum = date.getDate();

                    const btn = document.createElement('button');
                    btn.className = `flex-shrink-0 w-16 h-20 rounded-2xl flex flex-col items-center justify-center transition-all border-2 ${i === 0 ? 'bg-primary-teal text-white border-primary-teal' : 'bg-white text-gray-600 border-gray-100 hover:border-primary-teal'}`;
                    btn.onclick = () => selectDate(dateStr, btn);
                    btn.innerHTML = `<span class="text-xs font-bold uppercase">${dayName}</span><span class="text-xl font-bold">${dayNum}</span>`;
                    container.appendChild(btn);

                    if (i === 0) selectDate(dateStr, btn);
                }
            }

            async function selectDate(date, btn) {
                selectedDate = date;
                selectedSlotId = null;
                document.getElementById('book-btn').disabled = true;

                // UI Update
                document.querySelectorAll('#date-selection button').forEach(b => {
                    b.classList.remove('bg-primary-teal', 'text-white', 'border-primary-teal');
                    b.classList.add('bg-white', 'text-gray-600', 'border-gray-100');
                });
                btn.classList.add('bg-primary-teal', 'text-white', 'border-primary-teal');
                btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-100');

                fetchSlots(date);
            }

            async function fetchSlots(date) {
                const container = document.getElementById('slots-container');
                container.innerHTML = '<div class="col-span-full py-4 flex justify-center"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary-teal"></div></div>';

                try {
                    const response = await fetch(`/patient/get-slots?doctor_id=${currentDoctorId}&date=${date}`);
                    const data = await response.json();

                    if (data.slots && data.slots.length > 0) {
                        container.innerHTML = data.slots.map(slot => `
                        <button onclick="selectSlot('${slot.id}', this)" class="slot-btn p-3 rounded-xl border-2 border-gray-100 text-gray-700 font-bold text-sm hover:border-primary-teal transition-all">
                            ${slot.slot_start}
                        </button>
                    `).join('');
                    } else {
                        container.innerHTML = `<p class="col-span-full text-center text-red-500 py-4 font-bold">${data.message || 'No slots available for this date'}</p>`;
                    }
                } catch (err) {
                    container.innerHTML = '<p class="col-span-full text-center text-red-500 py-4">Error loading slots</p>';
                }
            }

            function selectSlot(id, btn) {
                selectedSlotId = id;
                document.querySelectorAll('.slot-btn').forEach(b => {
                    b.classList.remove('bg-primary-teal', 'text-white', 'border-primary-teal');
                    b.classList.add('border-gray-100', 'text-gray-700');
                });
                btn.classList.add('bg-primary-teal', 'text-white', 'border-primary-teal');
                btn.classList.remove('border-gray-100', 'text-gray-700');
                document.getElementById('book-btn').disabled = false;
            }

            async function bookAppointment() {
                if (!selectedSlotId) return;

                const result = await Swal.fire({
                    title: 'Confirm Booking',
                    text: `Schedule appointment for ${selectedDate}?`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#008B8B',
                    confirmButtonText: 'Yes, proceed to payment'
                });

                if (!result.isConfirmed) return;

                Swal.fire({
                    title: 'Processing...',
                    text: 'Redirecting to payment gateway',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                try {
                    const response = await fetch('/patient/create-checkout-session', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            slot_id: selectedSlotId,
                            doctor_id: currentDoctorId,
                            doctor_name: document.getElementById('modal-doctor-name').textContent.replace('Dr. ', '')
                        })
                    });
                    const data = await response.json();

                    if (response.ok && data.url) {
                        window.location.href = data.url;
                    } else {
                        Swal.fire('Error', data.message || 'Payment initiation failed', 'error');
                    }
                } catch (err) {
                    Swal.fire('Error', 'An error occurred. Please try again.', 'error');
                }
            }

            document.getElementById('slot-modal').addEventListener('click', function (e) {
                if (e.target === this) closeSlotModal();
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeSlotModal();
            });
        </script>
        <script src="/js/patient/patient_navbar.js"></script>
</body>

</html>
